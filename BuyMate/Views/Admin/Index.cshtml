@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mb-5">
    <div class="rounded-3 text-white p-4 p-md-5 mb-4 shadow" style="background:linear-gradient(135deg,#4c1d95 0%,#7c3aed 45%,#e9d5ff 140%);">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-md-between gap-3">
            <div>
                <h1 class="h4 fw-bold mb-1">Admin Dashboard</h1>
                <p class="small text-white-50 mb-0">Control center for products & categories management.</p>
            </div>
            <div class="d-flex flex-wrap align-items-center gap-2">
                <a asp-controller="Product" asp-action="Create" class="btn btn-outline-light btn-sm d-inline-flex align-items-center gap-1">
                    <i class="fas fa-plus"></i>
                    <span>New Product</span>
                </a>
                <a asp-controller="Category" asp-action="Create" class="btn btn-outline-light btn-sm d-inline-flex align-items-center gap-1">
                    <i class="fas fa-folder-plus"></i>
                    <span>New Category</span>
                </a>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card h-100 border-purple shadow-sm" style="cursor:pointer;" onclick="location.href='@Url.Action("Index", "Product")'">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-start justify-content-between mb-3">
                        <div>
                            <h3 class="small fw-bold text-primary mb-1">Products</h3>
                            <p class="small text-muted mb-0">Create, edit, and delete products.</p>
                        </div>
                        <div class="rounded bg-light d-flex align-items-center justify-content-center text-primary" style="width:3rem;height:3rem;">
                            <i class="fas fa-box-open"></i>
                        </div>
                    </div>
                    <div class="mt-auto">
                        <a asp-controller="Product" asp-action="Create" class="btn btn-dark btn-sm w-100" onclick="event.stopPropagation();">
                            <i class="fas fa-plus me-1"></i> Create New
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card h-100 border-purple shadow-sm" style="cursor:pointer;" onclick="location.href='@Url.Action("Index", "Category")'">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-start justify-content-between mb-3">
                        <div>
                            <h3 class="small fw-bold text-primary mb-1">Categories</h3>
                            <p class="small text-muted mb-0">Organize products by categories.</p>
                        </div>
                        <div class="rounded bg-light d-flex align-items-center justify-content-center text-primary" style="width:3rem;height:3rem;">
                            <i class="fas fa-tags"></i>
                        </div>
                    </div>
                    <div class="mt-auto">
                        <a asp-controller="Category" asp-action="Create" class="btn btn-dark btn-sm w-100" onclick="event.stopPropagation();">
                            <i class="fas fa-plus me-1"></i> Create New
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card h-100 border-purple shadow-sm" style="cursor:pointer;" onclick="location.href='@Url.Action("GetAll", "Order")'">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-start justify-content-between mb-3">
                        <div>
                            <h3 class="small fw-bold text-primary mb-1">Orders</h3>
                            <p class="small text-muted mb-0">Manage customer orders.</p>
                        </div>
                        <div class="rounded bg-light d-flex align-items-center justify-content-center text-primary" style="width:3rem;height:3rem;">
                            <i class="fas fa-shopping-cart"></i>
                        </div>
                    </div>
                    <div class="mt-auto small text-muted">
                        View and process orders
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-lg-3">
            <div class="card h-100 border-purple shadow-sm">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-start justify-content-between mb-3">
                        <div>
                            <h3 class="small fw-bold text-primary mb-1">Analytics</h3>
                            <p class="small text-muted mb-0">Add sales and inventory KPIs here.</p>
                        </div>
                        <div class="rounded bg-light d-flex align-items-center justify-content-center text-primary" style="width:3rem;height:3rem;">
                            <i class="fas fa-chart-line"></i>
                        </div>
                    </div>
                    <div class="mt-auto small text-muted">
                        Coming soon...
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
