@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="max-w-2xl mx-auto text-center">
    <div class="card p-8">
        <div class="mb-6">
            <svg class="w-24 h-24 mx-auto text-green-500 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <h1 class="text-3xl font-bold mb-2">Order Confirmed!</h1>
            <p class="text-muted-foreground">Thank you for your purchase</p>
        </div>

        <div class="bg-muted/30 rounded-lg p-6 mb-6">
            <h2 class="text-lg font-semibold mb-2">Order Details</h2>
            <p class="text-sm text-muted-foreground mb-2">Order ID: @ViewBag.OrderId</p>
            <p class="text-sm text-muted-foreground">We'll send you a confirmation email shortly.</p>
        </div>

        <div class="space-y-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                Continue Shopping
            </a>
            <a asp-controller="Account" asp-action="Orders" class="btn btn-secondary">
                View My Orders
            </a>
        </div>
    </div>
</div>
