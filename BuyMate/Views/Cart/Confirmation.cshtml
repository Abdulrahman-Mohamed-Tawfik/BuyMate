@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="container mb-5" style="max-width: 36rem;">
    <div class="card p-4 p-md-5 text-center mt-4">
        <div class="mb-3">
            <i class="fas fa-check-circle fa-3x text-success mb-2"></i>
            <h1 class="h4 fw-bold mb-1">Order Confirmed!</h1>
            <p class="text-muted mb-0">Thank you for your purchase</p>
        </div>

        <div class="bg-light rounded-3 p-3 mb-3 text-start">
            <h2 class="h6 fw-bold mb-2">Order Details</h2>
            <p class="small text-muted mb-1">Order ID: @ViewBag.OrderId</p>
            <p class="small text-muted mb-0">We'll send you a confirmation email shortly.</p>
        </div>

        <div class="d-flex flex-column gap-2 mt-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-dark btn-lg w-100">
                Continue Shopping
            </a>
            <a asp-controller="Account" asp-action="Orders" class="btn btn-outline-secondary w-100">
                View My Orders
            </a>
        </div>
    </div>
</div>
