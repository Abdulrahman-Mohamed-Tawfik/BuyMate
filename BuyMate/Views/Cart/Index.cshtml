@using BuyMate.DTO.ViewModels.Cart
@model CartViewModel

@{
    ViewData["Title"] = "Shopping Cart";
    var requestToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<div class="container mb-5" style="max-width: 48rem;">
    <input type="hidden" id="__RequestVerificationToken" value="@requestToken" />

    <h1 class="h3 fw-bold mb-4">Shopping Cart</h1>

    @if (Model is not null && Model.Items.Count != 0)
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var item in Model.Items)
            {
                <div class="card p-3">
                    <div class="d-flex align-items-center gap-3">
                        <img src="/images/@(item.ImageUrl ?? "placeholder.png")" alt="@item.ProductName" class="rounded" style="width:80px;height:80px;object-fit:contain;" />
                        <div class="flex-grow-1">
                            <h3 class="h6 fw-semibold mb-1">@item.ProductName</h3>
                            <div class="d-flex align-items-center flex-wrap gap-3 mt-1">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="small">Quantity:</span>
                                    <div class="input-group input-group-sm" style="width:auto;">
                                        <button type="button" class="btn btn-outline-secondary" onclick="changeItemQuantity('@item.ItemId', -1)">-</button>
                                        <input id="qty-@item.ItemId" type="text" class="form-control text-center" style="max-width:3rem;" value="@item.Quantity" readonly />
                                        <button type="button" class="btn btn-outline-secondary" onclick="changeItemQuantity('@item.ItemId',1)">+</button>
                                    </div>
                                </div>
                                <span class="fw-bold">$@item.TotalPrice</span>
                            </div>
                        </div>
                        <button class="btn btn-outline-danger btn-sm" onclick="removeFromCart('@item.ItemId')">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </div>
            }

            <div class="card p-3 mt-2">
                <h2 class="h5 fw-bold mb-3">Order Summary</h2>
                <div class="d-flex flex-column gap-1 mb-2">
                    <div class="d-flex justify-content-between">
                        <span>Subtotal</span>
                        <span>$@Model.Subtotal</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Shipping</span>
                        <span>Free</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Tax</span>
                        <span>$0.00</span>
                    </div>
                    <hr class="my-3" />
                    <div class="d-flex justify-content-between fw-bold">
                        <span>Total</span>
                        <span>$@Model.Total</span>
                    </div>
                </div>
                <div class="mt-3 d-flex flex-column gap-2">
                    <a asp-controller="Order" asp-action="Checkout" class="btn btn-dark w-100">
                        Proceed to Checkout
                    </a>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary w-100">
                        Continue Shopping
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fa-solid fa-cart-shopping fa-3x text-muted mb-3"></i>
            <h2 class="h4 fw-bold mb-2">Your cart is empty</h2>
            <p class="text-muted mb-3">Looks like you haven't added any items to your cart yet.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-dark btn-lg">
                Start Shopping
            </a>
        </div>
    }
</div>

<script src="~/js/cart.js"></script>
