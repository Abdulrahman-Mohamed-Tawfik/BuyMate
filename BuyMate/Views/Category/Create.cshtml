@model BuyMate.DTO.Category.CreateCategoryDto

@{
    ViewData["Title"] = "Create Category";
}

<div class="max-w-3xl mx-auto card p-8 mt-10">
    <h1 class="text-2xl font-bold mb-6">Create New Category</h1>
    <form method="post" asp-action="Create" id="createCategoryForm" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <!-- Name -->
        <div class="mb-5">
            <label class="font-medium">Name</label>
            <input asp-for="Name" class="input w-full" placeholder="Category name" />
            <span asp-validation-for="Name" class="text-danger text-sm"></span>
        </div>

        <!-- Upload Image -->
        <div class="mb-6">
            <label class="font-medium">Image</label>
            <div class="flex items-center gap-3 mb-2">
                <label for="imageFile" class="btn btn-outline">Select image</label>
                <span id="selectedFile" class="text-sm text-muted-foreground">No file chosen</span>
            </div>
            <input type="file" name="imageFile" id="imageFile" class="hidden" accept="image/*" />
            <small class="text-muted-foreground block">Max 2MB. Allowed: jpg, jpeg, png, gif, webp.</small>
        </div>

        <!-- Preview Image -->
        <div id="imagePreview" class="grid grid-cols-3 gap-4 mb-6"></div>

        <button type="submit" class="btn btn-primary w-full text-lg">Create Category</button>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
   <script src="~/js/category.js"></script>
}