@using BuyMate.DTO.Entities.Category
@model CreateCategoryDto
@{
    ViewData["Title"] = "Edit Category";
    var categoryId = ViewBag.Id as Guid?;
}

<div class="container mb-5" style="max-width: 48rem;">
    <div class="card p-4 p-md-5 mt-4">
        <a asp-controller="Admin" asp-action="Index" class="d-inline-flex align-items-center small text-muted text-decoration-none mb-3">
            <i class="fas fa-arrow-left me-2"></i> Back to Dashboard
        </a>
        <h1 class="h4 fw-bold mb-1">Edit Category</h1>
        <p class="small text-muted mb-3">Update the category name or replace its image. Leave image empty to keep the current one.</p>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success small mb-3">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger small mb-3">@TempData["Error"]</div>
        }

        <form asp-controller="Category"
              asp-action="Edit"
              asp-route-id="@categoryId"
              method="post"
              enctype="multipart/form-data"
              id="editCategoryForm">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Name" class="form-label small">Name</label>
                <input asp-for="Name" class="form-control" placeholder="Category name" />
                <span asp-validation-for="Name" class="small text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label small">Replace Image (optional)</label>
                <div class="d-flex align-items-center gap-2 mb-2">
                    <label for="imageFile" class="btn btn-outline-secondary btn-sm">Select image</label>
                    <span id="selectedFile" class="small text-muted">No file chosen</span>
                    <button type="button" id="clearImageBtn" class="btn btn-outline-secondary btn-sm d-none">Clear</button>
                </div>
                <input type="file" name="imageFile" id="imageFile" class="d-none" accept="image/*" />
                <small class="text-muted d-block">Leave empty to keep current. Max 2MB. Allowed: jpg, jpeg, png, gif, webp.</small>
            </div>

            <div id="imagePreview" class="row g-3 mb-3"></div>

            <div class="d-flex gap-2 mt-2">
                <button type="submit" class="btn btn-primary flex-fill">Save Changes</button>
                <a asp-controller="Category" asp-action="Index" class="btn btn-outline-secondary flex-fill">Cancel</a>
            </div>
        </form>

        <hr class="my-4" />

        <form asp-controller="Category"
              asp-action="Delete"
              asp-route-id="@categoryId"
              method="post"
              id="deleteCategoryForm">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger w-100">Delete Category</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/category.js"></script>
}