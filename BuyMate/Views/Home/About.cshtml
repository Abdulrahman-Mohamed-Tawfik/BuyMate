@{
    ViewData["Title"] = "About Us";
}

<div class="container mb-5" style="max-width: 48rem;">
    <h1 class="h3 fw-bold mb-4">About BUYMATE</h1>

    <div class="d-flex flex-column gap-4">
        <div class="card p-4">
            <h2 class="h5 fw-bold mb-3">Our Story</h2>
            <p class="text-muted mb-0">
                BUYMATE was founded with a simple mission: to make online shopping easier, faster, and more enjoyable for everyone.
                We believe that finding the perfect product should be effortless, and that's why we've built a platform that
                combines cutting-edge technology with exceptional customer service.
            </p>
        </div>

        <div class="card p-4">
            <h2 class="h5 fw-bold mb-3">Our Values</h2>
            <div class="row g-4">
                <div class="col-12 col-md-4 text-center">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-3" style="width:4rem;height:4rem;">
                        <i class="fas fa-check text-primary fs-4"></i>
                    </div>
                    <h3 class="small fw-bold mb-1">Quality</h3>
                    <p class="small text-muted mb-0">We only offer products that meet our high standards for quality and reliability.</p>
                </div>
                <div class="col-12 col-md-4 text-center">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-3" style="width:4rem;height:4rem;">
                        <i class="fas fa-bolt text-primary fs-4"></i>
                    </div>
                    <h3 class="small fw-bold mb-1">Speed</h3>
                    <p class="small text-muted mb-0">Fast delivery and quick customer support to get you what you need, when you need it.</p>
                </div>
                <div class="col-12 col-md-4 text-center">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-3" style="width:4rem;height:4rem;">
                        <i class="fas fa-heart text-primary fs-4"></i>
                    </div>
                    <h3 class="small fw-bold mb-1">Care</h3>
                    <p class="small text-muted mb-0">We care about our customers and are committed to providing the best shopping experience.</p>
                </div>
            </div>
        </div>

        <div class="card p-4">
            <h2 class="h5 fw-bold mb-3">Our Team</h2>
            <p class="text-muted mb-0">
                Our team is made up of passionate individuals who are dedicated to making BUYMATE the best place to shop online.
                From our developers who build the platform to our customer service representatives who help you with your orders,
                everyone at BUYMATE is committed to your satisfaction.
            </p>
        </div>

        <div class="card p-4">
            <h2 class="h5 fw-bold mb-3">Contact Information</h2>
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <h3 class="small fw-bold mb-1">Address</h3>
                    <p class="small text-muted mb-0">123 Shopping Street<br />E-commerce City, EC 12345</p>
                </div>
                <div class="col-12 col-md-6">
                    <h3 class="small fw-bold mb-1">Phone</h3>
                    <p class="small text-muted mb-0">+1 (555) 123-4567</p>
                </div>
                <div class="col-12 col-md-6">
                    <h3 class="small fw-bold mb-1">Email</h3>
                    <p class="small text-muted mb-0">support@buymate.com</p>
                </div>
                <div class="col-12 col-md-6">
                    <h3 class="small fw-bold mb-1">Hours</h3>
                    <p class="small text-muted mb-0">Mon-Fri: 9AM-6PM<br />Sat-Sun: 10AM-4PM</p>
                </div>
            </div>
        </div>
    </div>
</div>
