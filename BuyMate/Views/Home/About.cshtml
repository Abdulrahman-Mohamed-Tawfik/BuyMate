@{
    ViewData["Title"] = "About Us";
}

<div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold mb-8">About BUYMATE</h1>

    <div class="space-y-8">
        <div class="card p-8">
            <h2 class="text-2xl font-bold mb-4">Our Story</h2>
            <p class="text-muted-foreground leading-relaxed">
                BUYMATE was founded with a simple mission: to make online shopping easier, faster, and more enjoyable for everyone. 
                We believe that finding the perfect product should be effortless, and that's why we've built a platform that 
                combines cutting-edge technology with exceptional customer service.
            </p>
        </div>

        <div class="card p-8">
            <h2 class="text-2xl font-bold mb-4">Our Values</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="text-center">
                    <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <h3 class="font-bold mb-2">Quality</h3>
                    <p class="text-sm text-muted-foreground">We only offer products that meet our high standards for quality and reliability.</p>
                </div>
                <div class="text-center">
                    <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                        </svg>
                    </div>
                    <h3 class="font-bold mb-2">Speed</h3>
                    <p class="text-sm text-muted-foreground">Fast delivery and quick customer support to get you what you need, when you need it.</p>
                </div>
                <div class="text-center">
                    <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                        </svg>
                    </div>
                    <h3 class="font-bold mb-2">Care</h3>
                    <p class="text-sm text-muted-foreground">We care about our customers and are committed to providing the best shopping experience.</p>
                </div>
            </div>
        </div>

        <div class="card p-8">
            <h2 class="text-2xl font-bold mb-4">Our Team</h2>
            <p class="text-muted-foreground leading-relaxed">
                Our team is made up of passionate individuals who are dedicated to making BUYMATE the best place to shop online. 
                From our developers who build the platform to our customer service representatives who help you with your orders, 
                everyone at BUYMATE is committed to your satisfaction.
            </p>
        </div>

        <div class="card p-8">
            <h2 class="text-2xl font-bold mb-4">Contact Information</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <h3 class="font-bold mb-2">Address</h3>
                    <p class="text-muted-foreground">123 Shopping Street<br>E-commerce City, EC 12345</p>
                </div>
                <div>
                    <h3 class="font-bold mb-2">Phone</h3>
                    <p class="text-muted-foreground">+1 (555) 123-4567</p>
                </div>
                <div>
                    <h3 class="font-bold mb-2">Email</h3>
                    <p class="text-muted-foreground">support@buymate.com</p>
                </div>
                <div>
                    <h3 class="font-bold mb-2">Hours</h3>
                    <p class="text-muted-foreground">Mon-Fri: 9AM-6PM<br>Sat-Sun: 10AM-4PM</p>
                </div>
            </div>
        </div>
    </div>
</div>
