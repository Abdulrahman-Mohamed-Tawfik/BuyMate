@{
    ViewData["Title"] = "Access Denied";
}

<div class="container mb-5" style="max-width: 40rem;">
    <div class="card p-4 text-center mt-4">
        <i class="fas fa-ban fa-3x text-danger mb-3"></i>

        <h1 class="h5 fw-bold mb-1">Access Denied</h1>
        <p class="text-muted mb-3">You do not have permission to view this page. If you think this is a mistake, please contact support or sign in with an account that has the required access.</p>

        <div class="d-flex justify-content-center gap-2 mb-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-sm">Go to Home</a>
            @if (!User.Identity?.IsAuthenticated ?? true)
            {
                <a asp-controller="User" asp-action="Login" class="btn btn-outline-secondary btn-sm">Sign In</a>
            }
            <a href="/Home/Contact" class="btn btn-secondary btn-sm">Contact Support</a>
        </div>

        <div class="text-muted small mt-1">
            <span>Status code: 403</span>
        </div>
    </div>
</div>
