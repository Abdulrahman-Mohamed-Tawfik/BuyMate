@{
    ViewData["Title"] = "Analytics";
}

<div class="container mb-5" style="max-width: 72rem;">
    <h1 class="h4 fw-bold mb-3">Analytics Dashboard</h1>

    <div class="row g-3 mb-3 small">
        <div class="col-12 col-md-6 col-lg-3">
            <div class="card p-3 h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">Total Sales</p>
                        <p class="h5 fw-bold mb-0">$12,345</p>
                    </div>
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                        style="width:3rem;height:3rem;">
                        <i class="fas fa-dollar-sign text-primary"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="card p-3 h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">Orders</p>
                        <p class="h5 fw-bold mb-0">156</p>
                    </div>
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                        style="width:3rem;height:3rem;">
                        <i class="fas fa-receipt text-primary"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="card p-3 h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">Customers</p>
                        <p class="h5 fw-bold mb-0">89</p>
                    </div>
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                        style="width:3rem;height:3rem;">
                        <i class="fas fa-users text-primary"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-lg-3">
            <div class="card p-3 h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted mb-1">Products</p>
                        <p class="h5 fw-bold mb-0">245</p>
                    </div>
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center"
                        style="width:3rem;height:3rem;">
                        <i class="fas fa-box-open text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 small">
        <div class="col-12 col-lg-6">
            <div class="card p-3 h-100">
                <h2 class="h6 fw-bold mb-2">Recent Orders</h2>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center p-2 rounded-3 bg-light">
                        <div>
                            <p class="fw-semibold mb-0">Order #12345</p>
                            <p class="text-muted mb-0">iPhone 15 Pro Max</p>
                        </div>
                        <div class="text-end">
                            <p class="fw-semibold mb-0">$1,199</p>
                            <p class="text-muted mb-0">Delivered</p>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center p-2 rounded-3 bg-light">
                        <div>
                            <p class="fw-semibold mb-0">Order #12344</p>
                            <p class="text-muted mb-0">MacBook Pro 16"</p>
                        </div>
                        <div class="text-end">
                            <p class="fw-semibold mb-0">$2,499</p>
                            <p class="text-muted mb-0">Shipped</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-6">
            <div class="card p-3 h-100">
                <h2 class="h6 fw-bold mb-2">Top Products</h2>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex justify-content-between align-items-center p-2 rounded-3 bg-light">
                        <div>
                            <p class="fw-semibold mb-0">iPhone 15 Pro Max</p>
                            <p class="text-muted mb-0">Electronics</p>
                        </div>
                        <div class="text-end">
                            <p class="fw-semibold mb-0">45 sales</p>
                            <p class="text-muted mb-0">$53,955</p>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center p-2 rounded-3 bg-light">
                        <div>
                            <p class="fw-semibold mb-0">MacBook Pro 16"</p>
                            <p class="text-muted mb-0">Electronics</p>
                        </div>
                        <div class="text-end">
                            <p class="fw-semibold mb-0">23 sales</p>
                            <p class="text-muted mb-0">$57,477</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
