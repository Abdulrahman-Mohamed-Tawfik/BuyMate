                    </div>
                </div>
                <div class="flex items-center justify-between p-4 bg-muted/50 rounded-lg">
                    <div>
                        <p class="font-medium">MacBook Pro 16"</p>
                        <p class="text-sm text-muted-foreground">Electronics</p>
                    </div>
                    <div class="text-right">
                        <p class="font-medium">23 sales</p>
                        <p class="text-sm text-muted-foreground">$57,477</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
