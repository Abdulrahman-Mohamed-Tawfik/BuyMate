                    </div>
                </div>
            </div>
        </div>

        <div class="card p-6">
            <h2 class="text-xl font-bold mb-4">Top Products</h2>
            <div class="space-y-4">
                <div class="flex items-center justify-between p-4 bg-muted/50 rounded-lg">
                    <div>
                        <p class="font-medium">iPhone 15 Pro Max</p>
