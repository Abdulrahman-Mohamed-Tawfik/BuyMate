@using BuyMate.DTO.ViewModels.Category
@model IEnumerable<CategoryViewModel>

@{
    ViewData["Title"] = "Categories";
}

<div class="container mb-5" style="max-width: 72rem;">
    <div class="d-flex justify-content-between align-items-end mb-3">
        <h1 class="h4 fw-bold mb-0">Shop by Category</h1>
        <a asp-controller="Category" asp-action="Create" class="small fw-semibold text-dark text-decoration-none">
            + Add New Category
        </a>
    </div>

    <div class="d-flex flex-column gap-3 small">
        <div class="row g-3">
            @if (Model == null || !Model.Any())
            {
                <div class="col-12">
                    <div class="text-center p-4 border border-dashed rounded-3">
                        <p class="text-muted mb-2">No categories found in the database.</p>
                        <a asp-controller="Category" asp-action="Create" class="btn btn-dark btn-sm">
                            Create First Category
                        </a>
                    </div>
                </div>
            }
            else
            {
                @foreach (var category in Model)
                {
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card p-3 h-100 border" style="cursor:pointer;">
                            <div class="rounded-circle bg-dark bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-3" style="width:4rem;height:4rem;">
                                @Html.Raw(GetIconForCategory(category.Name))
                            </div>

                            <h3 class="h6 fw-bold text-center mb-1">@category.Name</h3>
                            <p class="text-center text-muted mb-2">0 products</p>

                            <div class="text-center">
                                <a href="#" class="small text-dark text-decoration-none">View Products</a>

                                <div class="d-flex justify-content-center gap-2 mt-3 pt-2 border-top">
                                    <a asp-controller="Category" asp-action="Edit" asp-route-id="@category.Id" class="small fw-semibold text-warning text-decoration-none">Edit</a>
                                    <span class="text-muted">|</span>
                                    <form asp-controller="Category" asp-action="Delete" asp-route-id="@category.Id" method="post" class="d-inline" onsubmit="return confirm('Delete @category.Name?');">
                                        <button type="submit" class="btn btn-link p-0 small fw-semibold text-danger text-decoration-none">Delete</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="card p-3 mt-3">
            <h2 class="h5 fw-bold mb-2">Popular Subcategories</h2>
            <div class="row g-2">
                <div class="col-6 col-md-3 col-lg-2">
                    <a href="#" class="d-block text-center p-3 border rounded-3 text-decoration-none h-100">
                        <div class="rounded-circle bg-dark bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-2" style="width:3rem;height:3rem;">
                            <i class="fas fa-mobile-alt text-dark"></i>
                        </div>
                        <p class="small fw-semibold mb-0">Smartphones</p>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    // Helper to keep your icons looking good
    string GetIconForCategory(string name)
    {
        var start = "<svg class='w-8 h-8 text-dark' fill='none' stroke='currentColor' viewBox='0 0 24 24'>";
        var content = "<path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z'></path>"; // Default Box Icon

        if (string.IsNullOrEmpty(name)) return start + content + "</svg>";

        // Match icons to names
        if (name.Contains("Electronic", StringComparison.OrdinalIgnoreCase)) content = "<path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z'></path>";
        if (name.Contains("Fashion", StringComparison.OrdinalIgnoreCase)) content = "<path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z'></path>";
        if (name.Contains("Home", StringComparison.OrdinalIgnoreCase)) content = "<path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z'></path>";

        return start + content + "</svg>";
    }
}