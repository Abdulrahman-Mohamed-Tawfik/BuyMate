@model IEnumerable<BuyMate.DTO.ViewModels.CategoryViewModel>

@{
    ViewData["Title"] = "Categories";
}

<div class="max-w-6xl mx-auto">
    <div class="flex justify-between items-end mb-8">
        <h1 class="text-3xl font-bold">Shop by Category</h1>
        <a asp-controller="Category" asp-action="Create" class="text-sm font-medium text-primary hover:underline">
            + Add New Category
        </a>
    </div>

    <div class="space-y-8">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

            @if (Model == null || !Model.Any())
            {
                <div class="col-span-full text-center p-10 border-2 border-dashed rounded-lg">
                    <p class="text-muted-foreground mb-2">No categories found in the database.</p>
                    <a asp-controller="Category" asp-action="Create" class="bg-primary text-white px-4 py-2 rounded hover:opacity-90">
                        Create First Category
                    </a>
                </div>
            }
            else
            {
                @foreach (var category in Model)
                {
                    <div class="card p-6 hover:shadow-lg transition-all cursor-pointer relative group border rounded-lg">

                        <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                            @Html.Raw(GetIconForCategory(category.Name))
                        </div>

                        <h3 class="text-xl font-bold text-center mb-2">@category.Name</h3>

                        <p class="text-center text-muted-foreground mb-4">0 products</p>

                        <div class="space-y-2 text-center">
                            <a href="#" class="block text-sm text-primary hover:underline">View Products</a>

                            <div class="flex justify-center gap-3 mt-4 pt-4 border-t border-gray-100">
                                <a asp-controller="Category" asp-action="Edit" asp-route-id="@category.Id" class="text-xs font-medium text-yellow-600 hover:text-yellow-700">Edit</a>
                                <span class="text-gray-300">|</span>
                                <form asp-controller="Category" asp-action="Delete" asp-route-id="@category.Id" method="post" class="inline" onsubmit="return confirm('Delete @category.Name?');">
                                    <button type="submit" class="text-xs font-medium text-red-600 hover:text-red-700 bg-transparent border-0 p-0 cursor-pointer">Delete</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        <div class="card p-8 mt-12 border rounded-lg">
            <h2 class="text-2xl font-bold mb-4">Popular Subcategories</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
                <a href="#" class="text-center p-4 border rounded-lg hover:shadow-md transition-all">
                    <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-2">
                        <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                    </div>
                    <p class="text-sm font-medium">Smartphones</p>
                </a>
            </div>
        </div>
    </div>
</div>

@functions {
    // Helper to keep your icons looking good
    string GetIconForCategory(string name)
    {
        var start = "<svg class='w-8 h-8 text-primary' fill='none' stroke='currentColor' viewBox='0 0 24 24'>";
        var content = "<path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z'></path>"; // Default Box Icon

        if (string.IsNullOrEmpty(name)) return start + content + "</svg>";

        // Match icons to names
        if (name.Contains("Electronic", StringComparison.OrdinalIgnoreCase)) content = "<path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z'></path>";
        if (name.Contains("Fashion", StringComparison.OrdinalIgnoreCase)) content = "<path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z'></path>";
        if (name.Contains("Home", StringComparison.OrdinalIgnoreCase)) content = "<path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2-2z'></path>";

        return start + content + "</svg>";
    }
}