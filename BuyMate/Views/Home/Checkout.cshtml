@{
    ViewData["Title"] = "Checkout";
}

<div class="max-w-6xl mx-auto">
    <h1 class="text-3xl font-bold mb-8">Checkout</h1>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-8">
            <div class="card p-8">
                <h2 class="text-2xl font-bold mb-6">Shipping Information</h2>
                <form class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium mb-2">First Name</label>
                            <input type="text" class="input w-full" placeholder="Enter your first name" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-2">Last Name</label>
                            <input type="text" class="input w-full" placeholder="Enter your last name" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2">Email Address</label>
                        <input type="email" class="input w-full" placeholder="Enter your email address" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2">Phone Number</label>
                        <input type="tel" class="input w-full" placeholder="Enter your phone number" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2">Address</label>
                        <input type="text" class="input w-full" placeholder="Enter your street address" />
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label class="block text-sm font-medium mb-2">City</label>
                            <input type="text" class="input w-full" placeholder="Enter your city" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-2">State</label>
                            <select class="select w-full">
                                <option>Select State</option>
                                <option>California</option>
                                <option>New York</option>
                                <option>Texas</option>
                                <option>Florida</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-2">ZIP Code</label>
                            <input type="text" class="input w-full" placeholder="Enter ZIP code" />
                        </div>
                    </div>
                </form>
            </div>

            <div class="card p-8">
                <h2 class="text-2xl font-bold mb-6">Payment Information</h2>
                <form class="space-y-6">
                    <div>
                        <label class="block text-sm font-medium mb-2">Card Number</label>
                        <input type="text" class="input w-full" placeholder="1234 5678 9012 3456" />
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-medium mb-2">Expiry Date</label>
                            <input type="text" class="input w-full" placeholder="MM/YY" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium mb-2">CVV</label>
                            <input type="text" class="input w-full" placeholder="123" />
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-medium mb-2">Cardholder Name</label>
                        <input type="text" class="input w-full" placeholder="Enter cardholder name" />
                    </div>
                </form>
            </div>

            <div class="card p-8">
                <h2 class="text-2xl font-bold mb-6">Shipping Method</h2>
                <div class="space-y-4">
                    <label class="flex items-center space-x-3 p-4 border rounded-lg cursor-pointer hover:bg-muted/50">
                        <input type="radio" name="shipping" class="radio" checked />
                        <div class="flex-1">
                            <div class="flex items-center justify-between">
                                <span class="font-medium">Standard Shipping</span>
                                <span class="font-bold text-primary">$5.99</span>
                            </div>
                            <p class="text-sm text-muted-foreground">5-7 business days</p>
                        </div>
                    </label>
                    <label class="flex items-center space-x-3 p-4 border rounded-lg cursor-pointer hover:bg-muted/50">
                        <input type="radio" name="shipping" class="radio" />
                        <div class="flex-1">
                            <div class="flex items-center justify-between">
                                <span class="font-medium">Express Shipping</span>
                                <span class="font-bold text-primary">$12.99</span>
                            </div>
                            <p class="text-sm text-muted-foreground">2-3 business days</p>
                        </div>
                    </label>
                    <label class="flex items-center space-x-3 p-4 border rounded-lg cursor-pointer hover:bg-muted/50">
                        <input type="radio" name="shipping" class="radio" />
                        <div class="flex-1">
                            <div class="flex items-center justify-between">
                                <span class="font-medium">Same Day Delivery</span>
                                <span class="font-bold text-primary">$19.99</span>
                            </div>
                            <p class="text-sm text-muted-foreground">Same day (select areas)</p>
                        </div>
                    </label>
                </div>
            </div>
        </div>

        <div class="lg:col-span-1">
            <div class="card p-6 sticky top-8">
                <h2 class="text-xl font-bold mb-4">Order Summary</h2>
                
                <div class="space-y-4 mb-6">
                    <div class="flex items-center space-x-3">
                        <img src="~/images/buymate-logo.png" alt="Product" class="w-16 h-16 object-contain rounded-lg" />
                        <div class="flex-1">
                            <h3 class="font-medium">iPhone 15 Pro Max</h3>
                            <p class="text-sm text-muted-foreground">Color: Space Black, Storage: 256GB</p>
                            <div class="flex items-center space-x-2 mt-1">
                                <span class="font-bold text-primary">$1,199.00</span>
                                <span class="text-sm text-muted-foreground">x1</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="space-y-2 border-t pt-4">
                    <div class="flex justify-between">
                        <span class="text-muted-foreground">Subtotal</span>
                        <span class="font-medium">$1,199.00</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-muted-foreground">Shipping</span>
                        <span class="font-medium">$5.99</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-muted-foreground">Tax</span>
                        <span class="font-medium">$0.00</span>
                    </div>
                    <div class="flex justify-between border-t pt-2">
                        <span class="font-bold">Total</span>
                        <span class="font-bold text-xl">$1,204.99</span>
                    </div>
                </div>

                <button class="btn btn-primary w-full mt-6">Place Order</button>
                
                <div class="mt-4 text-center">
                    <p class="text-xs text-muted-foreground">
                        By placing your order, you agree to our 
                        <a href="@Url.Action("Terms", "Home")" class="text-primary hover:underline">Terms of Service</a> 
                        and 
                        <a href="@Url.Action("Privacy", "Home")" class="text-primary hover:underline">Privacy Policy</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>