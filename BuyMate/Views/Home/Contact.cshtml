@{
    ViewData["Title"] = "Contact Us";
}

<div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold mb-8">Contact Us</h1>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <div class="card p-8">
            <h2 class="text-2xl font-bold mb-6">Get in Touch</h2>
            <form class="space-y-6">
                <div>
                    <label class="block text-sm font-medium mb-2">Name</label>
                    <input type="text" class="input w-full" placeholder="Your name" />
                </div>
                <div>
                    <label class="block text-sm font-medium mb-2">Email</label>
                    <input type="email" class="input w-full" placeholder="your.email@example.com" />
                </div>
                <div>
                    <label class="block text-sm font-medium mb-2">Subject</label>
                    <input type="text" class="input w-full" placeholder="What's this about?" />
                </div>
                <div>
                    <label class="block text-sm font-medium mb-2">Message</label>
                    <textarea class="textarea w-full" rows="5" placeholder="Tell us how we can help..."></textarea>
                </div>
                <button type="submit" class="btn btn-primary w-full">Send Message</button>
            </form>
        </div>

        <div class="space-y-6">
            <div class="card p-6">
                <h3 class="text-xl font-bold mb-4">Contact Information</h3>
                <div class="space-y-4">
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                            </svg>
                        </div>
                        <div>
                            <p class="font-medium">Phone</p>
                            <p class="text-sm text-muted-foreground">+1 (555) 123-4567</p>
                        </div>
                    </div>
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                        <div>
                            <p class="font-medium">Email</p>
                            <p class="text-sm text-muted-foreground">support@buymate.com</p>
                        </div>
                    </div>
                    <div class="flex items-center space-x-3">
                        <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                            <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                        </div>
                        <div>
                            <p class="font-medium">Address</p>
                            <p class="text-sm text-muted-foreground">123 Shopping Street<br>E-commerce City, EC 12345</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card p-6">
                <h3 class="text-xl font-bold mb-4">Business Hours</h3>
                <div class="space-y-2">
                    <div class="flex justify-between">
                        <span class="text-muted-foreground">Monday - Friday</span>
                        <span class="font-medium">9:00 AM - 6:00 PM</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-muted-foreground">Saturday</span>
                        <span class="font-medium">10:00 AM - 4:00 PM</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-muted-foreground">Sunday</span>
                        <span class="font-medium">Closed</span>
                    </div>
                </div>
            </div>

            <div class="card p-6">
                <h3 class="text-xl font-bold mb-4">Quick Links</h3>
                <div class="space-y-2">
                    <a href="#" class="block text-primary hover:underline">FAQ</a>
                    <a href="#" class="block text-primary hover:underline">Shipping Information</a>
                    <a href="#" class="block text-primary hover:underline">Returns & Exchanges</a>
                    <a href="#" class="block text-primary hover:underline">Track Your Order</a>
                </div>
            </div>
        </div>
    </div>
</div>
