@{
    ViewData["Title"] = "Contact Us";
}

<div class="container mb-5" style="max-width: 64rem;">
    <h1 class="h4 fw-bold mb-3">Contact Us</h1>

    <div class="row g-4">
        <div class="col-12 col-lg-6">
            <div class="card p-3">
                <h2 class="h5 fw-bold mb-3">Get in Touch</h2>
                <form>
                    <div class="mb-2">
                        <label class="form-label small">Name</label>
                        <input type="text" class="form-control" placeholder="Your name" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Email</label>
                        <input type="email" class="form-control" placeholder="your.email@example.com" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Subject</label>
                        <input type="text" class="form-control" placeholder="What's this about?" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small">Message</label>
                        <textarea class="form-control" rows="5" placeholder="Tell us how we can help..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Send Message</button>
                </form>
            </div>
        </div>

        <div class="col-12 col-lg-6 d-flex flex-column gap-3">
            <div class="card p-3 small">
                <h3 class="fw-bold mb-2">Contact Information</h3>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width:2.5rem;height:2.5rem;">
                            <i class="fas fa-phone text-primary"></i>
                        </div>
                        <div>
                            <p class="fw-semibold mb-0">Phone</p>
                            <p class="text-muted mb-0">+1 (555) 123-4567</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width:2.5rem;height:2.5rem;">
                            <i class="fas fa-envelope text-primary"></i>
                        </div>
                        <div>
                            <p class="fw-semibold mb-0">Email</p>
                            <p class="text-muted mb-0">support@buymate.com</p>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width:2.5rem;height:2.5rem;">
                            <i class="fas fa-location-dot text-primary"></i>
                        </div>
                        <div>
                            <p class="fw-semibold mb-0">Address</p>
                            <p class="text-muted mb-0">123 Shopping Street<br />E-commerce City, EC 12345</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card p-3 small">
                <h3 class="fw-bold mb-2">Business Hours</h3>
                <div class="d-flex flex-column gap-1">
                    <div class="d-flex justify-content-between"><span class="text-muted">Monday - Friday</span><span class="fw-semibold">9:00 AM - 6:00 PM</span></div>
                    <div class="d-flex justify-content-between"><span class="text-muted">Saturday</span><span class="fw-semibold">10:00 AM - 4:00 PM</span></div>
                    <div class="d-flex justify-content-between"><span class="text-muted">Sunday</span><span class="fw-semibold">Closed</span></div>
                </div>
            </div>

            <div class="card p-3 small">
                <h3 class="fw-bold mb-2">Quick Links</h3>
                <div class="d-flex flex-column gap-1">
                    <a href="#" class="text-primary text-decoration-none">FAQ</a>
                    <a href="#" class="text-primary text-decoration-none">Shipping Information</a>
                    <a href="#" class="text-primary text-decoration-none">Returns &amp; Exchanges</a>
                    <a href="#" class="text-primary text-decoration-none">Track Your Order</a>
                </div>
            </div>
        </div>
    </div>
</div>
