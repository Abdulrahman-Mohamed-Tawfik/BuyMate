                        <span class="text-sm text-muted-foreground line-through">$249</span>
                    </div>
                    <p class="text-xs text-muted-foreground">20% off</p>
                </div>

                <div class="card p-4 hover:shadow-lg transition-all cursor-pointer">
                    <div class="relative mb-3">
                        <img src="~/images/buymate-logo.png" alt="Product" class="w-full h-32 object-contain rounded-lg" />
                        <div class="absolute top-1 left-1 bg-green-500 text-white px-2 py-1 rounded text-xs font-bold">
                            TODAY
                        </div>
                    </div>
                    <h3 class="font-bold mb-1 text-sm">iPad Air</h3>
                    <div class="flex items-center space-x-1 mb-1">
                        <span class="text-lg font-bold text-primary">$499</span>
                        <span class="text-sm text-muted-foreground line-through">$599</span>
                    </div>
                    <p class="text-xs text-muted-foreground">17% off</p>
                </div>

                <div class="card p-4 hover:shadow-lg transition-all cursor-pointer">
                    <div class="relative mb-3">
                        <img src="~/images/buymate-logo.png" alt="Product" class="w-full h-32 object-contain rounded-lg" />
                        <div class="absolute top-1 left-1 bg-green-500 text-white px-2 py-1 rounded text-xs font-bold">
                            TODAY
                        </div>
                    </div>
                    <h3 class="font-bold mb-1 text-sm">Apple Watch Series 9</h3>
                    <div class="flex items-center space-x-1 mb-1">
                        <span class="text-lg font-bold text-primary">$349</span>
                        <span class="text-sm text-muted-foreground line-through">$399</span>
                    </div>
                    <p class="text-xs text-muted-foreground">13% off</p>
                </div>

                <div class="card p-4 hover:shadow-lg transition-all cursor-pointer">
                    <div class="relative mb-3">
                        <img src="~/images/buymate-logo.png" alt="Product" class="w-full h-32 object-contain rounded-lg" />
                        <div class="absolute top-1 left-1 bg-green-500 text-white px-2 py-1 rounded text-xs font-bold">
                            TODAY
                        </div>
                    </div>
                    <h3 class="font-bold mb-1 text-sm">MacBook Air M2</h3>
                    <div class="flex items-center space-x-1 mb-1">
                        <span class="text-lg font-bold text-primary">$999</span>
                        <span class="text-sm text-muted-foreground line-through">$1,199</span>
                    </div>
                    <p class="text-xs text-muted-foreground">17% off</p>
                </div>
            </div>
        </div>

        <div class="card p-8">
            <h2 class="text-2xl font-bold mb-4">Special Offers</h2>
            <div class="space-y-6">
                <div class="flex items-center space-x-4 p-4 bg-primary/10 rounded-lg">
                    <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center">
                        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-bold">Free Shipping on Orders Over $50</h3>
                        <p class="text-sm text-muted-foreground">No minimum purchase required for this offer</p>
                    </div>
                </div>

                <div class="flex items-center space-x-4 p-4 bg-primary/10 rounded-lg">
                    <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center">
                        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-bold">10% Off Your First Order</h3>
                        <p class="text-sm text-muted-foreground">Use code WELCOME10 at checkout</p>
                    </div>
                </div>

                <div class="flex items-center space-x-4 p-4 bg-primary/10 rounded-lg">
                    <div class="w-16 h-16 bg-primary rounded-full flex items-center justify-center">
                        <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="font-bold">Buy 2 Get 1 Free on Electronics</h3>
                        <p class="text-sm text-muted-foreground">Valid on selected electronics items</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card p-8">
            <h2 class="text-2xl font-bold mb-4">Newsletter Signup</h2>
            <p class="text-muted-foreground leading-relaxed mb-6">
                Subscribe to our newsletter to be the first to know about new deals, exclusive offers, and special promotions.
            </p>
            <form class="flex space-x-4">
                <input type="email" placeholder="Enter your email address" class="input flex-1" />
                <button type="submit" class="btn btn-primary">Subscribe</button>
            </form>
        </div>
    </div>
</div>
