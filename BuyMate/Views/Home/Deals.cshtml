@{
    ViewData["Title"] = "Deals & Offers";
}

<div class="max-w-6xl mx-auto">
    <h1 class="text-3xl font-bold mb-8">Deals & Offers</h1>

    <div class="space-y-8">
        <div class="card p-8">
            <h2 class="text-2xl font-bold mb-4">Flash Deals</h2>
            <p class="text-muted-foreground leading-relaxed mb-6">
                Limited time offers on popular items. These deals won't last long, so grab them while you can!
            </p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="card p-6 hover:shadow-lg transition-all cursor-pointer">
                    <div class="relative mb-4">
                        <img src="~/images/buymate-logo.png" alt="Product" class="w-full h-48 object-contain rounded-lg" />
                        <div class="absolute top-2 left-2 bg-red-500 text-white px-2 py-1 rounded text-sm font-bold">
                            50% OFF
                        </div>
                    </div>
                    <h3 class="font-bold mb-2">iPhone 15 Pro Max</h3>
                    <div class="flex items-center space-x-2 mb-2">
                        <span class="text-2xl font-bold text-primary">$599</span>
                        <span class="text-lg text-muted-foreground line-through">$1,199</span>
                    </div>
                    <p class="text-sm text-muted-foreground mb-4">Ends in 2 days</p>
                    <button class="btn btn-primary w-full">Add to Cart</button>
                </div>

                <div class="card p-6 hover:shadow-lg transition-all cursor-pointer">
                    <div class="relative mb-4">
                        <img src="~/images/buymate-logo.png" alt="Product" class="w-full h-48 object-contain rounded-lg" />
                        <div class="absolute top-2 left-2 bg-red-500 text-white px-2 py-1 rounded text-sm font-bold">
                            30% OFF
                        </div>
                    </div>
                    <h3 class="font-bold mb-2">MacBook Pro 16"</h3>
                    <div class="flex items-center space-x-2 mb-2">
                        <span class="text-2xl font-bold text-primary">$1,749</span>
                        <span class="text-lg text-muted-foreground line-through">$2,499</span>
                    </div>
                    <p class="text-sm text-muted-foreground mb-4">Ends in 5 days</p>
                    <button class="btn btn-primary w-full">Add to Cart</button>
                </div>

                <div class="card p-6 hover:shadow-lg transition-all cursor-pointer">
                    <div class="relative mb-4">
                        <img src="~/images/buymate-logo.png" alt="Product" class="w-full h-48 object-contain rounded-lg" />
                        <div class="absolute top-2 left-2 bg-red-500 text-white px-2 py-1 rounded text-sm font-bold">
                            25% OFF
                        </div>
                    </div>
                    <h3 class="font-bold mb-2">Samsung Galaxy S24 Ultra</h3>
                    <div class="flex items-center space-x-2 mb-2">
                        <span class="text-2xl font-bold text-primary">$899</span>
                        <span class="text-lg text-muted-foreground line-through">$1,199</span>
                    </div>
                    <p class="text-sm text-muted-foreground mb-4">Ends in 3 days</p>
                    <button class="btn btn-primary w-full">Add to Cart</button>
                </div>
            </div>
        </div>

        <div class="card p-8">
            <h2 class="text-2xl font-bold mb-4">Daily Deals</h2>
