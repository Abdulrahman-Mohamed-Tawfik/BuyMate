@{
    ViewData["Title"] = "Frequently Asked Questions";
}

<div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold mb-8">Frequently Asked Questions</h1>

    <div class="space-y-6">
        <div class="card p-6">
            <h2 class="text-xl font-bold mb-4">General Questions</h2>
            <div class="space-y-4">
                <div>
                    <h3 class="font-medium mb-2">What is BUYMATE?</h3>
                    <p class="text-muted-foreground">BUYMATE is an online marketplace that connects buyers with sellers, offering a wide range of products from electronics to fashion, home goods, and more.</p>
                </div>
                <div>
                    <h3 class="font-medium mb-2">How do I create an account?</h3>
                    <p class="text-muted-foreground">Click on the "Sign Up" button in the top right corner, fill in your details, and verify your email address to get started.</p>
                </div>
                <div>
                    <h3 class="font-medium mb-2">Is my personal information secure?</h3>
                    <p class="text-muted-foreground">Yes, we use industry-standard encryption and security measures to protect your personal information and payment details.</p>
                </div>
            </div>
        </div>

        <div class="card p-6">
            <h2 class="text-xl font-bold mb-4">Shopping & Orders</h2>
            <div class="space-y-4">
                <div>
                    <h3 class="font-medium mb-2">How do I place an order?</h3>
                    <p class="text-muted-foreground">Browse our products, add items to your cart, proceed to checkout, enter your shipping details, and complete your payment.</p>
                </div>
                <div>
                    <h3 class="font-medium mb-2">Can I modify or cancel my order?</h3>
                    <p class="text-muted-foreground">You can modify or cancel your order within 30 minutes of placing it. After that, please contact our customer service team.</p>
                </div>
                <div>
                    <h3 class="font-medium mb-2">How do I track my order?</h3>
                    <p class="text-muted-foreground">Once your order is shipped, you'll receive a tracking number via email. You can also track your order in your account dashboard.</p>
                </div>
            </div>
        </div>

        <div class="card p-6">
            <h2 class="text-xl font-bold mb-4">Shipping & Delivery</h2>
            <div class="space-y-4">
                <div>
                    <h3 class="font-medium mb-2">What are your shipping options?</h3>
                    <p class="text-muted-foreground">We offer standard shipping (5-7 business days), express shipping (2-3 business days), and same-day delivery in select areas.</p>
                </div>
                <div>
                    <h3 class="font-medium mb-2">Do you ship internationally?</h3>
                    <p class="text-muted-foreground">Yes, we ship to most countries worldwide. Shipping costs and delivery times vary by location.</p>
                </div>
                <div>
                    <h3 class="font-medium mb-2">What if my package is damaged or lost?</h3>
                    <p class="text-muted-foreground">Contact our customer service team immediately. We'll work with you to resolve the issue and provide a replacement or refund.</p>
                </div>
            </div>
        </div>

        <div class="card p-6">
            <h2 class="text-xl font-bold mb-4">Returns & Refunds</h2>
            <div class="space-y-4">
                <div>
                    <h3 class="font-medium mb-2">What is your return policy?</h3>
                    <p class="text-muted-foreground">We offer a 30-day return policy for most items. Items must be in original condition with tags and packaging.</p>
                </div>
                <div>
                    <h3 class="font-medium mb-2">How do I return an item?</h3>
                    <p class="text-muted-foreground">Go to your account dashboard, select the order you want to return, and follow the return process. We'll provide a prepaid return label.</p>
                </div>
                <div>
                    <h3 class="font-medium mb-2">When will I receive my refund?</h3>
                    <p class="text-muted-foreground">Refunds are processed within 5-7 business days after we receive your returned item. The refund will appear on your original payment method.</p>
                </div>
            </div>
        </div>

        <div class="card p-6">
            <h2 class="text-xl font-bold mb-4">Payment & Billing</h2>
            <div class="space-y-4">
                <div>
                    <h3 class="font-medium mb-2">What payment methods do you accept?</h3>
                    <p class="text-muted-foreground">We accept all major credit cards, PayPal, Apple Pay, Google Pay, and bank transfers.</p>
                </div>
                <div>
                    <h3 class="font-medium mb-2">Is my payment information secure?</h3>
                    <p class="text-muted-foreground">Yes, we use secure payment processing and never store your full payment information on our servers.</p>
                </div>
                <div>
                    <h3 class="font-medium mb-2">Can I save my payment information?</h3>
                    <p class="text-muted-foreground">Yes, you can save your payment information securely in your account for faster checkout in the future.</p>
                </div>
            </div>
        </div>

        <div class="card p-6">
            <h2 class="text-xl font-bold mb-4">Still Have Questions?</h2>
            <p class="text-muted-foreground mb-4">Can't find the answer you're looking for? Our customer service team is here to help!</p>
            <div class="flex space-x-4">
                <a href="@Url.Action("Contact", "Home")" class="btn btn-primary">Contact Us</a>
                <a href="mailto:support@buymate.com" class="btn btn-secondary">Email Support</a>
            </div>
        </div>
    </div>
</div>
