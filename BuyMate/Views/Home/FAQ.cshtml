@{
    ViewData["Title"] = "Frequently Asked Questions";
}

<div class="container mb-5" style="max-width: 64rem;">
    <h1 class="h4 fw-bold mb-3">Frequently Asked Questions</h1>

    <div class="d-flex flex-column gap-3 small">
        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">General Questions</h2>
            <div class="d-flex flex-column gap-2">
                <div>
                    <h3 class="fw-semibold mb-1">What is BUYMATE?</h3>
                    <p class="text-muted mb-0">BUYMATE is an online marketplace that connects buyers with sellers, offering a wide range of products from electronics to fashion, home goods, and more.</p>
                </div>
                <div>
                    <h3 class="fw-semibold mb-1">How do I create an account?</h3>
                    <p class="text-muted mb-0">Click on the "Sign Up" button in the top right corner, fill in your details, and verify your email address to get started.</p>
                </div>
                <div>
                    <h3 class="fw-semibold mb-1">Is my personal information secure?</h3>
                    <p class="text-muted mb-0">Yes, we use industry-standard encryption and security measures to protect your personal information and payment details.</p>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Shopping &amp; Orders</h2>
            <div class="d-flex flex-column gap-2">
                <div>
                    <h3 class="fw-semibold mb-1">How do I place an order?</h3>
                    <p class="text-muted mb-0">Browse our products, add items to your cart, proceed to checkout, enter your shipping details, and complete your payment.</p>
                </div>
                <div>
                    <h3 class="fw-semibold mb-1">Can I modify or cancel my order?</h3>
                    <p class="text-muted mb-0">You can modify or cancel your order within 30 minutes of placing it. After that, please contact our customer service team.</p>
                </div>
                <div>
                    <h3 class="fw-semibold mb-1">How do I track my order?</h3>
                    <p class="text-muted mb-0">Once your order is shipped, you'll receive a tracking number via email. You can also track your order in your account dashboard.</p>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Shipping &amp; Delivery</h2>
            <div class="d-flex flex-column gap-2">
                <div>
                    <h3 class="fw-semibold mb-1">What are your shipping options?</h3>
                    <p class="text-muted mb-0">We offer standard shipping (5-7 business days), express shipping (2-3 business days), and same-day delivery in select areas.</p>
                </div>
                <div>
                    <h3 class="fw-semibold mb-1">Do you ship internationally?</h3>
                    <p class="text-muted mb-0">Yes, we ship to most countries worldwide. Shipping costs and delivery times vary by location.</p>
                </div>
                <div>
                    <h3 class="fw-semibold mb-1">What if my package is damaged or lost?</h3>
                    <p class="text-muted mb-0">Contact our customer service team immediately. We'll work with you to resolve the issue and provide a replacement or refund.</p>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Returns &amp; Refunds</h2>
            <div class="d-flex flex-column gap-2">
                <div>
                    <h3 class="fw-semibold mb-1">What is your return policy?</h3>
                    <p class="text-muted mb-0">We offer a 30-day return policy for most items. Items must be in original condition with tags and packaging.</p>
                </div>
                <div>
                    <h3 class="fw-semibold mb-1">How do I return an item?</h3>
                    <p class="text-muted mb-0">Go to your account dashboard, select the order you want to return, and follow the return process. We'll provide a prepaid return label.</p>
                </div>
                <div>
                    <h3 class="fw-semibold mb-1">When will I receive my refund?</h3>
                    <p class="text-muted mb-0">Refunds are processed within 5-7 business days after we receive your returned item. The refund will appear on your original payment method.</p>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Payment &amp; Billing</h2>
            <div class="d-flex flex-column gap-2">
                <div>
                    <h3 class="fw-semibold mb-1">What payment methods do you accept?</h3>
                    <p class="text-muted mb-0">We accept all major credit cards, PayPal, Apple Pay, Google Pay, and bank transfers.</p>
                </div>
                <div>
                    <h3 class="fw-semibold mb-1">Is my payment information secure?</h3>
                    <p class="text-muted mb-0">Yes, we use secure payment processing and never store your full payment information on our servers.</p>
                </div>
                <div>
                    <h3 class="fw-semibold mb-1">Can I save my payment information?</h3>
                    <p class="text-muted mb-0">Yes, you can save your payment information securely in your account for faster checkout in the future.</p>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Still Have Questions?</h2>
            <p class="text-muted mb-3">Can't find the answer you're looking for? Our customer service team is here to help!</p>
            <div class="d-flex gap-2">
                <a href="@Url.Action("Contact", "Home")" class="btn btn-primary">Contact Us</a>
                <a href="mailto:support@buymate.com" class="btn btn-outline-secondary">Email Support</a>
            </div>
        </div>
    </div>
</div>
