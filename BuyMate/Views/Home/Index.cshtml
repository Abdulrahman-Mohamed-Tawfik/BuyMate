@using BuyMate.DTO.ViewModels.Shop
@model HomeViewModel
@{
    ViewData["Title"] = "Home";
    var requestToken = Antiforgery.GetAndStoreTokens(Context).RequestToken;
}

<div class="container mb-5">
    <input type="hidden" id="__RequestVerificationToken" value="@requestToken" />

    <!-- Hero Section -->
    <section class="bg-primary text-white rounded-3 p-5 mb-5 text-center">
        <div class="mx-auto" style="max-width: 48rem;">
            <h1 class="display-4 fw-bold mb-3">Welcome to BUYMATE</h1>
            <p class="fs-5 mb-4 text-light">Discover amazing products at unbeatable prices</p>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-light btn-lg d-inline-flex align-items-center">
                Shop Now
                <i class="fas fa-arrow-right ms-2"></i>
            </a>
        </div>
    </section>

    <!-- Featured Categories -->
    <section class="mb-5">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h2 class="h4 fw-bold mb-0">Shop by Category</h2>
            <a asp-controller="Shop" asp-action="Categories" class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center">
                View All
                <i class="fas fa-arrow-right ms-2"></i>
            </a>
        </div>
        <div class="row g-3">
            @foreach (var category in Model.Categories)
            {
                <div class="col-6 col-md-3">
                    <div class="card h-100 text-center" style="cursor:pointer;" onclick="location.href='@Url.Action("Index", "Shop", new { categoryId = category.Id })'">
                        <div class="card-body">
                            <div class="d-flex align-items-center justify-content-center rounded-circle mx-auto mb-3" style="width:3rem;height:3rem;">
                                @if (!string.IsNullOrEmpty(category.ImageUrl))
                                {
                                    <img src="@(category.ImageUrl)" alt="@category.Name" class="img-fluid rounded-circle" style="width:3rem;height:3rem;object-fit:cover;" />
                                }
                                else
                                {
                                    <div class="bg-primary rounded-circle" style="width:3rem;height:3rem;"></div>
                                }
                            </div>
                            <h3 class="h6 fw-semibold mb-1">@category.Name</h3>
                            <p class="small text-muted mb-0">
                                @category.ProductCount products
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Featured Products -->
    <section class="mb-5">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="d-flex align-items-center">
                <i class="fas fa-star text-warning me-2"></i>
                <h2 class="h4 fw-bold mb-0">Featured Products</h2>
            </div>
            <a asp-controller="Shop" asp-action="Index" asp-route-IsFeatured="true" class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center">
                View All
                <i class="fas fa-arrow-right ms-2"></i>
            </a>
        </div>

        <div class="row g-4">
            @foreach (var product in Model.FeaturedProducts)
            {
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card h-100" style="cursor:pointer;" onclick="location.href='@Url.Action("Product", "Shop", new { id = product.Id })'">
                        <div class="position-relative">
                            <img src="@(String.IsNullOrEmpty(product.ImageUrl) ? "/images/placeholder.png" : "/images/" + product.ImageUrl)" alt="@product.Name" class="card-img-top" style="height:240px;object-fit:cover;" />
                            @if (product.IsFlashDeal)
                            {
                                <span class="badge bg-danger position-absolute top-0 start-0 m-2">Flash Deal</span>
                            }
                            @if (product.Discount.HasValue && product.Discount > 0)
                            {
                                <span class="badge bg-secondary position-absolute top-0 end-0 m-2">-@product.Discount%</span>
                            }
                        </div>
                        <div class="card-body d-flex flex-column">
                            <div class="mb-2">
                                <h3 class="h6 fw-semibold mb-1 text-truncate" title="@product.Name">@product.Name</h3>
                                <p class="small text-muted mb-2">@product.Brand</p>
                                <div class="d-flex align-items-center mb-2">
                                    <div class="me-2">
                                        @{ var roundedRating = (int)Math.Round(product.Rating); }
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="fa-star @(i <= roundedRating ? "fas text-warning" : "far text-muted") small"></i>
                                        }
                                    </div>
                                    <span class="small text-muted">@product.Rating.ToString("F1") (@product.ReviewCount)</span>
                                </div>
                            </div>
                            <div class="mt-auto">
                                <div class="d-flex align-items-baseline mb-2">
                                    <span class="h5 fw-bold mb-0">$@product.Price</span>
                                    @if (product.OriginalPrice.HasValue)
                                    {
                                        <span class="small text-muted text-decoration-line-through ms-2">$@product.OriginalPrice</span>
                                    }
                                </div>
                                <button class="btn btn-primary w-100" onclick="event.stopPropagation(); addToCart('@product.Id')">Add to Cart</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Best Sellers -->
    <section class="mb-5">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="d-flex align-items-center">
                <i class="fas fa-chart-line text-success me-2"></i>
                <h2 class="h4 fw-bold mb-0">Best Sellers</h2>
            </div>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center">
                View All
                <i class="fas fa-arrow-right ms-2"></i>
            </a>
        </div>

        <div class="row g-4">
            @foreach (var product in Model.BestSellers)
            {
                <div class="col-6 col-lg-2">
                    <div class="card h-100" style="cursor:pointer;" onclick="location.href='@Url.Action("Product", "Shop", new { id = product.Id })'">
                        <div class="position-relative">
                            <img src="@(String.IsNullOrEmpty(product.ImageUrl) ? "/images/placeholder.png" : "/images/" + product.ImageUrl)" alt="@product.Name" class="card-img-top" style="height:180px;object-fit:cover;" />
                            @if (product.IsFlashDeal)
                            {
                                <span class="badge bg-danger position-absolute top-0 start-0 m-2">Flash Deal</span>
                            }
                            @if (product.Discount.HasValue && product.Discount > 0)
                            {
                                <span class="badge bg-secondary position-absolute top-0 end-0 m-2">-@product.Discount%</span>
                            }
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h3 class="small fw-semibold mb-1 text-truncate" title="@product.Name">@product.Name</h3>
                            <p class="small text-muted mb-2">@product.Brand</p>
                            <div class="d-flex align-items-center mb-2">
                                <div class="me-2">
                                    @{ var roundedRating = (int)Math.Round(product.Rating); }
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fa-star @(i <= roundedRating ? "fas text-warning" : "far text-muted") small"></i>
                                    }
                                </div>
                                <span class="small text-muted">@product.Rating.ToString("F1") (@product.ReviewCount)</span>
                            </div>
                            <div class="mt-auto">
                                <span class="fw-bold">$@product.Price</span>
                                @if (product.OriginalPrice.HasValue)
                                {
                                    <span class="small text-muted text-decoration-line-through ms-1">$@product.OriginalPrice</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Newsletter Signup -->
    <section class="mb-5">
        <h2 class="h4 fw-bold mb-2">Stay Updated</h2>
        <p class="text-muted mb-3 mx-auto" style="max-width:32rem;">
            Subscribe to our newsletter and be the first to know about new products, exclusive deals, and special offers.
        </p>
        <form class="row g-2 justify-content-center" novalidate>
            <div class="col-12 col-sm-7 col-md-5">
                <input type="email" class="form-control" placeholder="Enter your email" />
            </div>
            <div class="col-12 col-sm-auto">
                <button type="submit" class="btn btn-primary w-100">Subscribe</button>
            </div>
        </form>
    </section>
</div>

<script src="~/js/cart.js"></script>