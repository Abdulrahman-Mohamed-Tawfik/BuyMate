@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="container mb-5" style="max-width: 64rem;">
    <div class="text-center mb-4">
        <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-2"
            style="width:5rem;height:5rem;">
            <i class="fas fa-check text-success fs-2"></i>
        </div>
        <h1 class="h4 fw-bold text-success mb-1">Order Confirmed!</h1>
        <p class="text-muted mb-0">Thank you for your purchase. Your order has been successfully placed.</p>
    </div>

    <div class="d-flex flex-column gap-3">
        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Order Details</h2>
            <div class="row g-3 small">
                <div class="col-12 col-md-6">
                    <h3 class="fw-bold mb-1">Order Number</h3>
                    <p class="text-muted mb-0">#12345</p>
                </div>
                <div class="col-12 col-md-6">
                    <h3 class="fw-bold mb-1">Order Date</h3>
                    <p class="text-muted mb-0">December 15, 2024</p>
                </div>
                <div class="col-12 col-md-6">
                    <h3 class="fw-bold mb-1">Total Amount</h3>
                    <p class="h5 fw-bold text-primary mb-0">$1,199.00</p>
                </div>
                <div class="col-12 col-md-6">
                    <h3 class="fw-bold mb-1">Payment Method</h3>
                    <p class="text-muted mb-0">Credit Card ending in 1234</p>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Shipping Information</h2>
            <div class="row g-3 small">
                <div class="col-12 col-md-6">
                    <h3 class="fw-bold mb-1">Shipping Address</h3>
                    <p class="text-muted mb-0">
                        John Doe<br />
                        123 Main Street<br />
                        Anytown, ST 12345<br />
                        United States
                    </p>
                </div>
                <div class="col-12 col-md-6">
                    <h3 class="fw-bold mb-1">Shipping Method</h3>
                    <p class="text-muted mb-0">Standard Shipping (5-7 business days)</p>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Order Items</h2>
            <div class="d-flex flex-column gap-2 small">
                <div class="d-flex align-items-center gap-3 p-2 border rounded">
                    <img src="~/images/buymate-logo.png" alt="Product" class="rounded"
                        style="width:80px;height:80px;object-fit:contain;" />
                    <div class="flex-grow-1">
                        <h3 class="fw-bold mb-1">iPhone 15 Pro Max</h3>
                        <p class="text-muted mb-1">Color: Space Black, Storage: 256GB</p>
                        <div class="d-flex align-items-center gap-2">
                            <span class="fw-bold text-primary">$1,199.00</span>
                            <span class="text-muted">x1</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">What's Next?</h2>
            <div class="d-flex flex-column gap-2 small">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold"
                        style="width:2rem;height:2rem;">1</div>
                    <div>
                        <h3 class="fw-bold mb-1">Order Processing</h3>
                        <p class="text-muted mb-0">We're preparing your order for shipment</p>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center text-muted fw-bold"
                        style="width:2rem;height:2rem;">2</div>
                    <div>
                        <h3 class="fw-bold mb-1">Order Shipped</h3>
                        <p class="text-muted mb-0">You'll receive a tracking number via email</p>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center text-muted fw-bold"
                        style="width:2rem;height:2rem;">3</div>
                    <div>
                        <h3 class="fw-bold mb-1">Order Delivered</h3>
                        <p class="text-muted mb-0">Your order will arrive at your doorstep</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Need Help?</h2>
            <p class="text-muted small mb-3">
                If you have any questions about your order or need to make changes, our customer service team is here to
                help.
            </p>
            <div class="d-flex gap-2">
                <a href="@Url.Action("Contact", "Home")" class="btn btn-primary">Contact Support</a>
                <a href="@Url.Action("Orders", "Home")" class="btn btn-outline-secondary">View All Orders</a>
            </div>
        </div>
    </div>
</div>