@{
    ViewData["Title"] = "My Orders";
}

<div class="container mb-5" style="max-width: 72rem;">
    <h1 class="h4 fw-bold mb-3">My Orders</h1>

    <div class="d-flex flex-column gap-3 small">
        <div class="card p-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="h6 fw-bold mb-0">Order History</h2>
                <div class="d-flex align-items-center gap-2">
                    <span class="text-muted">Filter by:</span>
                    <select class="form-select form-select-sm" style="width:auto;">
                        <option>All Orders</option>
                        <option>Pending</option>
                        <option>Shipped</option>
                        <option>Delivered</option>
                        <option>Cancelled</option>
                    </select>
                </div>
            </div>

            <div class="d-flex flex-column gap-2">
                <div class="border rounded-3 p-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <h3 class="fw-bold mb-0">Order #12345</h3>
                            <p class="text-muted mb-0">Placed on December 15, 2024</p>
                        </div>
                        <div class="text-end">
                            <p class="fw-bold text-primary mb-1">$1,199.00</p>
                            <span class="badge bg-success rounded-pill">Delivered</span>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <img src="~/images/buymate-logo.png" alt="Product" class="rounded" style="width:64px;height:64px;object-fit:contain;" />
                        <div class="flex-grow-1">
                            <h4 class="fw-semibold mb-0">iPhone 15 Pro Max</h4>
                            <p class="text-muted mb-0">Color: Space Black, Storage: 256GB</p>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="@Url.Action("OrderDetail", "Home")" class="btn btn-outline-secondary btn-sm">View Details</a>
                            <button class="btn btn-outline-secondary btn-sm">Buy Again</button>
                        </div>
                    </div>
                </div>

                <div class="border rounded-3 p-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <h3 class="fw-bold mb-0">Order #12344</h3>
                            <p class="text-muted mb-0">Placed on December 10, 2024</p>
                        </div>
                        <div class="text-end">
                            <p class="fw-bold text-primary mb-1">$2,499.00</p>
                            <span class="badge bg-primary rounded-pill">Shipped</span>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <img src="~/images/buymate-logo.png" alt="Product" class="rounded" style="width:64px;height:64px;object-fit:contain;" />
                        <div class="flex-grow-1">
                            <h4 class="fw-semibold mb-0">MacBook Pro 16"</h4>
                            <p class="text-muted mb-0">Color: Space Gray, Storage: 512GB</p>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="@Url.Action("OrderDetail", "Home")" class="btn btn-outline-secondary btn-sm">View Details</a>
                            <button class="btn btn-outline-secondary btn-sm">Track Package</button>
                        </div>
                    </div>
                </div>

                <div class="border rounded-3 p-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div>
                            <h3 class="fw-bold mb-0">Order #12343</h3>
                            <p class="text-muted mb-0">Placed on December 5, 2024</p>
                        </div>
                        <div class="text-end">
                            <p class="fw-bold text-primary mb-1">$1,199.00</p>
                            <span class="badge bg-warning text-dark rounded-pill">Pending</span>
                        </div>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <img src="~/images/buymate-logo.png" alt="Product" class="rounded" style="width:64px;height:64px;object-fit:contain;" />
                        <div class="flex-grow-1">
                            <h4 class="fw-semibold mb-0">Samsung Galaxy S24 Ultra</h4>
                            <p class="text-muted mb-0">Color: Titanium Black, Storage: 256GB</p>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="@Url.Action("OrderDetail", "Home")" class="btn btn-outline-secondary btn-sm">View Details</a>
                            <button class="btn btn-outline-secondary btn-sm">Cancel Order</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h6 fw-bold mb-2">Quick Actions</h2>
            <div class="row g-2">
                <div class="col-12 col-md-4">
                    <a href="@Url.Action("Contact", "Home")" class="card p-2 text-center text-decoration-none h-100">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-2" style="width:3rem;height:3rem;">
                            <i class="fas fa-envelope text-primary"></i>
                        </div>
                        <h3 class="fw-bold mb-0" style="font-size:0.9rem;">Contact Support</h3>
                        <p class="text-muted mb-0" style="font-size:0.8rem;">Get help with your orders</p>
                    </a>
                </div>

                <div class="col-12 col-md-4">
                    <a href="@Url.Action("Returns", "Home")" class="card p-2 text-center text-decoration-none h-100">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-2" style="width:3rem;height:3rem;">
                            <i class="fas fa-undo-alt text-primary"></i>
                        </div>
                        <h3 class="fw-bold mb-0" style="font-size:0.9rem;">Start a Return</h3>
                        <p class="text-muted mb-0" style="font-size:0.8rem;">Return or exchange items</p>
                    </a>
                </div>

                <div class="col-12 col-md-4">
                    <a href="@Url.Action("Shipping", "Home")" class="card p-2 text-center text-decoration-none h-100">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-2" style="width:3rem;height:3rem;">
                            <i class="fas fa-shipping-fast text-primary"></i>
                        </div>
                        <h3 class="fw-bold mb-0" style="font-size:0.9rem;">Shipping Info</h3>
                        <p class="text-muted mb-0" style="font-size:0.8rem;">Learn about shipping options</p>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>