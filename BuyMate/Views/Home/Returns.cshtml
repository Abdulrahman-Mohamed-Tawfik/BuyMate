@{
    ViewData["Title"] = "Returns & Exchanges";
}

<div class="container mb-5" style="max-width: 64rem;">
    <h1 class="h4 fw-bold mb-3">Returns &amp; Exchanges</h1>

    <div class="d-flex flex-column gap-3 small">
        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Return Policy</h2>
            <p class="text-muted mb-2">
                We want you to be completely satisfied with your purchase. If you're not happy with your order,
                you can return it within 30 days of delivery for a full refund or exchange.
            </p>
            <div class="rounded-3 bg-dark bg-opacity-10 p-2">
                <p class="text-dark fw-semibold mb-0">
                    <i class="far fa-clock me-1"></i>
                    30-day return window for most items
                </p>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">How to Return an Item</h2>
            <div class="d-flex flex-column gap-2">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-dark d-flex align-items-center justify-content-center text-white fw-bold" style="width:2rem;height:2rem;">1</div>
                    <div>
                        <h3 class="fw-bold mb-1">Start Your Return</h3>
                        <p class="text-muted mb-0">Go to your account dashboard and select the order you want to return</p>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-dark d-flex align-items-center justify-content-center text-white fw-bold" style="width:2rem;height:2rem;">2</div>
                    <div>
                        <h3 class="fw-bold mb-1">Choose Return Reason</h3>
                        <p class="text-muted mb-0">Select why you're returning the item and choose refund or exchange</p>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-dark d-flex align-items-center justify-content-center text-white fw-bold" style="width:2rem;height:2rem;">3</div>
                    <div>
                        <h3 class="fw-bold mb-1">Print Return Label</h3>
                        <p class="text-muted mb-0">We'll provide a prepaid return label for you to print</p>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-dark d-flex align-items-center justify-content-center text-white fw-bold" style="width:2rem;height:2rem;">4</div>
                    <div>
                        <h3 class="fw-bold mb-1">Ship Your Return</h3>
                        <p class="text-muted mb-0">Package the item securely and drop it off at any authorized location</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Return Conditions</h2>
            <div class="d-flex flex-column gap-2">
                <div>
                    <h3 class="fw-bold mb-1">Items Must Be:</h3>
                    <ul class="text-muted mb-0">
                        <li>In original condition with all tags attached</li>
                        <li>In original packaging with all accessories included</li>
                        <li>Returned within 30 days of delivery</li>
                        <li>Accompanied by the original receipt or order confirmation</li>
                    </ul>
                </div>
                <div>
                    <h3 class="fw-bold mb-1">Items That Cannot Be Returned:</h3>
                    <ul class="text-muted mb-0">
                        <li>Personalized or customized items</li>
                        <li>Items damaged by misuse or normal wear</li>
                        <li>Items that have been used or worn</li>
                        <li>Items without original packaging</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Refund Processing</h2>
            <div class="d-flex flex-column gap-2">
                <div>
                    <h3 class="fw-bold mb-1">Refund Timeline</h3>
                    <ul class="text-muted mb-0">
                        <li>Refunds are processed within 5-7 business days after we receive your return</li>
                        <li>Refunds will appear on your original payment method</li>
                        <li>Bank processing times may vary (typically 3-5 business days)</li>
                    </ul>
                </div>
                <div>
                    <h3 class="fw-bold mb-1">Refund Methods</h3>
                    <ul class="text-muted mb-0">
                        <li>Credit card purchases: Refunded to original card</li>
                        <li>PayPal purchases: Refunded to PayPal account</li>
                        <li>Gift card purchases: Refunded as store credit</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Exchanges</h2>
            <p class="text-muted mb-2">
                Need a different size, color, or style? We make exchanges easy. Simply follow the return process
                and select "Exchange" instead of "Refund" when starting your return.
            </p>
            <div class="rounded-3 bg-dark bg-opacity-10 p-2">
                <p class="text-dark fw-semibold mb-0">
                    <i class="fas fa-exchange-alt me-1"></i>
                    Free exchanges on all items
                </p>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Return Shipping</h2>
            <div class="d-flex flex-column gap-2">
                <div>
                    <h3 class="fw-bold mb-1">Free Return Shipping</h3>
                    <p class="text-muted mb-0">
                        We provide prepaid return labels for most returns. Simply print the label and drop off your package
                        at any authorized shipping location.
                    </p>
                </div>
                <div>
                    <h3 class="fw-bold mb-1">Return Shipping Costs</h3>
                    <ul class="text-muted mb-0">
                        <li>Free for items returned due to our error</li>
                        <li>Free for defective or damaged items</li>
                        <li>Free for most standard returns</li>
                        <li>Customer pays for returns due to change of mind (in some cases)</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">International Returns</h2>
            <p class="text-muted mb-2">
                International returns are subject to different policies and may incur additional shipping costs.
                Please contact our customer service team before initiating an international return.
            </p>
            <div class="d-flex gap-2">
                <a href="@Url.Action("Contact", "Home")" class="btn btn-dark">Contact Support</a>
                <a href="mailto:returns@buymate.com" class="btn btn-outline-secondary">Email Returns Team</a>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Need Help?</h2>
            <p class="text-muted mb-2">
                If you have any questions about returns or exchanges, our customer service team is here to help.
                We're committed to making the return process as smooth as possible.
            </p>
            <div class="d-flex gap-2">
                <a href="@Url.Action("Contact", "Home")" class="btn btn-dark">Contact Support</a>
                <a href="@Url.Action("FAQ", "Home")" class="btn btn-outline-secondary">View FAQ</a>
            </div>
        </div>
    </div>
</div>
