                                </svg>
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                                </svg>
                            </div>
                            <span class="text-sm text-muted-foreground">(4.9)</span>
                        </div>
                        <button class="btn btn-primary w-full">Add to Cart</button>
                    </div>

                    <div class="card p-4 hover:shadow-lg transition-all cursor-pointer">
                        <div class="relative mb-4">
                            <img src="~/images/buymate-logo.png" alt="Product" class="w-full h-48 object-contain rounded-lg" />
                            <div class="absolute top-2 right-2 bg-green-500 text-white px-2 py-1 rounded text-sm font-bold">
                                NEW
                            </div>
                        </div>
                        <h3 class="font-bold mb-2">Samsung Galaxy S24 Ultra</h3>
                        <div class="flex items-center space-x-2 mb-2">
                            <span class="text-xl font-bold text-primary">$1,199</span>
                        </div>
                        <div class="flex items-center space-x-1 mb-3">
                            <div class="flex text-yellow-400">
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                                </svg>
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                                </svg>
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                                </svg>
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                                </svg>
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                                </svg>
                            </div>
                            <span class="text-sm text-muted-foreground">(4.7)</span>
                        </div>
                        <button class="btn btn-primary w-full">Add to Cart</button>
                    </div>
                </div>

                <div class="flex justify-center mt-8">
                    <button class="btn btn-secondary">Load More</button>
                </div>
            </div>
        </div>
    </div>
</div>
