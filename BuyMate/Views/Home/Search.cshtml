@{
    ViewData["Title"] = "Search Results";
}

<div class="max-w-6xl mx-auto">
    <h1 class="text-3xl font-bold mb-8">Search Results</h1>

    <div class="space-y-8">
        <div class="card p-6">
            <form class="flex space-x-4">
                <input type="text" placeholder="Search for products..." class="input flex-1" />
                <button type="submit" class="btn btn-primary">Search</button>
            </form>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
            <div class="lg:col-span-1">
                <div class="card p-6">
                    <h2 class="text-xl font-bold mb-4">Filters</h2>
                    
                    <div class="space-y-6">
                        <div>
                            <h3 class="font-bold mb-3">Category</h3>
                            <div class="space-y-2">
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">Electronics</span>
                                </label>
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">Fashion</span>
                                </label>
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">Home & Garden</span>
                                </label>
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">Sports</span>
                                </label>
                            </div>
                        </div>

                        <div>
                            <h3 class="font-bold mb-3">Price Range</h3>
                            <div class="space-y-2">
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">Under $50</span>
                                </label>
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">$50 - $100</span>
                                </label>
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">$100 - $500</span>
                                </label>
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">Over $500</span>
                                </label>
                            </div>
                        </div>

                        <div>
                            <h3 class="font-bold mb-3">Brand</h3>
                            <div class="space-y-2">
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">Apple</span>
                                </label>
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">Samsung</span>
                                </label>
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">Sony</span>
                                </label>
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">Nike</span>
                                </label>
                            </div>
                        </div>

                        <div>
                            <h3 class="font-bold mb-3">Rating</h3>
                            <div class="space-y-2">
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">4+ Stars</span>
                                </label>
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">3+ Stars</span>
                                </label>
                                <label class="flex items-center space-x-2">
                                    <input type="checkbox" class="checkbox" />
                                    <span class="text-sm">2+ Stars</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-3">
                <div class="flex items-center justify-between mb-6">
                    <p class="text-muted-foreground">Showing 1-12 of 245 results</p>
                    <div class="flex items-center space-x-2">
                        <span class="text-sm">Sort by:</span>
                        <select class="select">
                            <option>Relevance</option>
                            <option>Price: Low to High</option>
                            <option>Price: High to Low</option>
                            <option>Newest</option>
                            <option>Rating</option>
                        </select>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                    <div class="card p-4 hover:shadow-lg transition-all cursor-pointer">
                        <div class="relative mb-4">
                            <img src="~/images/buymate-logo.png" alt="Product" class="w-full h-48 object-contain rounded-lg" />
                            <div class="absolute top-2 right-2 bg-red-500 text-white px-2 py-1 rounded text-sm font-bold">
                                20% OFF
                            </div>
                        </div>
                        <h3 class="font-bold mb-2">iPhone 15 Pro Max</h3>
                        <div class="flex items-center space-x-2 mb-2">
                            <span class="text-xl font-bold text-primary">$959</span>
                            <span class="text-lg text-muted-foreground line-through">$1,199</span>
                        </div>
                        <div class="flex items-center space-x-1 mb-3">
                            <div class="flex text-yellow-400">
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                                </svg>
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                                </svg>
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                                </svg>
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                                </svg>
                                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                                    <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
                                </svg>
                            </div>
                            <span class="text-sm text-muted-foreground">(4.8)</span>
                        </div>
                        <button class="btn btn-primary w-full">Add to Cart</button>
                    </div>

                    <div class="card p-4 hover:shadow-lg transition-all cursor-pointer">
                        <div class="relative mb-4">
                            <img src="~/images/buymate-logo.png" alt="Product" class="w-full h-48 object-contain rounded-lg" />
                        </div>
                        <h3 class="font-bold mb-2">MacBook Pro 16"</h3>
                        <div class="flex items-center space-x-2 mb-2">
