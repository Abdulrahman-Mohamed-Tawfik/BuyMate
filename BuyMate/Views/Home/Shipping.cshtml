@{
    ViewData["Title"] = "Shipping Information";
}

<div class="container mb-5" style="max-width: 64rem;">
    <h1 class="h4 fw-bold mb-3">Shipping Information</h1>

    <div class="d-flex flex-column gap-3 small">
        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Shipping Options</h2>
            <div class="row g-3">
                <div class="col-12 col-md-4">
                    <div class="text-center border rounded-3 p-3 h-100">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-2" style="width:4rem;height:4rem;">
                            <i class="fas fa-box text-primary fs-4"></i>
                        </div>
                        <h3 class="fw-bold mb-1">Standard Shipping</h3>
                        <p class="h5 fw-bold text-primary mb-1">$5.99</p>
                        <p class="text-muted mb-0">5-7 business days</p>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="text-center border rounded-3 p-3 h-100">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-2" style="width:4rem;height:4rem;">
                            <i class="fas fa-bolt text-primary fs-4"></i>
                        </div>
                        <h3 class="fw-bold mb-1">Express Shipping</h3>
                        <p class="h5 fw-bold text-primary mb-1">$12.99</p>
                        <p class="text-muted mb-0">2-3 business days</p>
                    </div>
                </div>
                <div class="col-12 col-md-4">
                    <div class="text-center border rounded-3 p-3 h-100">
                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-2" style="width:4rem;height:4rem;">
                            <i class="far fa-clock text-primary fs-4"></i>
                        </div>
                        <h3 class="fw-bold mb-1">Same Day Delivery</h3>
                        <p class="h5 fw-bold text-primary mb-1">$19.99</p>
                        <p class="text-muted mb-0">Same day (select areas)</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Free Shipping</h2>
            <p class="text-muted mb-2">
                Enjoy free standard shipping on orders over $50! This applies to all orders within the continental United States.
            </p>
            <div class="rounded-3 bg-primary bg-opacity-10 p-2">
                <p class="text-primary fw-semibold mb-0">
                    <i class="far fa-clock me-1"></i>
                    Free shipping on orders over $50
                </p>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Shipping Destinations</h2>
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <h3 class="fw-bold mb-1">Domestic Shipping</h3>
                    <ul class="text-muted mb-0">
                        <li>Continental United States</li>
                        <li>Alaska and Hawaii</li>
                        <li>Puerto Rico</li>
                        <li>US Virgin Islands</li>
                    </ul>
                </div>
                <div class="col-12 col-md-6">
                    <h3 class="fw-bold mb-1">International Shipping</h3>
                    <ul class="text-muted mb-0">
                        <li>Canada</li>
                        <li>United Kingdom</li>
                        <li>European Union</li>
                        <li>Australia and New Zealand</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Order Processing</h2>
            <div class="d-flex flex-column gap-2">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold" style="width:2rem;height:2rem;">1</div>
                    <div>
                        <h3 class="fw-bold mb-1">Order Placed</h3>
                        <p class="text-muted mb-0">Your order is received and being processed</p>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold" style="width:2rem;height:2rem;">2</div>
                    <div>
                        <h3 class="fw-bold mb-1">Order Confirmed</h3>
                        <p class="text-muted mb-0">Payment is verified and order is confirmed</p>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold" style="width:2rem;height:2rem;">3</div>
                    <div>
                        <h3 class="fw-bold mb-1">Order Shipped</h3>
                        <p class="text-muted mb-0">Your order is packed and shipped</p>
                    </div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white fw-bold" style="width:2rem;height:2rem;">4</div>
                    <div>
                        <h3 class="fw-bold mb-1">Order Delivered</h3>
                        <p class="text-muted mb-0">Your order arrives at your doorstep</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Tracking Your Order</h2>
            <p class="text-muted mb-2">
                Once your order is shipped, you'll receive a tracking number via email. You can use this number to track your package
                on the carrier's website or through our order tracking system.
            </p>
            <div class="d-flex gap-2">
                <a href="#" class="btn btn-primary">Track Order</a>
                <a href="@Url.Action("Contact", "Home")" class="btn btn-outline-secondary">Need Help?</a>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Shipping Restrictions</h2>
            <p class="text-muted mb-2">
                Some items may have shipping restrictions due to size, weight, or regulatory requirements.
                These restrictions will be clearly indicated on the product page.
            </p>
            <ul class="text-muted mb-0">
                <li>Large items may require special handling</li>
                <li>Some electronics may have shipping restrictions</li>
                <li>International orders may be subject to customs duties</li>
                <li>Certain items cannot be shipped to all locations</li>
            </ul>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Contact Shipping Support</h2>
            <p class="text-muted mb-2">
                If you have any questions about shipping, delivery, or tracking, our support team is here to help.
            </p>
            <div class="d-flex gap-2">
                <a href="@Url.Action("Contact", "Home")" class="btn btn-primary">Contact Support</a>
                <a href="mailto:shipping@buymate.com" class="btn btn-outline-secondary">Email Shipping Team</a>
            </div>
        </div>
    </div>
</div>
