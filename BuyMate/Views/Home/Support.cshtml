@{
    ViewData["Title"] = "Support";
}

<div class="container mb-5" style="max-width: 64rem;">
    <h1 class="h4 fw-bold mb-3">Support Center</h1>

    <div class="d-flex flex-column gap-3 small">
        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">How Can We Help You?</h2>
            <p class="text-muted mb-3">
                Our support team is here to assist you with any questions or issues you may have.
                Choose the option that best describes what you need help with.
            </p>

            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <a href="@Url.Action("Contact", "Home")" class="card p-3 text-decoration-none h-100">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle bg-dark bg-opacity-10 d-flex align-items-center justify-content-center" style="width:3rem;height:3rem;">
                                <i class="fas fa-envelope text-dark"></i>
                            </div>
                            <div>
                                <h3 class="fw-bold mb-0">Contact Us</h3>
                                <p class="text-muted mb-0">Send us a message</p>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-12 col-md-6">
                    <a href="@Url.Action("FAQ", "Home")" class="card p-3 text-decoration-none h-100">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle bg-dark bg-opacity-10 d-flex align-items-center justify-content-center" style="width:3rem;height:3rem;">
                                <i class="fas fa-circle-question text-dark"></i>
                            </div>
                            <div>
                                <h3 class="fw-bold mb-0">FAQ</h3>
                                <p class="text-muted mb-0">Find answers to common questions</p>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-12 col-md-6">
                    <a href="#" class="card p-3 text-decoration-none h-100">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle bg-dark bg-opacity-10 d-flex align-items-center justify-content-center" style="width:3rem;height:3rem;">
                                <i class="fas fa-receipt text-dark"></i>
                            </div>
                            <div>
                                <h3 class="fw-bold mb-0">Track Order</h3>
                                <p class="text-muted mb-0">Check your order status</p>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-12 col-md-6">
                    <a href="#" class="card p-3 text-decoration-none h-100">
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle bg-dark bg-opacity-10 d-flex align-items-center justify-content-center" style="width:3rem;height:3rem;">
                                <i class="fas fa-rotate-left text-dark"></i>
                            </div>
                            <div>
                                <h3 class="fw-bold mb-0">Returns</h3>
                                <p class="text-muted mb-0">Start a return or exchange</p>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Quick Help Topics</h2>
            <div class="d-flex flex-column gap-2">
                <div class="border-start border-dark ps-3">
                    <h3 class="fw-bold mb-0">Order Issues</h3>
                    <p class="text-muted mb-0">Problems with your order, shipping, or delivery</p>
                </div>
                <div class="border-start border-dark ps-3">
                    <h3 class="fw-bold mb-0">Account Problems</h3>
                    <p class="text-muted mb-0">Login issues, password reset, or account settings</p>
                </div>
                <div class="border-start border-dark ps-3">
                    <h3 class="fw-bold mb-0">Payment Questions</h3>
                    <p class="text-muted mb-0">Billing, refunds, or payment method issues</p>
                </div>
                <div class="border-start border-dark ps-3">
                    <h3 class="fw-bold mb-0">Product Support</h3>
                    <p class="text-muted mb-0">Questions about products, specifications, or compatibility</p>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Contact Information</h2>
            <div class="row g-3 text-center">
                <div class="col-12 col-md-4">
                    <div class="rounded-circle bg-dark bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-2" style="width:4rem;height:4rem;">
                        <i class="fas fa-phone text-dark fs-4"></i>
                    </div>
                    <h3 class="fw-bold mb-1">Phone Support</h3>
                    <p class="text-muted mb-0">+1 (555) 123-4567</p>
                    <p class="text-muted mb-0">Mon-Fri: 9AM-6PM</p>
                </div>
                <div class="col-12 col-md-4">
                    <div class="rounded-circle bg-dark bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-2" style="width:4rem;height:4rem;">
                        <i class="fas fa-envelope-open-text text-dark fs-4"></i>
                    </div>
                    <h3 class="fw-bold mb-1">Email Support</h3>
                    <p class="text-muted mb-0">support@buymate.com</p>
                    <p class="text-muted mb-0">24/7 response</p>
                </div>
                <div class="col-12 col-md-4">
                    <div class="rounded-circle bg-dark bg-opacity-10 d-flex align-items-center justify-content-center mx-auto mb-2" style="width:4rem;height:4rem;">
                        <i class="fas fa-comments text-dark fs-4"></i>
                    </div>
                    <h3 class="fw-bold mb-1">Live Chat</h3>
                    <p class="text-muted mb-0">Available 24/7</p>
                    <p class="text-muted mb-0">Instant support</p>
                </div>
            </div>
        </div>

        <div class="card p-3">
            <h2 class="h5 fw-bold mb-2">Still Need Help?</h2>
            <p class="text-muted mb-3">
                If you can't find what you're looking for, our support team is always ready to help.
                We're committed to providing you with the best possible experience.
            </p>
            <div class="d-flex gap-2">
                <a href="@Url.Action("Contact", "Home")" class="btn btn-dark">Contact Support</a>
                <a href="mailto:support@buymate.com" class="btn btn-outline-secondary">Send Email</a>
            </div>
        </div>
    </div>
</div>
