@{
    ViewData["Title"] = "Support";
}

<div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold mb-8">Support Center</h1>

    <div class="space-y-8">
        <div class="card p-8">
            <h2 class="text-2xl font-bold mb-4">How Can We Help You?</h2>
            <p class="text-muted-foreground leading-relaxed mb-6">
                Our support team is here to assist you with any questions or issues you may have. 
                Choose the option that best describes what you need help with.
            </p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <a href="@Url.Action("Contact", "Home")" class="card p-6 hover:shadow-lg transition-all cursor-pointer">
                    <div class="flex items-center space-x-4">
                        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
                            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-bold">Contact Us</h3>
                            <p class="text-sm text-muted-foreground">Send us a message</p>
                        </div>
                    </div>
                </a>

                <a href="@Url.Action("FAQ", "Home")" class="card p-6 hover:shadow-lg transition-all cursor-pointer">
                    <div class="flex items-center space-x-4">
                        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
                            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-bold">FAQ</h3>
                            <p class="text-sm text-muted-foreground">Find answers to common questions</p>
                        </div>
                    </div>
                </a>

                <a href="#" class="card p-6 hover:shadow-lg transition-all cursor-pointer">
                    <div class="flex items-center space-x-4">
                        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
                            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-bold">Track Order</h3>
                            <p class="text-sm text-muted-foreground">Check your order status</p>
                        </div>
                    </div>
                </a>

                <a href="#" class="card p-6 hover:shadow-lg transition-all cursor-pointer">
                    <div class="flex items-center space-x-4">
                        <div class="w-12 h-12 bg-primary/10 rounded-full flex items-center justify-center">
                            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path>
                            </svg>
                        </div>
                        <div>
                            <h3 class="font-bold">Returns</h3>
                            <p class="text-sm text-muted-foreground">Start a return or exchange</p>
                        </div>
                    </div>
                </a>
            </div>
        </div>

        <div class="card p-8">
            <h2 class="text-2xl font-bold mb-4">Quick Help Topics</h2>
            <div class="space-y-4">
                <div class="border-l-4 border-primary pl-4">
                    <h3 class="font-bold">Order Issues</h3>
                    <p class="text-sm text-muted-foreground">Problems with your order, shipping, or delivery</p>
                </div>
                <div class="border-l-4 border-primary pl-4">
                    <h3 class="font-bold">Account Problems</h3>
                    <p class="text-sm text-muted-foreground">Login issues, password reset, or account settings</p>
                </div>
                <div class="border-l-4 border-primary pl-4">
                    <h3 class="font-bold">Payment Questions</h3>
                    <p class="text-sm text-muted-foreground">Billing, refunds, or payment method issues</p>
                </div>
                <div class="border-l-4 border-primary pl-4">
                    <h3 class="font-bold">Product Support</h3>
                    <p class="text-sm text-muted-foreground">Questions about products, specifications, or compatibility</p>
                </div>
            </div>
        </div>

        <div class="card p-8">
            <h2 class="text-2xl font-bold mb-4">Contact Information</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="text-center">
                    <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
                        </svg>
                    </div>
                    <h3 class="font-bold mb-2">Phone Support</h3>
                    <p class="text-muted-foreground">+1 (555) 123-4567</p>
                    <p class="text-sm text-muted-foreground">Mon-Fri: 9AM-6PM</p>
                </div>
                <div class="text-center">
                    <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                        </svg>
                    </div>
                    <h3 class="font-bold mb-2">Email Support</h3>
                    <p class="text-muted-foreground">support@buymate.com</p>
                    <p class="text-sm text-muted-foreground">24/7 response</p>
                </div>
                <div class="text-center">
                    <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                        </svg>
                    </div>
                    <h3 class="font-bold mb-2">Live Chat</h3>
                    <p class="text-muted-foreground">Available 24/7</p>
                    <p class="text-sm text-muted-foreground">Instant support</p>
                </div>
            </div>
        </div>

        <div class="card p-8">
            <h2 class="text-2xl font-bold mb-4">Still Need Help?</h2>
            <p class="text-muted-foreground leading-relaxed mb-6">
                If you can't find what you're looking for, our support team is always ready to help. 
                We're committed to providing you with the best possible experience.
            </p>
            <div class="flex space-x-4">
                <a href="@Url.Action("Contact", "Home")" class="btn btn-primary">Contact Support</a>
                <a href="mailto:support@buymate.com" class="btn btn-secondary">Send Email</a>
            </div>
        </div>
    </div>
</div>
