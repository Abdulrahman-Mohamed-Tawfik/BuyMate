@{
    ViewData["Title"] = "My Wishlist";
}

<div class="max-w-6xl mx-auto">
    <h1 class="text-3xl font-bold mb-8">My Wishlist</h1>

    <div class="space-y-8">
        <div class="card p-6">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-xl font-bold">Saved Items (3)</h2>
                <button class="btn btn-secondary">Clear All</button>
            </div>

            <div class="space-y-4">
                <div class="flex items-center space-x-4 p-4 border rounded-lg hover:shadow-md transition-all">
                    <img src="~/images/buymate-logo.png" alt="Product" class="w-20 h-20 object-cover rounded-lg" />
                    <div class="flex-1">
                        <h3 class="font-bold">iPhone 15 Pro Max</h3>
                        <p class="text-sm text-muted-foreground">Electronics</p>
                        <div class="flex items-center space-x-2 mt-2">
                            <span class="text-xl font-bold text-primary">$1,199</span>
                            <span class="text-lg text-muted-foreground line-through">$1,399</span>
                        </div>
                    </div>
                    <div class="flex items-center space-x-2">
                        <button class="btn btn-primary">Add to Cart</button>
                        <button class="btn btn-secondary">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="flex items-center space-x-4 p-4 border rounded-lg hover:shadow-md transition-all">
                    <img src="~/images/buymate-logo.png" alt="Product" class="w-20 h-20 object-cover rounded-lg" />
