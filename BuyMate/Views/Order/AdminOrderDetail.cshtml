@using BuyMate.DTO.ViewModels.Order
@model OrderViewModel
@{
    ViewData["Title"] = "Order Detail (Admin)";
}

<div class="max-w-4xl mx-auto">
    <div class="mb-8">
        <a asp-controller="Order" asp-action="GetAll" class="btn btn-ghost mb-4">Back to All Orders</a>

        <h1 class="text-3xl font-bold">Order #@Model.Id</h1>
        <p class="text-muted-foreground">Placed on @Model.OrderDate.ToString("MMM dd, yyyy 'at' h:mm tt")</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-6">
            <div class="card p-6">
                <h2 class="text-xl font-bold mb-4">Order Items</h2>
                <div class="space-y-4">
                    @foreach (var item in Model.Items)
                    {
                        <div class="flex items-center space-x-4">
                            <img src="@("/images/" + item.ImageUrl ?? "/images/placeholder.png")" alt="@item.ProductName" class="w-20 h-20 object-contain rounded-lg" />
                            <div class="flex-1">
                                <h3 class="font-medium">@item.ProductName</h3>
                                <p class="text-sm text-muted-foreground">@item.Brand</p>
                                <p class="text-sm text-muted-foreground">Quantity: @item.Quantity</p>
                            </div>
                            <div class="text-right">
                                <p class="font-medium">$@item.UnitPrice</p>
                                <p class="text-sm text-muted-foreground">Total: $@item.TotalPrice</p>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="card p-6">
                <h2 class="text-xl font-bold mb-4">Shipping Information</h2>
                <div class="text-sm text-muted-foreground">
                    <p>@Model.Address.Street</p>
                    <p>@Model.Address.City, @Model.Address.State @Model.Address.ZipCode</p>
                </div>
            </div>
        </div>

        <div class="space-y-6">
            <div class="card p-6">
                <h2 class="text-xl font-bold mb-4">Order Summary</h2>
                <div class="space-y-2">
                    <div class="flex justify-between">
                        <span>Subtotal</span>
                        <span>$@Model.Subtotal</span>
                    </div>
                    <div class="flex justify-between">
                        <span>Shipping</span>
                        <span>Free</span>
                    </div>
                    <div class="flex justify-between">
                        <span>Tax</span>
                        <span>$0.00</span>
                    </div>
                    <hr class="my-2" />
                    <div class="flex justify-between text-lg font-bold">
                        <span>Total</span>
                        <span>$@Model.Total</span>
                    </div>
                </div>
            </div>

            <div class="card p-6">
                <h2 class="text-xl font-bold mb-4">Order Actions</h2>
                <div class="space-y-3">
                    <a asp-controller="Order" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit Status</a>
                    <form asp-controller="Order" asp-action="Delete" method="post" onsubmit="return confirm('Are you sure?');">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-destructive">Delete Order</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>