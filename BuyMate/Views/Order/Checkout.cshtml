@using BuyMate.DTO.ViewModels
@using BuyMate.DTO.ViewModels.Cart
@using BuyMate.DTO.ViewModels.Order
@model CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="container mb-5" style="max-width: 60rem;">
    <h1 class="h3 fw-bold mb-4">Checkout</h1>

    <form asp-action="Create" asp-controller="Order" method="post">
        <div class="row g-4">
            <div class="col-12 col-lg-7">
                <div class="card mb-3">
                    <div class="card-body">
                        <h2 class="h5 fw-bold mb-3">Shipping Information</h2>

                        <div class="mb-3">
                            <label asp-for="ShippingAddress.Street" class="form-label small">Street Address</label>
                            <input asp-for="ShippingAddress.Street" class="form-control" placeholder="Enter your street address" />
                            <span asp-validation-for="ShippingAddress.Street" class="small text-danger"></span>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-12 col-md-6">
                                <label asp-for="ShippingAddress.City" class="form-label small">City</label>
                                <input asp-for="ShippingAddress.City" class="form-control" placeholder="City" />
                                <span asp-validation-for="ShippingAddress.City" class="small text-danger"></span>
                            </div>
                            <div class="col-12 col-md-6">
                                <label asp-for="ShippingAddress.State" class="form-label small">State</label>
                                <input asp-for="ShippingAddress.State" class="form-control" placeholder="State" />
                                <span asp-validation-for="ShippingAddress.State" class="small text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ShippingAddress.ZipCode" class="form-label small">ZIP Code</label>
                            <input asp-for="ShippingAddress.ZipCode" class="form-control" placeholder="ZIP Code" />
                            <span asp-validation-for="ShippingAddress.ZipCode" class="small text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <h2 class="h5 fw-bold mb-3">Payment Method</h2>

                        <div class="d-flex flex-column gap-2">
                            <div class="form-check">
                                <input asp-for="PaymentMethod" type="radio" value="Card" id="pm-card" class="form-check-input" />
                                <label for="pm-card" class="form-check-label small">Credit/Debit Card</label>
                            </div>
                            <div class="form-check">
                                <input asp-for="PaymentMethod" type="radio" value="Wallet" id="pm-wallet" class="form-check-input" />
                                <label for="pm-wallet" class="form-check-label small">Digital Wallet</label>
                            </div>
                            <div class="form-check">
                                <input asp-for="PaymentMethod" type="radio" value="Cod" id="pm-cod" class="form-check-input" />
                                <label for="pm-cod" class="form-check-label small">Cash on Delivery</label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-3">
                    <div class="card-body">
                        <h2 class="h5 fw-bold mb-3">Delivery Options</h2>

                        <div class="d-flex flex-column gap-2">
                            <div class="form-check">
                                <input asp-for="DeliveryType" type="radio" value="Standard" id="dt-standard" class="form-check-input" />
                                <label for="dt-standard" class="form-check-label small">Standard Delivery (5-7 days) - Free</label>
                            </div>
                            <div class="form-check">
                                <input asp-for="DeliveryType" type="radio" value="Express" id="dt-express" class="form-check-input" />
                                <label for="dt-express" class="form-check-label small">Express Delivery (2-3 days) - $9.99</label>
                            </div>
                            <div class="form-check">
                                <input asp-for="DeliveryType" type="radio" value="Scheduled" id="dt-scheduled" class="form-check-input" />
                                <label for="dt-scheduled" class="form-check-label small">Scheduled Delivery - $4.99</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-5">
                <div class="card">
                    <div class="card-body">
                        <h2 class="h5 fw-bold mb-3">Order Summary</h2>

                        <div class="d-flex flex-column gap-2 mb-3">
                            @foreach (var item in Model.CartVm.Items)
                            {
                                <div class="d-flex align-items-center justify-content-between">
                                    <div>
                                        <div class="small fw-semibold">@item.ProductName</div>
                                        <div class="small text-muted">Qty: @item.Quantity</div>
                                    </div>
                                    <span class="fw-bold">$@item.TotalPrice</span>
                                </div>
                            }
                        </div>

                        <hr class="my-3" />

                        <div class="d-flex flex-column gap-1 mb-3">
                            <div class="d-flex justify-content-between">
                                <span>Subtotal</span>
                                <span>$@Model.CartVm.Items.Sum(item => item.TotalPrice)</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Shipping</span>
                                <span>Free</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span>Tax</span>
                                <span>$0.00</span>
                            </div>
                            <hr class="my-2" />
                            <div class="d-flex justify-content-between fw-bold">
                                <span>Total</span>
                                <span>$@Model.CartVm.Items.Sum(item => item.TotalPrice)</span>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 btn-lg mt-2">
                            Place Order
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>
