@using BuyMate.DTO.ViewModels.Order
@model OrderViewModel
@{
    ViewData["Title"] = "Edit Order";
}

<div class="container mb-5" style="max-width: 32rem;">
    <h1 class="h5 fw-bold mb-3">Edit Order</h1>

    <form asp-action="UpdateStatus" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="card p-3">
            <div class="mb-3">
                <label class="form-label small">Order Status</label>
                <select asp-for="OrderStatus" class="form-select">
                    <option value="0">Pending</option>
                    <option value="1">Confirmed</option>
                    <option value="2">Shipped</option>
                    <option value="3">Delivered</option>
                    <option value="4">Cancelled</option>
                    <option value="5">Returned</option>
                </select>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-controller="Order" asp-action="GetAll" class="btn btn-outline-secondary btn-sm">Cancel</a>
                <button type="submit" class="btn btn-dark btn-sm">Save</button>
            </div>
        </div>
    </form>
</div>