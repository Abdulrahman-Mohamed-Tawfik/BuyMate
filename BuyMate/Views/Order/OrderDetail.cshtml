@using BuyMate.DTO.ViewModels.Order
@model OrderViewModel
@{
    ViewData["Title"] = "Order Detail";
}

<div class="container mb-5" style="max-width: 48rem;">
    <div class="mb-3">
        <a asp-controller="Order" asp-action="Index" class="btn btn-outline-secondary btn-sm mb-2">
            <i class="fas fa-arrow-left me-1"></i> Back to Orders
        </a>
        <h1 class="h4 fw-bold mb-1">Order #@Model.TrackingNumber</h1>
        <p class="small text-muted">Placed on @Model.OrderDate.ToString("MMM dd, yyyy 'at' h:mm tt")</p>
    </div>

    <div class="row g-4">
        <div class="col-12 col-lg-8 d-flex flex-column gap-3">
            <div class="card p-3">
                <h2 class="h5 fw-bold mb-3">Order Items</h2>
                @if (Model.Items != null && Model.Items.Any())
                {
                    <div class="d-flex flex-column gap-2">
                        @foreach (var item in Model.Items)
                        {
                            <div class="d-flex align-items-center gap-3">
                                <img src="@((!string.IsNullOrEmpty(item.ImageUrl) ? "/images/" + item.ImageUrl : "/images/placeholder.png"))" alt="@item.ProductName" class="rounded" style="width:80px;height:80px;object-fit:contain;" />
                                <div class="flex-grow-1">
                                    <h3 class="small fw-semibold mb-0">@item.ProductName</h3>
                                    <p class="small text-muted mb-0">@item.Brand</p>
                                    <p class="small text-muted mb-0">Quantity: @item.Quantity</p>
                                </div>
                                <div class="text-end">
                                    <p class="small fw-semibold mb-0">$@item.UnitPrice</p>
                                    <p class="small text-muted mb-0">Total: $@item.TotalPrice</p>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="small text-muted mb-0">No items found for this order.</p>
                }
            </div>

            <div class="card p-3">
                <h2 class="h5 fw-bold mb-3">Shipping Information</h2>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <h3 class="small fw-bold mb-1">Shipping Address</h3>
                        <p class="small text-muted mb-0">@Model.Address.Street</p>
                        <p class="small text-muted mb-0">@Model.Address.City, @Model.Address.State @Model.Address.ZipCode</p>
                    </div>
                    <div class="col-12 col-md-6">
                        <h3 class="small fw-bold mb-1">Tracking Information</h3>
                        @if (!string.IsNullOrEmpty(Model.TrackingId))
                        {
                            <p class="small text-muted mb-1">Tracking Number: @Model.TrackingId</p>
                            <a href="#" class="small text-primary text-decoration-none">Track Package</a>
                        }
                        else
                        {
                            <p class="small text-muted mb-0">No tracking available yet.</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4 d-flex flex-column gap-3">
            <div class="card p-3">
                <h2 class="h5 fw-bold mb-3">Order Summary</h2>
                <div class="d-flex flex-column gap-1 small">
                    <div class="d-flex justify-content-between"><span>Subtotal</span><span>$@Model.Subtotal</span></div>
                    <div class="d-flex justify-content-between"><span>Shipping</span><span>Free</span></div>
                    <div class="d-flex justify-content-between"><span>Tax</span><span>$0.00</span></div>
                    <hr class="my-2" />
                    <div class="d-flex justify-content-between fw-bold"><span>Total</span><span>$@Model.Total</span></div>
                </div>
            </div>

            <div class="card p-3">
                <h2 class="h5 fw-bold mb-3">Order Status</h2>
                <div class="d-flex flex-column gap-2 small">
                    <div class="d-flex align-items-center">
                        <span class="rounded-circle bg-success me-2" style="width:0.75rem;height:0.75rem;"></span>
                        <span>Order Placed</span>
                        <span class="text-muted ms-auto">@Model.OrderDate.ToString("MMM dd")</span>
                    </div>

                    @if (Model.Status == OrderStatusViewModel.Confirmed || Model.Status == OrderStatusViewModel.Shipped || Model.Status == OrderStatusViewModel.Delivered)
                    {
                        <div class="d-flex align-items-center">
                            <span class="rounded-circle bg-success me-2" style="width:0.75rem;height:0.75rem;"></span>
                            <span>Order Confirmed</span>
                        </div>
                    }

                    @if (Model.Status == OrderStatusViewModel.Shipped || Model.Status == OrderStatusViewModel.Delivered)
                    {
                        <div class="d-flex align-items-center">
                            <span class="rounded-circle bg-success me-2" style="width:0.75rem;height:0.75rem;"></span>
                            <span>Shipped</span>
                            @if (!string.IsNullOrEmpty(Model.TrackingId))
                            {
                                <span class="text-muted ms-auto">@Model.TrackingId</span>
                            }
                        </div>
                    }

                    @if (Model.Status == OrderStatusViewModel.Delivered)
                    {
                        <div class="d-flex align-items-center">
                            <span class="rounded-circle bg-success me-2" style="width:0.75rem;height:0.75rem;"></span>
                            <span>Delivered</span>
                            @if (Model.ActualDelivery.HasValue)
                            {
                                <span class="text-muted ms-auto">@Model.ActualDelivery.Value.ToString("MMM dd")</span>
                            }
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.TrackingId))
                {
                    <div class="mt-3 pt-2 border-top small">
                        <p class="text-muted mb-1">Tracking Number</p>
                        <p class="font-monospace mb-0">@Model.TrackingId</p>
                    </div>
                }
            </div>

            <div class="d-flex gap-2">
                <a asp-controller="Order" asp-action="Index" class="btn btn-outline-secondary flex-fill">Back to Orders</a>
                <button class="btn btn-primary flex-fill" type="button">Download Invoice</button>
            </div>

            @if (Model.Status == OrderStatusViewModel.Pending)
            {
                <form id="cancelOrderForm" asp-controller="Order" asp-action="Cancel" method="post" class="mt-2">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="button" id="cancelOrderBtn" class="btn btn-danger w-100">Cancel Order</button>
                </form>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        (function () {
            var btn = document.getElementById('cancelOrderBtn');
            if (!btn) return;
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                Swal.fire({
                    title: 'Cancel order?',
                    text: 'Are you sure you want to cancel this order? This action cannot be undone.',
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    confirmButtonText: 'Yes, cancel it',
                    cancelButtonText: 'No, keep order'
                }).then((result) => {
                    if (result.isConfirmed) {
                        document.getElementById('cancelOrderForm').submit();
                    }
                });
            });
        })();
    </script>
}