@using BuyMate.DTO.ViewModels.Order
@model OrderViewModel
@{
	ViewData["Title"] = "Order Detail";
}

<div class="max-w-4xl mx-auto">
	<div class="mb-8">
		<a asp-controller="Order" asp-action="Index" class="btn btn-ghost mb-4">
			<svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="002424">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1519l-7-77-7"></path>
			</svg>
			Back to Orders
		</a>

		<h1 class="text-3xl font-bold">Order #@Model.TrackingNumber</h1>
		<p class="text-muted-foreground">Placed on @Model.OrderDate.ToString("MMM dd, yyyy 'at' h:mm tt")</p>
	</div>

	<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
		<!-- Order Items -->
		<div class="lg:col-span-2 space-y-6">
			<div class="card p-6">
				<h2 class="text-xl font-bold mb-4">Order Items</h2>
				<div class="space-y-4">
					@if (Model.Items != null && Model.Items.Any())
					{
						@foreach (var item in Model.Items)
						{
							<div class="flex items-center space-x-4">
								<img src="@("/images/"+item.ImageUrl ?? "/images/placeholder.png")" alt="@item.ProductName" class="w-20 h-20 object-contain rounded-lg" />
								<div class="flex-1">
									<h3 class="font-medium">@item.ProductName</h3>
									<p class="text-sm text-muted-foreground">@item.Brand</p>
									<p class="text-sm text-muted-foreground">Quantity: @item.Quantity</p>
								</div>
								<div class="text-right">
									<p class="font-medium">$@item.UnitPrice</p>
									<p class="text-sm text-muted-foreground">Total: $@item.TotalPrice</p>
								</div>
							</div>
						}
					}
					else
					{
						<p class="text-sm text-muted-foreground">No items found for this order.</p>
					}
				</div>
			</div>

			<!-- Shipping Address -->
			<div class="card p-6">
				<h2 class="text-xl font-bold mb-4">Shipping Information</h2>
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					<div>
						<h3 class="font-bold mb-2">Shipping Address</h3>
						<div class="text-sm text-muted-foreground">
							<p>@Model.Address.Street</p>
							<p>@Model.Address.City, @Model.Address.State @Model.Address.ZipCode</p>
						</div>
					</div>
					<div>
						<h3 class="font-bold mb-2">Tracking Information</h3>
						@if (!string.IsNullOrEmpty(Model.TrackingId))
						{
							<p class="text-sm text-muted-foreground">Tracking Number: @Model.TrackingId</p>
							<a href="#" class="text-primary hover:underline">Track Package</a>
						}
						else
						{
							<p class="text-sm text-muted-foreground">No tracking available yet.</p>
						}
					</div>
				</div>
			</div>
		</div>

		<!-- Order Summary -->
		<div class="space-y-6">
			<div class="card p-6">
				<h2 class="text-xl font-bold mb-4">Order Summary</h2>

				<div class="space-y-2">
					<div class="flex justify-between">
						<span>Subtotal</span>
						<span>$@Model.Subtotal</span>
					</div>
					<div class="flex justify-between">
						<span>Shipping</span>
						<span>Free</span>
					</div>
					<div class="flex justify-between">
						<span>Tax</span>
						<span>$0.00</span>
					</div>
					<hr class="my-2" />
					<div class="flex justify-between text-lg font-bold">
						<span>Total</span>
						<span>$@Model.Total</span>
					</div>
				</div>
			</div>

			<div class="card p-6">
				<h2 class="text-xl font-bold mb-4">Order Status</h2>
				<div class="space-y-3">
					<div class="flex items-center">
						<div class="w-3 h-3 rounded-full bg-green-500 mr-3"></div>
						<span class="text-sm">Order Placed</span>
						<span class="text-xs text-muted-foreground ml-auto">@Model.OrderDate.ToString("MMM dd")</span>
					</div>

					@if (Model.Status == OrderStatusViewModel.Confirmed || Model.Status == OrderStatusViewModel.Shipped || Model.Status == OrderStatusViewModel.Delivered)
					{
						<div class="flex items-center">
							<div class="w-3 h-3 rounded-full bg-green-500 mr-3"></div>
							<span class="text-sm">Order Confirmed</span>
						</div>
					}

					@if (Model.Status == OrderStatusViewModel.Shipped || Model.Status == OrderStatusViewModel.Delivered)
					{
						<div class="flex items-center">
							<div class="w-3 h-3 rounded-full bg-green-500 mr-3"></div>
							<span class="text-sm">Shipped</span>
							@if (!string.IsNullOrEmpty(Model.TrackingId))
							{
								<span class="text-xs text-muted-foreground ml-auto">@Model.TrackingId</span>
							}
						</div>
					}

					@if (Model.Status == OrderStatusViewModel.Delivered)
					{
						<div class="flex items-center">
							<div class="w-3 h-3 rounded-full bg-green-500 mr-3"></div>
							<span class="text-sm">Delivered</span>
							@if (Model.ActualDelivery.HasValue)
							{
								<span class="text-xs text-muted-foreground ml-auto">@Model.ActualDelivery.Value.ToString("MMM dd")</span>
							}
						</div>
					}
				</div>

				@if (!string.IsNullOrEmpty(Model.TrackingId))
				{
					<div class="mt-4 pt-4 border-t">
						<p class="text-sm text-muted-foreground mb-2">Tracking Number</p>
						<p class="font-mono text-sm">@Model.TrackingId</p>
					</div>
				}
			</div>

			<div class="flex space-x-4">
				<a asp-controller="Order" asp-action="Index" class="btn btn-secondary">Back to Orders</a>
				<button class="btn btn-primary">Download Invoice</button>
			</div>

			@* Cancel button for pending orders *@
			@if (Model.Status == OrderStatusViewModel.Pending)
			{
				<form id="cancelOrderForm" asp-controller="Order" asp-action="Cancel" method="post" class="mt-4">
					<input type="hidden" name="id" value="@Model.Id" />
					<button type="button" id="cancelOrderBtn" class="btn btn-destructive">Cancel Order</button>
				</form>
			}
		</div>
	</div>
</div>

@section Scripts {
	<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
	<script>
		(function(){
			var btn = document.getElementById('cancelOrderBtn');
			if (!btn) return;
			btn.addEventListener('click', function(e){
				e.preventDefault();
				Swal.fire({
					title: 'Cancel order?',
					text: 'Are you sure you want to cancel this order? This action cannot be undone.',
					icon: 'warning',
					showCancelButton: true,
					confirmButtonColor: '#d33',
					confirmButtonText: 'Yes, cancel it',
					cancelButtonText: 'No, keep order'
				}).then((result) => {
					if (result.isConfirmed) {
						document.getElementById('cancelOrderForm').submit();
					}
				});
			});
		})();
	</script>
}