@model BuyMate.DTO.ViewModels.ProductCreateViewModel

@{
	ViewData["Title"] = "Create Product";
}

<div class="max-w-3xl mx-auto card p-8 mt-10">
	<h1 class="text-2xl font-bold mb-6">Create New Product</h1>
	<form method="post" asp-action="Create" id="createForm" enctype="multipart/form-data">
		@Html.AntiForgeryToken()
		<!-- Name -->
		<div class="mb-4">
			<label class="font-medium">Name</label>
			<input asp-for="Name" class="input w-full" />
		</div>

		<!-- Brand (optional) -->
		<div class="mb-4">
			<label class="font-medium">Brand </label>
			<input asp-for="Brand" class="input w-full" />
		</div>

		<!-- Description -->
		<div class="mb-4">
			<label class="font-medium">Description</label>
			<textarea asp-for="Description" class="input w-full"></textarea>
		</div>

		<!-- Price -->
		<div class="mb-4">
			<label class="font-medium">Price</label>
			<input asp-for="Price" type="number" step="0.01" class="input w-full" />
		</div>

		<!-- Stock -->
		<div class="mb-4">
			<label class="font-medium">Stock Quantity</label>
			<input asp-for="StockQuantity" type="number" class="input w-full" />
		</div>

		<!-- Category selection dropdown (optional) -->
		<div class="mb-4">
			<label class="font-medium">Category </label>
			<select id="categorySelect" class="input w-full" multiple>
				@if (ViewBag.Categories != null)
				{
					foreach (var c in ViewBag.Categories as List<BuyMate.DTO.ViewModels.CategoryViewModel>)
					{
						<option value="@c.Id">@c.Name (@c.ProductCount)</option>
					}
				}
				else
				{
					<option disabled>No categories available</option>
				}
			</select>
			<small class="text-muted-foreground">Selecting categories is optional. Hold Ctrl/Cmd to select multiple if desired.</small>
		</div>

		<div class="mb-6">
			<label class="font-medium">Specifications</label>

			<div id="specificationContainer" class="space-y-3"></div>

			<button type="button" id="addSpecBtn" class="btn btn-outline mt-2">
				Add Specification
			</button>
		</div>


		<!-- Upload Images (improved UI) -->
		<div class="mb-4">
			<label class="font-medium">Images</label>
			<div class="flex items-center gap-3">
				<label for="files" class="btn btn-outline">Select images</label>
				<span id="selectedFiles" class="text-sm text-muted-foreground">No files chosen</span>
			</div>
			<input type="file" name="files" id="files" class="hidden" accept="image/*" multiple />
			<small class="text-muted-foreground block mt-1">You can select multiple images. Max each4MB. Allowed: jpg, jpeg, png, gif, webp.</small>
		</div>

		<!-- Preview Images -->
		<div id="imagePreview" class="grid grid-cols-3 gap-4 mb-6"></div>

		<button type="submit" class="btn btn-primary w-full text-lg">Create Product</button>
	</form>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
	<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

	<script src="~/js/product.js"></script>
}
