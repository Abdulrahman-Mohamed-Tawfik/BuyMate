@model List<BuyMate.DTO.ViewModels.ProductViewModel>
@{
	ViewData["Title"] = "Products";
}

<div class="max-w-6xl mx-auto mt-10">
	<div class="flex items-center justify-between mb-6">
		<h1 class="text-2xl font-bold">Products</h1>
		<a asp-controller="Product" asp-action="Create" class="btn btn-primary">Add New Product</a>
	</div>

	<div class="card p-0 overflow-hidden">
		<table class="table w-full">
			<thead class="bg-muted">
				<tr>
					<th class="px-4 py-3 text-left text-sm font-semibold">Id</th>
					<th class="px-4 py-3 text-left text-sm font-semibold">Image</th>
					<th class="px-4 py-3 text-left text-sm font-semibold">Name</th>
					<th class="px-4 py-3 text-left text-sm font-semibold">Brand</th>
					<th class="px-4 py-3 text-left text-sm font-semibold">Price</th>
					<th class="px-4 py-3 text-left text-sm font-semibold">Discount</th>
					<th class="px-4 py-3 text-left text-sm font-semibold">Featured</th>
					<th class="px-4 py-3 text-left text-sm font-semibold">Flash Deal</th>
					<th class="px-4 py-3 text-left text-sm font-semibold">Rating</th>
					<th class="px-4 py-3 text-left text-sm font-semibold">Action</th>
				</tr>
			</thead>
			<tbody>
				@if (Model != null && Model.Count != 0)
				{
					foreach (var product in Model)
					{
						<tr class="border-t">
							<td class="px-4 py-3 text-sm">@product.Id</td>
							<td class="px-4 py-3">
								@if (!string.IsNullOrWhiteSpace(product.ImageUrl))
								{
									<img src="@(product.ImageUrl.StartsWith("/") ? product.ImageUrl : "/images/" + product.ImageUrl)" alt="@product.Name" class="h-12 w-12 object-cover rounded border" />
								}
								else
								{
									<span class="text-xs text-muted-foreground">No image</span>
								}
							</td>
							<td class="px-4 py-3 text-sm font-medium">@product.Name</td>
							<td class="px-4 py-3 text-sm">@product.Brand</td>
							<td class="px-4 py-3 text-sm">$@product.Price</td>
							<td class="px-4 py-3 text-sm">@(product.Discount.HasValue ? $"{product.Discount}%" : "-")</td>
							<td class="px-4 py-3 text-sm">@(product.IsFeatured ? "Yes" : "No")</td>
							<td class="px-4 py-3 text-sm">@(product.IsFlashDeal ? "Yes" : "No")</td>
							<td class="px-4 py-3 text-sm">@product.Rating.ToString("F1")</td>
							<td class="px-4 py-3 text-sm">
								<div class="flex items-center gap-2">
									<a asp-controller="Product" asp-action="Edit" asp-route-id="@product.Id" class="btn btn-outline btn-sm">Edit</a>
									<form action="@Url.Action("Delete", "Product", new { id = product.Id })" method="post" onsubmit="return confirm('Delete this product?');">
										@Html.AntiForgeryToken()
										<button type="submit" class="btn btn-danger btn-sm">Delete</button>
									</form>
								</div>
							</td>
						</tr>
					}
				}
				else
				{
					<tr>
						<td colspan="10" class="px-4 py-6 text-center text-sm text-muted-foreground">No products found.</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
</div>