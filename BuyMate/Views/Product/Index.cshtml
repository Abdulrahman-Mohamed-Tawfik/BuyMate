@using BuyMate.DTO.ViewModels.Product
@model List<ProductViewModel>
@{
    ViewData["Title"] = "Products";
}

<div class="container mb-5" style="max-width: 72rem;">
    <a asp-controller="Admin" asp-action="Index" class="d-inline-flex align-items-center small text-muted text-decoration-none mb-3">
        <i class="fas fa-arrow-left me-2"></i> Back to Dashboard
    </a>

    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h4 fw-bold mb-0">Products</h1>
        <a asp-controller="Product" asp-action="Create" class="btn btn-primary">Add New Product</a>
    </div>

    <div class="card">
        <div class="table-responsive mb-0">
            <table class="table table-striped align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th scope="col">Image</th>
                        <th scope="col">Name</th>
                        <th scope="col">Brand</th>
                        <th scope="col">Price</th>
                        <th scope="col">Stock Quantity</th>
                        <th scope="col">Discount</th>
                        <th scope="col">Featured</th>
                        <th scope="col">Flash Deal</th>
                        <th scope="col">Rating</th>
                        <th scope="col">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count != 0)
                    {
                        foreach (var product in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(product.ImageUrl))
                                    {
                                        <img src="@(product.ImageUrl.StartsWith("/") ? product.ImageUrl : "/images/" + product.ImageUrl)" alt="@product.Name" class="border rounded" style="width:48px;height:48px;object-fit:contain;" />
                                    }
                                    else
                                    {
                                        <span class="small text-muted">No image</span>
                                    }
                                </td>
                                <td class="small fw-semibold">@product.Name</td>
                                <td class="small">@product.Brand</td>
                                <td class="small">$@product.Price</td>
                                <td class="small">@product.StockQuantity</td>
                                <td class="small">@(product.Discount.HasValue ? $"{product.Discount}%" : "-")</td>
                                <td class="small">@(product.IsFeatured ? "Yes" : "No")</td>
                                <td class="small">@(product.IsFlashDeal ? "Yes" : "No")</td>
                                <td class="small">@product.Rating.ToString("F1")</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <a asp-controller="Product" asp-action="Edit" asp-route-id="@product.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                                        <form action="@Url.Action("Delete", "Product", new { id = product.Id })" method="post" class="swal-delete d-inline" data-confirm="Delete this product?">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="text-center small text-muted py-4">No products found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/product-index.js"></script>
}