@using BuyMate.DTO.ViewModels.Cart
@model MiniCartViewModel

<div class="position-relative cart-container" onmouseenter="showMiniCart()" onmouseleave="hideMiniCart()">
    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary btn-sm position-relative cart-icon" aria-label="Shopping cart">
        <i class="fas fa-shopping-cart"></i>
        <span class="cart-badge badge bg-danger text-white position-absolute" id="cartBadge" style="top:-0.4rem;right:-0.4rem;display:@(Model.TotalItems > 0 ? "inline-flex" : "none")">@Model.TotalItems</span>
    </a>

    <div id="miniCart" class="mini-cart position-absolute end-0 mt-2" style="top:100%;width:20rem;display:none;z-index:1050;">
        <div class="card shadow">
            <div class="card-header py-2 px-3 d-flex justify-content-between align-items-center">
                <h3 class="h6 mb-0">Shopping Cart</h3>
                <span class="badge bg-secondary" id="num-count">@(Model.TotalItems) items</span>
            </div>

            <div id="miniCartContent" class="max-h-64 overflow-y-auto"></div>

            <div id="miniCartFooter" class="card-footer py-2 px-3">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="fw-semibold">Total:</span>
                    <span id="miniCartTotal" class="fw-semibold">$@Model.TotalPrice</span>
                </div>
                <div class="d-flex flex-column gap-2">
                    <a asp-controller="Cart" asp-action="Index" class="btn btn-primary btn-sm w-100">View Cart</a>
                    <a asp-controller="Order" asp-action="Checkout" class="btn btn-outline-secondary btn-sm w-100">Checkout</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/js/Default.js"></script>