<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BUYMATE - @ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="icon" href="~/images/buymate-icon.webp" />
</head>

<body class="bg-light d-flex flex-column min-vh-100">

    <header class="border-bottom py-3 bg-white">
        <div class="container d-flex align-items-center justify-content-center position-relative">
            <a asp-controller="Home" asp-action="Index"
                class="position-absolute start-0 d-flex align-items-center text-decoration-none text-primary small">
                <i class="fas fa-arrow-left me-2"></i>
                Back to Home
            </a>
            <span class="fw-bold text-center">@ViewData["Title"]</span>
        </div>
    </header>

    <main class="flex-grow-1 container py-4">
        @if (TempData["Success"] != null)
        {
        <div id="successAlert" class="alert alert-success position-relative mx-auto" style="max-width: 480px;"
            role="alert">
            <span class="d-block text-center fw-medium">@TempData["Success"]</span>
            <div id="progressBar" class="position-absolute bottom-0 start-0 bg-success" style="height:4px;width:0%">
            </div>
        </div>
        }

        @if (ViewData.ModelState.ErrorCount > 0)
        {
        <div id="errorAlert" class="alert alert-danger position-relative mx-auto" style="max-width: 480px;"
            role="alert">
            <ul class="mb-0 text-center list-unstyled">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                <li>@error.ErrorMessage</li>
                }
            </ul>
            <div id="errorProgressBar" class="position-absolute bottom-0 start-0 bg-danger" style="height:4px;width:0%">
            </div>
        </div>
        }

        @RenderBody()
    </main>

    <footer class="border-top mt-5 py-3 text-center small text-muted bg-white">
        &copy; 2024 BUYMATE. All rights reserved.
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>