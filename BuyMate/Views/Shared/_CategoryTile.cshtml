@using BuyMate.DTO.ViewModels.Category
@model CategoryViewModel
@{
    var imgSrc = string.IsNullOrEmpty(Model.ImageUrl) ? "" :
        (Model.ImageUrl.StartsWith("http", StringComparison.OrdinalIgnoreCase) ? Model.ImageUrl : Url.Content("~/" + Model.ImageUrl.TrimStart('/')));
}

<div class="category-tile card-category h-100 w-100 text-center d-flex flex-column" style="cursor:pointer;" onclick="location.href='@Url.Action("Index", "Shop", new { categoryId = Model.Id })'">
    <div class="category-image-wrapper position-relative mx-auto mt-2 mb-3" style="width: 100%; max-width: 140px; aspect-ratio: 1/1;">
        @if (!string.IsNullOrEmpty(imgSrc))
        {
            <img src="@imgSrc" alt="@Model.Name" class="category-thumb" style="width: 100%; height: 100%; object-fit: cover; border-radius: 1rem;" />
        }
        else
        {
            <div class="rounded-circle bg-dark bg-opacity-10 d-flex align-items-center justify-content-center w-100 h-100">
                <i class="fas fa-tags text-dark fs-3"></i>
            </div>
        }
     
    </div>

    <div class="mt-auto px-2 pb-2">
        <h3 class="h6 fw-bold mb-1 text-truncate" title="@Model.Name">@Model.Name</h3>
        <p class="small text-muted mb-0">@Model.ProductCount 
            @if (Model.ProductCount == 1)
            {
                <span> Product</span>            
            }
            else { <span> Products</span>}
        </p>
    </div>
</div>
