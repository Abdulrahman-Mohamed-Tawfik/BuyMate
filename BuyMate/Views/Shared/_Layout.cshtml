<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BUYMATE</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/images/buymate-icon.webp" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-..." crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
</head>
<body class="bg-background text-foreground d-flex flex-column min-vh-100">
    <header class="border-bottom bg-light">
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
            <div class="container">
                <button class="btn btn-outline-secondary me-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#mainSidePanel" aria-controls="mainSidePanel" aria-label="Open menu">
                    <i class="fas fa-bars"></i>
                </button>

                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index" aria-label="Go to homepage">
                    <img src="~/images/buymate-logo.webp" alt="BUYMATE - Click. Buy. Smile" class="me-2" style="height:40px; width:auto;" />
                </a>

                <form class="d-none d-md-flex flex-grow-1 mx-3" asp-controller="Shop" asp-action="Index" method="get">
                    <div class="input-group">
                        <input name="Search" type="text" class="form-control" placeholder="Search products..." />
                        <button type="submit" class="btn btn-dark">
                            <i class="fas fa-magnifying-glass text-white"></i>
                        </button>
                    </div>
                </form>

                <div class="d-flex align-items-center gap-2">
                    <a asp-controller="Account" asp-action="Wishlist" class="btn btn-outline-secondary position-relative" aria-label="Wishlist">
                        <i class="fas fa-heart"></i>
                        <span class="wishlist-badge badge bg-danger position-absolute top-0 start-100 translate-middle" style="display:none;">0</span>
                    </a>

                    <div class="position-relative me-2">
                        <vc:cart-summary />
                    </div>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="dropdown">
                            <a class="btn btn-outline-secondary dropdown-toggle d-flex align-items-center" href="#" role="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="/images/@(@User.FindFirst("avatar")?.Value ?? "UserProfileImages/Default.webp") "
                                     alt="User Avatar"
                                     class="rounded-circle me-2" style="width:32px;height:32px;object-fit:cover;" />
                                <span class="d-none d-sm-inline">@User.Identity.Name</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                @if (User.IsInRole("admin"))
                                {
                                    <li>
                                        <a class="dropdown-item text-primary" asp-controller="Admin" asp-action="Index">Admin Dashboard</a>
                                    </li>
                                }
                                <li>
                                    <a class="dropdown-item" asp-controller="User" asp-action="Profile">Profile</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Order" asp-action="Index">Orders</a>
                                </li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="User" asp-action="Logout" method="post" class="px-3">
                                        <button type="submit" class="btn btn-link p-0 text-danger">Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="User" asp-action="Login" class="btn btn-outline-dark me-2" aria-label="Login">
                            <i class="fas fa-user me-1"></i>
                            <span>Login</span>
                        </a>
                        <a asp-controller="User" asp-action="Register" class="btn btn-dark" aria-label="Register">
                            <i class="fas fa-user-plus me-1"></i>
                            <span>Register</span>
                        </a>
                    }
                </div>
            </div>
        </nav>

        <div class="offcanvas offcanvas-start" tabindex="-1" id="mainSidePanel" aria-labelledby="mainSidePanelLabel" data-bs-scroll="true">
            <div class="offcanvas-header border-bottom bg-light">
                <div class="d-flex align-items-center gap-2">
                    <img src="~/images/buymate-icon.webp" alt="BUYMATE" style="width:28px;height:28px;object-fit:contain;" />
                    <div class="lh-sm">
                        <div class="fw-semibold" id="mainSidePanelLabel">BUYMATE</div>
                        <div class="small text-muted">Browse</div>
                    </div>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body p-0">
                <div class="p-3">
                    <div class="small text-uppercase text-muted fw-semibold mb-2">Shop</div>
                    <div class="list-group list-group-flush">
                        <a class="list-group-item list-group-item-action d-flex align-items-center gap-2" asp-controller="Shop" asp-action="Index">
                            <i class="fas fa-store text-secondary"></i>
                            <span>Shop</span>
                        </a>
                        <a class="list-group-item list-group-item-action d-flex align-items-center gap-2 text-danger" asp-controller="Shop" asp-action="Deals">
                            <i class="fas fa-bolt"></i>
                            <span>Flash Deals</span>
                        </a>

                        @if (User.IsInRole("admin"))
                        {
                            <div class="border-top my-2"></div>
                            <div class="small text-uppercase text-muted fw-semibold mb-2">Admin</div>
                            <a class="list-group-item list-group-item-action d-flex align-items-center gap-2" asp-controller="Admin" asp-action="Index">
                                <i class="fas fa-gauge text-secondary"></i>
                                <span>Admin Dashboard</span>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white border-top d-md-none">
            <div class="container py-2">
                <form asp-controller="Shop" asp-action="Index" method="get">
                    <div class="input-group">
                        <input type="text" name="Search" class="form-control" placeholder="Search products..." />
                        <button type="submit" class="btn btn-dark" aria-label="Search">
                            <i class="fas fa-magnifying-glass text-white"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </header>

    <main class="flex-grow-1 container my-4">
        @if (TempData["Success"] != null)
        {
            <div id="successAlert" class="alert alert-success position-relative mx-auto" style="max-width: 480px;" role="alert">
                <span class="d-block text-center fw-medium">@TempData["Success"]</span>
                <div id="progressBar" class="position-absolute bottom-0 start-0 bg-success" style="height:4px;width:0%"></div>
            </div>
        }

        @if (TempData["Error"] != null || ViewData.ModelState.ErrorCount > 0)
        {
            <div id="errorAlert" class="alert alert-danger position-relative mx-auto" style="max-width: 480px;" role="alert">
                <ul class="mb-0 text-center list-unstyled">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>

                @if (TempData["Error"] != null)
                {
                    <div class="mt-2 text-center">@TempData["Error"]</div>
                }

                <div id="errorProgressBar" class="position-absolute bottom-0 start-0 bg-danger" style="height:4px;width:0%"></div>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="border-top mt-5 bg-light text-dark">
        <div class="container py-4">
            <div class="row g-4">
                <div class="col-12 col-md-3">
                    <h5 class="fw-semibold mb-3">BUYMATE</h5>
                    <p class="small text-muted mb-0">
                        Your trusted e-commerce platform for quality products at great prices.
                    </p>
                </div>

                <div class="col-6 col-md-3">
                    <h6 class="fw-medium mb-3">Quick Links</h6>
                    <ul class="list-unstyled small mb-0">
                        <li><a asp-controller="Home" asp-action="Index" class="text-muted text-decoration-none">Home</a></li>
                        <li><a asp-controller="Shop" asp-action="Index" class="text-muted text-decoration-none">Shop</a></li>
                        <li><a asp-controller="Shop" asp-action="Deals" class="text-muted text-decoration-none">Deals</a></li>
                        <li><a asp-controller="Home" asp-action="About" class="text-muted text-decoration-none">About</a></li>
                        <li><a asp-controller="Home" asp-action="Terms" class="text-muted text-decoration-none">Terms</a></li>
                    </ul>
                </div>

                <div class="col-6 col-md-3">
                    <h6 class="fw-medium mb-3">Support</h6>
                    <ul class="list-unstyled small mb-0">
                        <li><a asp-controller="Home" asp-action="Support" class="text-muted text-decoration-none">Help Center</a></li>
                        <li><a asp-controller="Home" asp-action="Contact" class="text-muted text-decoration-none">Contact Us</a></li>
                        <li><a asp-controller="Home" asp-action="Cookies" class="text-muted text-decoration-none">Cookies</a></li>
                        <li><a asp-controller="Home" asp-action="FAQ" class="text-muted text-decoration-none">FAQ</a></li>
                    </ul>
                </div>

                <div class="col-12 col-md-3">
                    <h6 class="fw-medium mb-3">Legal</h6>
                    <ul class="list-unstyled small mb-0">
                        <li><a asp-controller="Home" asp-action="Privacy" class="text-muted text-decoration-none">Privacy Policy</a></li>
                        <li><a asp-controller="Home" asp-action="Terms" class="text-muted text-decoration-none">Terms of Service</a></li>
                        <li><a asp-controller="Home" asp-action="Returns" class="text-muted text-decoration-none">Returns</a></li>
                    </ul>
                </div>
            </div>

            <div class="border-top mt-4 pt-3 text-center small text-muted">
                &copy; 2024 BUYMATE. All rights reserved.
            </div>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>