<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BUYMATE</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Main.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/images/buymate-logo.png" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" integrity="sha512-..." crossorigin="anonymous" referrerpolicy="no-referrer" />

   
</head>
<body class="bg-background text-foreground">
    <header class="header">
        <!-- Top bar -->
        <div class="container">
            <div class="header-top">
                <!-- Mobile menu toggle and Logo -->
                <div class="flex items-center space-x-4">
                    <!-- Mobile menu hamburger button -->
                    <button class="mobile-menu lg:hidden" type="button" aria-label="Toggle mobile menu">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                        </svg>
                    </button>

                    <!-- BUYMATE Logo -->
                    <a asp-controller="Home" asp-action="Index" class="flex items-center" aria-label="Go to homepage">
                        <img src="~/images/buymate-logo.png" alt="BUYMATE - Click. Buy. Smile" class="h-8 w-auto" />
                    </a>
                </div>

                <!-- Search Bar -->
                <form class="hidden md:flex flex-1 max-w-2xl mx-8" asp-controller="Product" asp-action="Index" method="get">
                    <div class="relative w-full">
                        <input type="text" name="q" placeholder="Search products..." class="input w-full pr-12" />
                        <button type="submit" class="absolute right-1 top-1 h-8 w-8 p-0 btn btn-primary btn-sm flex items-center justify-center">
                            <i class="fas fa-magnifying-glass text-white text-lg"></i>
                        </button>
                    </div>
                </form>


                <!-- Header Action Buttons -->
                <div class="flex items-center space-x-2">
                    <!-- Mobile search button - only visible on mobile -->
                    <a asp-controller="Product" asp-action="Index" class="md:hidden btn btn-ghost btn-sm" aria-label="Search products">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                    </a>

                    <!-- Wishlist button -->
                    <a asp-controller="Account" asp-action="Wishlist" class="relative btn btn-ghost btn-sm" aria-label="Wishlist">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                        </svg>
                        <span class="wishlist-badge badge badge-destructive badge-sm absolute -top-2 -right-2" style="display: none;">0</span>
                    </a>

                    <!-- Shopping cart with hover mini-cart -->
                    <div class="relative">
                        <vc:cart-summary />
                    </div>

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <!-- Profile link -->
                        <div class="dropdown dropdown-end">
                            <label tabindex="0" class="btn btn-ghost btn-sm flex items-center space-x-2">
                                <img src="/images/@(@User.FindFirst("avatar")?.Value ?? "UserProfileImages/Default.jpg") "
                                     alt="User Avatar"
                                     class="w-8 h-8 rounded-full object-cover"   />
                                <span>@User.Identity.Name</span>
                            </label>
                            <ul tabindex="0" class="dropdown-content menu p-2 shadow bg-base-100 rounded-box w-52">
                                <li>
                                    <a asp-controller="User" asp-action="Profile">Profile</a>
                                </li>
                                <li>
                                    <form asp-controller="User" asp-action="Logout" method="post">
                                        <button type="submit">Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <!-- Login link -->
                        <a asp-controller="User" asp-action="Login" class="flex items-center space-x-1 btn btn-ghost btn-sm" aria-label="Login">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <span>Login</span>
                        </a>

                        <!-- Register link -->
                        <a asp-controller="User" asp-action="Register" class="flex items-center space-x-1 btn btn-ghost btn-sm" aria-label="Register">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                            <span>Register</span>
                        </a>
                    }   
                </div>
            </div>

            <!-- Mobile search bar - only visible on mobile devices -->
            <div class="md:hidden pb-4">
                <form asp-controller="Product" asp-action="Index" method="get">
                    <div class="relative">
                        <input type="text" name="q" placeholder="Search products..." class="input w-full pr-12" />
                        <button type="submit" class="absolute right-1 top-1 h-8 w-8 p-0 btn btn-primary btn-sm" aria-label="Search">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                            </svg>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Main Navigation Menu -->
        <div class="border-t">
            <div class="container">
                <!-- Desktop navigation - hidden on mobile -->
                <nav class="desktop-nav hidden lg:flex items-center space-x-8 h-12">
                    <!-- Shop dropdown with categories -->
                    <a asp-controller="Product" asp-action="Index" class="text-sm hover:text-primary transition-colors flex items-center space-x-1">
                        <span>Shop</span>
                        <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </a>

                    <!-- Flash deals link -->
                    <a asp-controller="Shop" asp-action="Deals" class="text-sm text-destructive hover:text-destructive/80 transition-colors">
                        Flash Deals
                    </a>
                </nav>

                <!-- Mobile navigation - only visible when menu is open -->
                <nav class="mobile-menu lg:hidden py-4 space-y-2" style="display: none;">
                    <!-- All products link -->
                    <a asp-controller="Product" asp-action="Index" class="block w-full text-left py-2 text-sm hover:text-primary transition-colors font-medium">
                        All Products
                    </a>

                    <!-- Flash deals link -->
                    <a asp-controller="Shop" asp-action="Deals" class="block w-full text-left py-2 text-sm text-destructive hover:text-destructive/80 transition-colors">
                        Flash Deals
                    </a>
                </nav>
            </div>
        </div>
    </header>

    <main class="flex-1 container mx-auto px-4 py-8">


        @if (TempData["Success"] != null)
        {
            <div id="successAlert" class="relative bg-green-100 border border-green-400 text-green-700 px-8 py-8 rounded mb-8 w-full max-w-md mx-auto" role="alert">
                <span class="block text-center font-medium">@TempData["Success"]</span>
                <!-- Progress bar -->
                <div id="progressBar" class="absolute bottom-0 left-0 h-2 bg-green-500 rounded-b" style="width:0%"></div>
            </div>
        }

        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div id="errorAlert" class="relative bg-red-100 border border-red-400 text-red-700 px-8 py-4 rounded mb-8 w-full max-w-md mx-auto" role="alert">
                <ul class=" text-center list-disc pl-5">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
                <!-- Optional progress bar -->
                <div id="errorProgressBar" class="absolute bottom-0 left-0 h-2 bg-red-500 rounded-b" style="width:0%"></div>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="border-t mt-12 bg-background text-foreground">
        <div class="container py-8 flex flex-col md:flex-row md:justify-between md:items-start gap-8">

            <div class="flex-1">
                <h3 class="font-semibold mb-4">BUYMATE</h3>
                <p class="text-sm text-muted-foreground">
                    Your trusted e-commerce platform for quality products at great prices.
                </p>
            </div>

            <div class="flex-1">
                <h4 class="font-medium mb-4">Quick Links</h4>
                <ul class="space-y-2 text-sm">
                    <li><a asp-controller="Home" asp-action="Index" class="text-muted-foreground hover:text-primary">Home</a></li>
                    <li><a asp-controller="Product" asp-action="Index" class="text-muted-foreground hover:text-primary">Shop</a></li>
                    <li><a asp-controller="Shop" asp-action="Deals" class="text-muted-foreground hover:text-primary">Deals</a></li>
                    <li><a asp-controller="Home" asp-action="About" class="text-muted-foreground hover:text-primary">About</a></li>
                    <li><a asp-controller="Home" asp-action="Terms" class="text-muted-foreground hover:text-primary">Terms</a></li>
                </ul>
            </div>

            <div class="flex-1">
                <h4 class="font-medium mb-4">Support</h4>
                <ul class="space-y-2 text-sm">
                    <li><a asp-controller="Home" asp-action="Support" class="text-muted-foreground hover:text-primary">Help Center</a></li>
                    <li><a asp-controller="Home" asp-action="Contact" class="text-muted-foreground hover:text-primary">Contact Us</a></li>
                    <li><a asp-controller="Home" asp-action="Cookies" class="text-muted-foreground hover:text-primary">Cookies</a></li>
                    <li><a asp-controller="Home" asp-action="FAQ" class="text-muted-foreground hover:text-primary">FAQ</a></li>
                </ul>
            </div>

            <div class="flex-1">
                <h4 class="font-medium mb-4">Legal</h4>
                <ul class="space-y-2 text-sm">
                    <li><a asp-controller="Home" asp-action="Privacy" class="text-muted-foreground hover:text-primary">Privacy Policy</a></li>
                    <li><a asp-controller="Home" asp-action="Terms" class="text-muted-foreground hover:text-primary">Terms of Service</a></li>
                    <li><a asp-controller="Home" asp-action="Returns" class="text-muted-foreground hover:text-primary">Returns</a></li>
                </ul>
            </div>
        </div>

        <div class="border-t mt-8 pt-8 text-center text-sm text-muted-foreground">
            &copy; 2024 BUYMATE. All rights reserved.
        </div>
    </footer>


    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>