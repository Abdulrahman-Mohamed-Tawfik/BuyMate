@using BuyMate.DTO.ViewModels.Product
@model ProductViewModel
@{
    var imageClass = ViewData["ImageClass"]?.ToString() ?? "product-card-image";
}

<div class="card h-100 product-card" style="cursor:pointer;" onclick="location.href='@Url.Action("Product", "Shop", new { id = Model.Id })'">
    <div class="position-relative">
        <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/placeholder.png" : (Model.ImageUrl.StartsWith("/") ? Model.ImageUrl : "/images/" + Model.ImageUrl))" alt="@Model.Name" class="@imageClass" />
        
        @if (Model.IsFlashDeal)
        {
            <span class="badge bg-danger position-absolute top-0 start-0 m-2">Flash Deal</span>
        }
        @if (Model.Discount.HasValue && Model.Discount > 0)
        {
            <span class="badge bg-secondary position-absolute top-0 end-0 m-2">-@Model.Discount%</span>
        }

        <!-- Example Wishlist Button (You only need to add this here!) -->
        @* <button class="wishlist-button" onclick="event.stopPropagation(); toggleWishlist('@Model.Id')"><i class="far fa-heart"></i></button> *@
    </div>
    
    <div class="card-body d-flex flex-column">
        <div class="mb-2">
            <h3 class="h6 fw-semibold mb-1 text-truncate" title="@Model.Name">@Model.Name</h3>
            <p class="small text-muted mb-2">@Model.Brand</p>
            <div class="d-flex align-items-center mb-2">
                <div class="me-2">
                    @{
                        var roundedRating = (int)Math.Round(Model.Rating);
                    }
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="fa-star @(i <= roundedRating ? "fas text-warning" : "far text-muted") small"></i>
                    }
                </div>
                <span class="small text-muted">@Model.Rating.ToString("F1") (@Model.ReviewCount)</span>
            </div>
        </div>

        <div class="mt-auto">
            <div class="d-flex align-items-baseline mb-2">
                <span class="fw-bold mb-0" style="font-size: 1.1rem;">@Model.Price.ToString("C")</span>
                @if (Model.OriginalPrice.HasValue)
                {
                    <span class="small text-muted text-decoration-line-through ms-2">@Model.OriginalPrice.Value.ToString("C")</span>
                }
            </div>
            <button class="btn btn-dark w-100 btn-sm" onclick="event.stopPropagation(); addToCart('@Model.Id')">Add to Cart</button>
        </div>
    </div>
</div>
