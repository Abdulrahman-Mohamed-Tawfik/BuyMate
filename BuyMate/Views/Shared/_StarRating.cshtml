@model (double Rating, int ReviewCount)

<div class="d-flex align-items-center mb-2">
    <div class="me-2">
        @{
            var roundedRating = (int)Math.Round(Model.Rating);
        }
        @for (int i = 1; i <= 5; i++)
        {
            <i class="fa-star @(i <= roundedRating ? "fas text-warning" : "far text-muted") small"></i>
        }
    </div>
    <span class="small text-muted">@Model.Rating.ToString("F1") (@Model.ReviewCount)</span>
</div>
