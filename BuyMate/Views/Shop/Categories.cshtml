@using BuyMate.DTO.ViewModels.Category
@model IEnumerable<CategoryViewModel>
@{
    ViewData["Title"] = "All Categories";
    var search = Context.Request.Query["q"].ToString();
}

<div class="container mb-5" style="max-width: 72rem;">
    <h1 class="h4 fw-bold mb-3">All Categories</h1>

    <div class="d-flex flex-column flex-sm-row align-items-sm-center justify-content-sm-between gap-2 mb-3">
        <form method="get" asp-action="Categories" class="d-flex w-100 w-sm-auto gap-2">
            <input name="q"
                   value="@search"
                   placeholder="Search categories..."
                   class="form-control" />
            <button type="submit" class="btn btn-dark">Search</button>
            @if (!string.IsNullOrWhiteSpace(search))
            {
                <a asp-action="Categories" class="btn btn-outline-secondary">Clear</a>
            }
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="card p-4 text-center text-muted mb-3">
            <p class="small mb-0">No categories found.</p>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var category in Model)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card h-100" style="cursor:pointer;" onclick="location.href='@Url.Action("Index", "Shop", new { categoryId = category.Id })'">
                        <div class="bg-light d-flex align-items-center justify-content-center" style="aspect-ratio:1/1;overflow:hidden;">
                            @if (!string.IsNullOrWhiteSpace(category.ImageUrl))
                            {
                                <img src="/@category.ImageUrl"
                                     alt="@category.Name"
                                     class="img-fluid" style="max-height:100%;object-fit:contain;" />
                            }
                            else
                            {
                                <div class="text-muted small">No Image</div>
                            }
                        </div>
                        <div class="card-body py-2">
                            <h2 class="card-title h6 mb-1 text-truncate">@category.Name</h2>
                            <p class="card-text small text-muted mb-0">@category.ProductCount products</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
