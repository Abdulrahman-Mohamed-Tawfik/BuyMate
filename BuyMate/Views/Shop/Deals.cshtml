@using BuyMate.DTO.ViewModels
@using BuyMate.DTO.ViewModels.Product
@model List<ProductViewModel>
@{
    ViewData["Title"] = "Flash Deals";
}

<div class="container mb-5" style="max-width: 72rem;">
    <div class="text-center mb-3">
        <h1 class="h4 fw-bold mb-1">Flash Deals</h1>
        <p class="text-muted mb-0">Limited time offers - Don't miss out!</p>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row g-3 small">
            @foreach (var product in Model)
            {
                <div class="col-12 col-sm-6 col-lg-4 col-xl-3">
                    <div class="card h-100" style="cursor:pointer;" onclick="location.href='@Url.Action("Product", "Product", new { id = product?.Id })'">
                        <div class="position-relative">
                            <img src="@($"/images/{product?.ImageUrl}" ?? "/images/placeholder.png")" alt="@(product?.Name ?? "Product")" class="card-img-top p-2" style="height:12rem;object-fit:contain;" />
                            <span class="badge bg-danger position-absolute" style="top:0.5rem;left:0.5rem;">Flash Deal</span>
                            @if (product?.Discount.HasValue == true)
                            {
                                <span class="badge bg-secondary position-absolute" style="top:0.5rem;right:0.5rem;">-@product!.Discount%</span>
                            }
                        </div>
                        <div class="card-body p-2 d-flex flex-column">
                            <h3 class="fw-semibold mb-1" style="font-size:0.95rem;">@(product?.Name ?? "")</h3>
                            <p class="text-muted mb-1">@(product?.Brand ?? "")</p>
                            <div class="d-flex align-items-center mb-1">
                                <div class="text-warning me-1">
                                    @{
                                        var rating = product?.Rating ?? 0;
                                    }
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fas fa-star @(i <= rating ? string.Empty : "text-secondary")" style="font-size:0.75rem;"></i>
                                    }
                                </div>
                                <span class="text-muted">(@(product?.ReviewCount ?? 0))</span>
                            </div>
                            <div class="d-flex align-items-center justify-content-between mt-auto">
                                <div>
                                    <span class="fw-bold text-primary">$@(product?.Price ?? 0)</span>
                                    @if (product?.OriginalPrice.HasValue == true)
                                    {
                                        <span class="text-muted text-decoration-line-through ms-1">$@product!.OriginalPrice</span>
                                    }
                                </div>
                                <button class="btn btn-primary btn-sm" onclick="event.stopPropagation(); addToCart('@(product?.Id ?? Guid.Empty)')">
                                    Add to Cart
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h3 class="h6 fw-bold mb-1">No flash deals available</h3>
            <p class="text-muted mb-0">Check back later for amazing deals!</p>
        </div>
    }
</div>

<script src="~/js/shop-deals.js"></script>
