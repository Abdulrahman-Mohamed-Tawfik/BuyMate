@using BuyMate.DTO.ViewModels.Shop
@model ShopViewModel
@{
    ViewData["Title"] = "Shop";
    var SelectedCategoryId = Model.SelectedCategoryId;
}

<div class="container mb-5">
    <div class="text-center mb-4">
        <h1 class="h3 fw-bold mb-2">Shop All Products</h1>
        <p class="text-muted mb-0">Discover our wide range of quality products</p>
    </div>

    <div class="row g-4">
        <aside class="col-12 col-lg-3">
            <div class="d-flex justify-content-between align-items-center mb-3 d-lg-none">
                <button id="filterToggle" class="btn btn-outline-secondary btn-sm">Filters</button>
            </div>

            <div id="filterSidebar" class="card p-3" style="max-height:60vh;overflow:auto;">
                <h3 class="h6 fw-semibold mb-3">Filters</h3>

                <form method="get" asp-controller="Shop" asp-action="Index" class="mb-3">
                    @if (Model.SelectedCategoryId.HasValue)
                    {
                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                    }
                    <div class="mb-3">
                        <label class="form-label small">Search</label>
                        <input type="text" name="search" value="@Model.Search" class="form-control form-control-sm" placeholder="Search products..." />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small">Brand</label>
                        <select name="brand" class="form-select form-select-sm">
                            @if (string.IsNullOrEmpty(Model.SelectedBrand))
                            {
                                <option value="" selected>All brands</option>
                            }
                            else
                            {
                                <option value="">All brands</option>
                            }

                            @foreach (var b in Model.Brands)
                            {
                                var isSelected = string.Equals(Model.SelectedBrand, b, StringComparison.OrdinalIgnoreCase);
                                if (isSelected)
                                {
                                    <option value="@b" selected>@b</option>
                                }
                                else
                                {
                                    <option value="@b">@b</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small">Price range</label>
                        <div class="row g-2">
                            <div class="col-6">
                                <input type="number" name="minPrice" step="0.01" placeholder="Min" value="@(Model.SelectedMinPrice?.ToString() ?? "")" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <input type="number" name="maxPrice" step="0.01" placeholder="Max" value="@(Model.SelectedMaxPrice?.ToString() ?? "")" class="form-control form-control-sm" />
                            </div>
                        </div>
                        @if (Model.MinPrice.HasValue || Model.MaxPrice.HasValue)
                        {
                            <p class="small text-muted mt-1">Price range: $@Model.MinPrice - $@Model.MaxPrice</p>
                        }
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-check-sm">
                            <input type="checkbox" name="hasDiscount" value="true" @(Model.HasDiscount == true ? "checked" : "") class="form-check-input" id="hasDiscountChk" />
                            <label class="form-check-label small" for="hasDiscountChk">Has discount</label>
                        </div>
                        <div class="form-check form-check-sm">
                            <input type="checkbox" name="isFeatured" value="true" @(Model.IsFeatured == true ? "checked" : "") class="form-check-input" id="isFeaturedChk" />
                            <label class="form-check-label small" for="isFeaturedChk">Featured</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small">Sort by</label>
                        <div class="row g-2">
                            <div class="col-8">
                                <select name="orderBy" class="form-select form-select-sm">
                                    @if (Model.OrderBy == "price")
                                    {
                                        <option value="price" selected>Price</option>
                                    }
                                    else
                                    {
                                        <option value="price">Price</option>
                                    }

                                    @if (Model.OrderBy == "name")
                                    {
                                        <option value="name" selected>Name</option>
                                    }
                                    else
                                    {
                                        <option value="name">Name</option>
                                    }

                                    @if (Model.OrderBy == "rating")
                                    {
                                        <option value="rating" selected>Rating</option>
                                    }
                                    else
                                    {
                                        <option value="rating">Rating</option>
                                    }

                                    @if (string.IsNullOrEmpty(Model.OrderBy))
                                    {
                                        <option value="" selected>Default</option>
                                    }
                                    else
                                    {
                                        <option value="">Default</option>
                                    }
                                </select>
                            </div>
                            <div class="col-4">
                                <select name="asc" class="form-select form-select-sm">
                                    @if (Model.Asc)
                                    {
                                        <option value="true" selected>Asc</option>
                                        <option value="false">Desc</option>
                                    }
                                    else
                                    {
                                        <option value="true">Asc</option>
                                        <option value="false" selected>Desc</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-dark btn-sm">Apply</button>
                        <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear</a>
                    </div>
                </form>

                <hr />

                <h3 class="h6 fw-semibold mb-2">Categories</h3>
                <div class="d-flex flex-column gap-1">
                    @if (Model.SelectedCategoryId == null)
                    {
                        <a asp-controller="Shop" asp-action="Index" class="small text-dark text-decoration-none"
                           asp-route-search="@Model.Search"
                           asp-route-brand="@Model.SelectedBrand"
                           asp-route-minPrice="@Model.SelectedMinPrice"
                           asp-route-maxPrice="@Model.SelectedMaxPrice"
                           asp-route-hasDiscount="@(Model.HasDiscount.HasValue? Model.HasDiscount.ToString() : null)"
                           asp-route-isFeatured="@(Model.IsFeatured.HasValue? Model.IsFeatured.ToString() : null)"
                           asp-route-orderBy="@Model.OrderBy"
                           asp-route-asc="@Model.Asc"
                           asp-route-pageNumber="1">All Products</a>
                    }
                    else
                    {
                        <a asp-controller="Shop" asp-action="Index" class="small text-muted text-decoration-none"
                           asp-route-search="@Model.Search"
                           asp-route-brand="@Model.SelectedBrand"
                           asp-route-minPrice="@Model.SelectedMinPrice"
                           asp-route-maxPrice="@Model.SelectedMaxPrice"
                           asp-route-hasDiscount="@(Model.HasDiscount.HasValue? Model.HasDiscount.ToString() : null)"
                           asp-route-isFeatured="@(Model.IsFeatured.HasValue? Model.IsFeatured.ToString() : null)"
                           asp-route-orderBy="@Model.OrderBy"
                           asp-route-asc="@Model.Asc"
                           asp-route-pageNumber="1">All Products</a>
                    }

                    @foreach (var category in Model.Categories)
                    {
                        if (Model.SelectedCategoryId == category.Id)
                        {
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="@category.Id" class="small text-dark fw-semibold text-decoration-none"
                               asp-route-search="@Model.Search"
                               asp-route-brand="@Model.SelectedBrand"
                               asp-route-minPrice="@Model.SelectedMinPrice"
                               asp-route-maxPrice="@Model.SelectedMaxPrice"
                               asp-route-hasDiscount="@(Model.HasDiscount.HasValue ? Model.HasDiscount.ToString() : null)"
                               asp-route-isFeatured="@(Model.IsFeatured.HasValue ? Model.IsFeatured.ToString() : null)"
                               asp-route-orderBy="@Model.OrderBy"
                               asp-route-asc="@Model.Asc"
                               asp-route-pageNumber="1">@category.Name (@category.ProductCount)</a>
                        }
                        else
                        {
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="@category.Id" class="small text-muted text-decoration-none"
                               asp-route-search="@Model.Search"
                               asp-route-brand="@Model.SelectedBrand"
                               asp-route-minPrice="@Model.SelectedMinPrice"
                               asp-route-maxPrice="@Model.SelectedMaxPrice"
                               asp-route-hasDiscount="@(Model.HasDiscount.HasValue ? Model.HasDiscount.ToString() : null)"
                               asp-route-isFeatured="@(Model.IsFeatured.HasValue ? Model.IsFeatured.ToString() : null)"
                               asp-route-orderBy="@Model.OrderBy"
                               asp-route-asc="@Model.Asc"
                               asp-route-pageNumber="1">@category.Name (@category.ProductCount)</a>
                        }
                    }
                </div>
            </div>
        </aside>

        <section class="col-12 col-lg-9">
            @if (Model.Products.Any())
            {
                <div class="row g-4">
                    @foreach (var product in Model.Products)
                    {
                        <div class="col-12 col-sm-6 col-lg-6">
                            <partial name="_ProductCard" model="product" view-data='new ViewDataDictionary(ViewData) { { "ImageClass", "product-card-image product-card-image--shop" } }' />
                        </div>
                    }
                </div>

                <div class="mt-4 d-flex justify-content-center">
                    @{
                        var totalPages = (int)Math.Ceiling((double)Model.TotalCount / (Model.PageSize > 0 ? Model.PageSize : 1));
                        var prev = Model.PageNumber - 1;
                        var next = Model.PageNumber + 1;
                    }
                    <div class="btn-group" role="group">
                        <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-secondary btn-sm"
                           asp-route-search="@Model.Search" asp-route-brand="@Model.SelectedBrand" asp-route-minPrice="@Model.SelectedMinPrice" asp-route-maxPrice="@Model.SelectedMaxPrice" asp-route-hasDiscount="@(Model.HasDiscount.HasValue? Model.HasDiscount.ToString() : null)" asp-route-isFeatured="@(Model.IsFeatured.HasValue? Model.IsFeatured.ToString() : null)" asp-route-orderBy="@Model.OrderBy" asp-route-asc="@Model.Asc" asp-route-pageNumber="@Math.Max(1, prev)" asp-route-categoryId="@Model.SelectedCategoryId">Prev</a>
                        <span class="btn btn-outline-secondary btn-sm disabled">Page @Model.PageNumber of @totalPages</span>
                        <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-secondary btn-sm"
                           asp-route-search="@Model.Search" asp-route-brand="@Model.SelectedBrand" asp-route-minPrice="@Model.SelectedMinPrice" asp-route-maxPrice="@Model.SelectedMaxPrice" asp-route-hasDiscount="@(Model.HasDiscount.HasValue? Model.HasDiscount.ToString() : null)" asp-route-isFeatured="@(Model.IsFeatured.HasValue? Model.IsFeatured.ToString() : null)" asp-route-orderBy="@Model.OrderBy" asp-route-asc="@Model.Asc" asp-route-pageNumber="@(next <= totalPages ? next : totalPages)" asp-route-categoryId="@Model.SelectedCategoryId">Next</a>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <h3 class="h5 fw-semibold mb-2">No products found</h3>
                    <p class="text-muted mb-3">Try adjusting your filters or browse all products.</p>
                </div>
            }
        </section>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/js/cart.js"></script>
<script src="~/js/shop-index.js"></script>