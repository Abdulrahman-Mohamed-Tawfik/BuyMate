@model BuyMate.DTO.ViewModels.ShopViewModel
@{
    ViewData["Title"] = "Shop";
}

<div class="space-y-8">
    <!-- Page Header -->
    <div class="text-center">
        <h1 class="text-3xl font-bold mb-4">Shop All Products</h1>
        <p class="text-muted-foreground">Discover our wide range of quality products</p>
    </div>

    <!-- زر إضافة منتج جديد -->
    <div class="flex justify-end mb-4">
        <a href="@Url.Action("Create","Shop")" class="btn btn-primary">
            + Add New Product
        </a>
    </div>

    <!-- Filters and Categories -->
    <div class="flex flex-col lg:flex-row gap-8">
        <!-- Sidebar Filters -->
        <div class="lg:w-64">
            <div class="card p-6">
                <h3 class="font-semibold mb-4">Categories</h3>
                <div class="space-y-2">

                    <a asp-controller="Shop"
                       asp-action="Index"
                       class="block text-sm hover:text-primary transition-colors @(Model.SelectedCategoryId == null ? "text-primary font-medium" : "text-muted-foreground")">
                        All Products
                    </a>

                    @foreach (var category in Model.Categories)
                    {
                        <a asp-controller="Shop"
                           asp-action="Index"
                           asp-route-categoryId="@category.Id"
                           class="block text-sm hover:text-primary transition-colors @(Model.SelectedCategoryId == category.Id ? "text-primary font-medium" : "text-muted-foreground")">
                            @category.Name (@category.ProductCount)
                        </a>
                    }
                </div>
            </div>
        </div>

        <!-- Products Grid -->
        <div class="flex-1">
            @if (Model.Products.Any())
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                    @foreach (var product in Model.Products)
                    {
                        <div class="card product-card"
                             onclick="location.href='@Url.Action("Product", "Shop", new { id = product.Id })'">

                            <div class="relative">
                                <img src="@(product.ImageUrl ?? "/images/placeholder.png")"
                                     alt="@product.Name"
                                     class="w-full h-48 object-cover rounded-t-lg" />

                                @if (product.IsFlashDeal)
                                {
                                    <span class="absolute top-2 left-2 badge badge-destructive">Flash Deal</span>
                                }

                                @if (product.Discount.HasValue)
                                {
                                    <span class="absolute top-2 right-2 badge badge-secondary">
                                        -@product.Discount%
                                    </span>
                                }
                            </div>

                            <div class="card-content p-4">
                                <h3 class="font-medium mb-2 line-clamp-2">@product.Name</h3>
                                <p class="text-sm text-muted-foreground mb-2">@product.Brand</p>

                                <!-- Rating -->
                                <div class="flex items-center mb-2">
                                    <div class="flex items-center">
                                        @{
                                            var roundedRating = (int)Math.Round(product.Rating);
                                        }
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <svg class="w-4 h-4 @(i <= roundedRating ? "text-yellow-400" : "text-gray-300")"
                                                 fill="currentColor" viewBox="0 0 20 20">
                                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.988 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                            </svg>
                                        }
                                    </div>
                                    <span class="text-sm text-muted-foreground ml-2">
                                        @product.Rating.ToString("F1") (@product.ReviewCount)
                                    </span>
                                </div>

                                <!-- Price + Add to cart -->
                                <div class="flex items-center justify-between">
                                    <div>
                                        <span class="text-lg font-bold">$@product.Price</span>
                                        @if (product.OriginalPrice.HasValue)
                                        {
                                            <span class="text-sm text-muted-foreground line-through ml-2">
                                                $@product.OriginalPrice
                                            </span>
                                        }
                                    </div>
                                    <button class="btn btn-primary btn-sm"
                                            onclick="event.stopPropagation(); addToCart('@product.Id')">
                                        Add to Cart
                                    </button>
                                </div>

                                <!-- Admin actions -->
                                <div class="flex justify-end gap-2 mt-3">
                                    <a href="@Url.Action("Edit", "Shop", new { id = product.Id })"
                                       class="btn btn-secondary btn-xs"
                                       onclick="event.stopPropagation();">
                                        Edit
                                    </a>

                                    <form asp-controller="Shop"
                                          asp-action="Delete"
                                          method="post"
                                          class="inline delete-form"
                                          onclick="event.stopPropagation();">

                                        <input type="hidden" name="id" value="@product.Id" />

                                        <button type="submit" class="btn btn-danger btn-xs">
                                            Delete
                                        </button>

                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-12">
                    <h3 class="text-lg font-medium mb-2">No products found</h3>
                    <p class="text-muted-foreground">Try adjusting your filters or browse all products.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- SweetAlert JS -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    // Add To Cart 
    function addToCart(productId) {
        fetch('/Cart/AddToCart', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `productId=${productId}&quantity=1`
        })
        .then(response => {
            if (response.ok) {
                alert('Product added to cart!');
            }
        });
    }

    // SweetAlert Delete Confirm
    document.querySelectorAll(".delete-form").forEach(form => {
        form.addEventListener("submit", function (e) {
            e.preventDefault();

            Swal.fire({
                title: "Are you sure?",
                text: "Do you want to delete this product?!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Yes, delete it",
                cancelButtonText: "Cancel"
            }).then(result => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        });
    });
</script>
