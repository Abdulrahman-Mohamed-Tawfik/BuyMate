@model BuyMate.DTO.ViewModels.ShopViewModel
@{
    ViewData["Title"] = "Shop";

    var SelectedCategoryId = Model.SelectedCategoryId;
}
<!-- Adjusted links to Product controller -->
<div class="space-y-8">
    <div class="text-center">
        <h1 class="text-3xl font-bold mb-4">Shop All Products</h1>
        <p class="text-muted-foreground">Discover our wide range of quality products</p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
        <!-- Sidebar: collapsed on small screens, narrower on large screens -->
        <div id="filterSidebar" class="lg:w-48 hidden lg:block">
            <div class="card p-4 space-y-4 max-h-[60vh] overflow-auto">
                <h3 class="font-semibold mb-2">Filters</h3>

                <form method="get" asp-controller="Shop" asp-action="Index" class="space-y-3">
                    @* Preserve selected category when applying filters *@
                    @if (Model.SelectedCategoryId.HasValue)
                    {
                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                    }
                    <div>
                        <label class="block text-sm">Search</label>
                        <input type="text" name="search" value="@Model.Search" class="input input-bordered w-full" placeholder="Search products..." />
                    </div>

                    <div>
                        <label class="block text-sm">Brand</label>
                        <select name="brand" class="select select-bordered w-full">
                            @if (string.IsNullOrEmpty(Model.SelectedBrand))
                            {
                                <option value="" selected>All brands</option>
                            }
                            else
                            {
                                <option value="">All brands</option>
                            }

                            @foreach (var b in Model.Brands)
                            {
                                var isSelected = string.Equals(Model.SelectedBrand, b, StringComparison.OrdinalIgnoreCase);
                                if (isSelected)
                                {
                                    <option value="@b" selected>@b</option>
                                }
                                else
                                {
                                    <option value="@b">@b</option>
                                }
                            }
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm">Price range</label>
                        <div class="flex gap-2">
                            <input type="number" name="minPrice" step="0.01" placeholder="Min" value="@(Model.SelectedMinPrice?.ToString() ?? "")" class="input input-bordered w-1/2" />
                            <input type="number" name="maxPrice" step="0.01" placeholder="Max" value="@(Model.SelectedMaxPrice?.ToString() ?? "")" class="input input-bordered w-1/2" />
                        </div>
                        @if (Model.MinPrice.HasValue || Model.MaxPrice.HasValue)
                        {
                            <p class="text-xs text-muted-foreground mt-1">Price range: $@Model.MinPrice - $@Model.MaxPrice</p>
                        }
                    </div>

                    <div class="flex items-center gap-4">
                        <label class="inline-flex items-center">
                            <input type="checkbox" name="hasDiscount" value="true" @(Model.HasDiscount == true ? "checked" : "") class="checkbox" />
                            <span class="ml-2 text-sm">Has discount</span>
                        </label>
                        <label class="inline-flex items-center">
                            <input type="checkbox" name="isFeatured" value="true" @(Model.IsFeatured == true ? "checked" : "") class="checkbox" />
                            <span class="ml-2 text-sm">Featured</span>
                        </label>
                    </div>

                    <div>
                        <label class="block text-sm">Sort by</label>
                        <div class="flex gap-2">
                            <select name="orderBy" class="select select-bordered w-3/4">
                                @if (Model.OrderBy == "price")
                                {
                                    <option value="price" selected>Price</option>
                                }
                                else
                                {
                                    <option value="price">Price</option>
                                }

                                @if (Model.OrderBy == "name")
                                {
                                    <option value="name" selected>Name</option>
                                }
                                else
                                {
                                    <option value="name">Name</option>
                                }

                                @if (Model.OrderBy == "rating")
                                {
                                    <option value="rating" selected>Rating</option>
                                }
                                else
                                {
                                    <option value="rating">Rating</option>
                                }

                                @* Default option placed first *@
                                @if (string.IsNullOrEmpty(Model.OrderBy))
                                {
                                    <option value="" selected>Default</option>
                                }
                                else
                                {
                                    <option value="">Default</option>
                                }
                            </select>
                            <select name="asc" class="select select-bordered w-1/4">
                                @if (Model.Asc)
                                {
                                    <option value="true" selected>Asc</option>
                                    <option value="false">Desc</option>
                                }
                                else
                                {
                                    <option value="true">Asc</option>
                                    <option value="false" selected>Desc</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm">Apply</button>
                        <a asp-controller="Shop" asp-action="Index" class="btn btn-sm">Clear</a>
                    </div>
                </form>

                <hr />

                <h3 class="font-semibold">Categories</h3>
                <div class="space-y-2">
                    @if (Model.SelectedCategoryId == null)
                    {
                        <a asp-controller="Shop" asp-action="Index" class="block text-sm hover:text-primary transition-colors text-primary font-medium"
                           asp-route-search="@Model.Search"
                           asp-route-brand="@Model.SelectedBrand"
                           asp-route-minPrice="@Model.SelectedMinPrice"
                           asp-route-maxPrice="@Model.SelectedMaxPrice"
                           asp-route-hasDiscount="@(Model.HasDiscount.HasValue? Model.HasDiscount.ToString() : null)"
                           asp-route-isFeatured="@(Model.IsFeatured.HasValue? Model.IsFeatured.ToString() : null)"
                           asp-route-orderBy="@Model.OrderBy"
                           asp-route-asc="@Model.Asc"
                           asp-route-pageNumber="1">All Products</a>
                    }
                    else
                    {
                        <a asp-controller="Shop" asp-action="Index" class="block text-sm hover:text-primary transition-colors text-muted-foreground"
                           asp-route-search="@Model.Search"
                           asp-route-brand="@Model.SelectedBrand"
                           asp-route-minPrice="@Model.SelectedMinPrice"
                           asp-route-maxPrice="@Model.SelectedMaxPrice"
                           asp-route-hasDiscount="@(Model.HasDiscount.HasValue? Model.HasDiscount.ToString() : null)"
                           asp-route-isFeatured="@(Model.IsFeatured.HasValue? Model.IsFeatured.ToString() : null)"
                           asp-route-orderBy="@Model.OrderBy"
                           asp-route-asc="@Model.Asc"
                           asp-route-pageNumber="1">All Products</a>
                    }

                    @foreach (var category in Model.Categories)
                    {
                        if (Model.SelectedCategoryId == category.Id)
                        {
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="@category.Id" class="block text-sm hover:text-primary transition-colors text-primary font-medium"
                               asp-route-search="@Model.Search"
                               asp-route-brand="@Model.SelectedBrand"
                               asp-route-minPrice="@Model.SelectedMinPrice"
                               asp-route-maxPrice="@Model.SelectedMaxPrice"
                               asp-route-hasDiscount="@(Model.HasDiscount.HasValue ? Model.HasDiscount.ToString() : null)"
                               asp-route-isFeatured="@(Model.IsFeatured.HasValue ? Model.IsFeatured.ToString() : null)"
                               asp-route-orderBy="@Model.OrderBy"
                               asp-route-asc="@Model.Asc"
                               asp-route-pageNumber="1">@category.Name (@category.ProductCount)</a>
                        }
                        else
                        {
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="@category.Id" class="block text-sm hover:text-primary transition-colors text-muted-foreground"
                               asp-route-search="@Model.Search"
                               asp-route-brand="@Model.SelectedBrand"
                               asp-route-minPrice="@Model.SelectedMinPrice"
                               asp-route-maxPrice="@Model.SelectedMaxPrice"
                               asp-route-hasDiscount="@(Model.HasDiscount.HasValue ? Model.HasDiscount.ToString() : null)"
                               asp-route-isFeatured="@(Model.IsFeatured.HasValue ? Model.IsFeatured.ToString() : null)"
                               asp-route-orderBy="@Model.OrderBy"
                               asp-route-asc="@Model.Asc"
                               asp-route-pageNumber="1">@category.Name (@category.ProductCount)</a>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="flex-1">
            <!-- Mobile filter toggle -->
            <div class="flex items-center justify-between mb-4 lg:hidden">
                <button id="filterToggle" class="btn">Filters</button>
            </div>

            @if (Model.Products.Any())
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-2 xl:grid-cols-2 gap-8">
                    @foreach (var product in Model.Products)
                    {
                        <div class="card product-card flex flex-col h-full" onclick="location.href='@Url.Action("Product", "Shop", new { id = product.Id })'">
                            <div class="relative">
                                <img src="@(String.IsNullOrEmpty(product.ImageUrl) ? "/images/placeholder.png" : "/images/" + product.ImageUrl)" alt="@product.Name" class="w-full h-72 object-cover rounded-t-lg" />
                                @if (product.IsFlashDeal)
                                {
                                    <span class="absolute top-2 left-2 badge badge-destructive">Flash Deal</span>
                                }
                                @if (product.Discount.HasValue && product.Discount != 0)
                                {
                                    <span class="absolute top-2 right-2 badge badge-secondary">-@product.Discount%</span>
                                }
                            </div>
                            <div class="card-content p-8 flex flex-col justify-between flex-1">
                                <div>
                                    <h3 class="font-medium mb-2 line-clamp-2">@product.Name</h3>
                                    <p class="text-sm text-muted-foreground mb-2">@product.Brand</p>
                                    <div class="flex items-center mb-2">
                                        <div class="flex items-center">
                                            @{
                                                var roundedRating = (int)Math.Round(product.Rating);
                                            }
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <svg class="w-4 h-4 @(i <= roundedRating ? "text-yellow-400" : "text-gray-300")" fill="currentColor" viewBox="002020"><path d="M9.0492.927c.3-.9211.603-.9211.9020l1.073.292a11000.95.69h3.462c.96901.3711.24.5881.81l-2.82.034a11000-.3641.118l1.073.292c.3.921-.7551.688-1.541.118l-2.8-2.034a11000-1.1750l-2.82.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a11000-.364-1.118L2.9888.72c-.783-.57-.38-1.81.588-1.81h3.461a11000.951-.69l1.07-3.292z" /></svg>
                                            }
                                        </div>
                                        <span class="text-sm text-muted-foreground ml-2">@product.Rating.ToString("F1") (@product.ReviewCount)</span>
                                    </div>

                                    <div class="mb-4">
                                        <span class="text-2xl font-bold">$@product.Price</span>
                                        @if (product.OriginalPrice.HasValue)
                                        {
                                            <span class="text-sm text-muted-foreground line-through ml-3">$@product.OriginalPrice</span>
                                        }
                                    </div>
                                </div>

                                <div class="space-y-3">
                                    <button class="btn btn-primary w-full" onclick="event.stopPropagation(); addToCart('@product.Id')">Add to Cart</button>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-6 flex items-center justify-center">
                    @{
                        var totalPages = (int)Math.Ceiling((double)Model.TotalCount / (Model.PageSize > 0 ? Model.PageSize : 1));
                        var prev = Model.PageNumber - 1;
                        var next = Model.PageNumber + 1;
                    }
                    <div class="btn-group">
                        <a asp-controller="Shop" asp-action="Index" class="btn" asp-route-search="@Model.Search" asp-route-brand="@Model.SelectedBrand" asp-route-minPrice="@Model.SelectedMinPrice" asp-route-maxPrice="@Model.SelectedMaxPrice" asp-route-hasDiscount="@(Model.HasDiscount.HasValue? Model.HasDiscount.ToString() : null)" asp-route-isFeatured="@(Model.IsFeatured.HasValue? Model.IsFeatured.ToString() : null)" asp-route-orderBy="@Model.OrderBy" asp-route-asc="@Model.Asc" asp-route-pageNumber="@Math.Max(1, prev)" asp-route-categoryId="@Model.SelectedCategoryId">Prev</a>
                        <span class="btn">Page @Model.PageNumber of @totalPages</span>
                        <a asp-controller="Shop" asp-action="Index" class="btn" asp-route-search="@Model.Search" asp-route-brand="@Model.SelectedBrand" asp-route-minPrice="@Model.SelectedMinPrice" asp-route-maxPrice="@Model.SelectedMaxPrice" asp-route-hasDiscount="@(Model.HasDiscount.HasValue? Model.HasDiscount.ToString() : null)" asp-route-isFeatured="@(Model.IsFeatured.HasValue? Model.IsFeatured.ToString() : null)" asp-route-orderBy="@Model.OrderBy" asp-route-asc="@Model.Asc" asp-route-pageNumber="@(next <= totalPages ? next : totalPages)" asp-route-categoryId="@Model.SelectedCategoryId">Next</a>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-12">
                    <h3 class="text-lg font-medium mb-2">No products found</h3>
                    <p class="text-muted-foreground">Try adjusting your filters or browse all products.</p>
                </div>
            }
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/js/cart.js"></script>
<script>
    document.querySelectorAll('.delete-form').forEach(f => { f.addEventListener('submit', e => { e.preventDefault(); Swal.fire({ title: 'Are you sure?', text: 'Do you want to delete this product?!', icon: 'warning', showCancelButton: true, confirmButtonText: 'Yes, delete it', cancelButtonText: 'Cancel' }).then(res => { if (res.isConfirmed) f.submit(); }); }); });

    // Filter sidebar toggle (for mobile)
    document.addEventListener('DOMContentLoaded', function () {
    var toggle = document.getElementById('filterToggle');
    var sidebar = document.getElementById('filterSidebar');
    if (toggle && sidebar) {
    toggle.addEventListener('click', function (e) {
    e.preventDefault();
    sidebar.classList.toggle('hidden');
    });
    }
    });
</script>