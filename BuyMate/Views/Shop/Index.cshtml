@model BuyMate.DTO.ViewModels.ShopViewModel
@{
 ViewData["Title"] = "Shop";
}

<div class="space-y-8">
 <!-- Page Header -->
 <div class="text-center">
 <h1 class="text-3xl font-bold mb-4">Shop All Products</h1>
 <p class="text-muted-foreground">Discover our wide range of quality products</p>
 </div>

 <!-- Filters and Categories -->
 <div class="flex flex-col lg:flex-row gap-8">
 <!-- Sidebar Filters -->
 <div class="lg:w-64">
 <div class="card p-6">
 <h3 class="font-semibold mb-4">Categories</h3>
 <div class="space-y-2">
 <a asp-controller="Shop" asp-action="Index" class="block text-sm hover:text-primary transition-colors @(string.IsNullOrEmpty(Model.SelectedCategory) ? "text-primary font-medium" : "text-muted-foreground")">
 All Products
 </a>
 @foreach (var category in Model.Categories)
 {
 <a asp-controller="Shop" asp-action="Index" asp-route-category="@category.Name" class="block text-sm hover:text-primary transition-colors @(Model.SelectedCategory == category.Name ? "text-primary font-medium" : "text-muted-foreground")">
 @category.Name (@category.ProductCount)
 </a>
 }
 </div>
 </div>
 </div>

 <!-- Products Grid -->
 <div class="flex-1">
 @if (Model.Products.Any())
 {
 <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
 @foreach (var product in Model.Products)
 {
 <div class="card product-card" onclick="location.href='@Url.Action("Product", "Shop", new { id = product.Id })'">
 <div class="relative">
 <img src="@(product.ImageUrl ?? "/images/placeholder.png")" alt="@product.Name" class="w-full h-48 object-cover rounded-t-lg" />
 @if (product.IsFlashDeal)
 {
 <span class="absolute top-2 left-2 badge badge-destructive">Flash Deal</span>
 }
 @if (product.Discount.HasValue)
 {
 <span class="absolute top-2 right-2 badge badge-secondary">-@product.Discount%</span>
 }
 </div>
 <div class="card-content p-4">
 <h3 class="font-medium mb-2 line-clamp-2">@product.Name</h3>
 <p class="text-sm text-muted-foreground mb-2">@product.Brand</p>
 <div class="flex items-center mb-2">
 <div class="flex items-center">
 @for (int i =1; i <=5; i++)
 {
 <svg class="w-4 h-4 @(i <= product.Rating ? "text-yellow-400" : "text-gray-300")" fill="currentColor" viewBox="002020">
 <path d="M9.0492.927c.3-.9211.603-.9211.9020l1.073.292a11000.95.69h3.462c.96901.3711.24.5881.81l-2.82.034a11000-.3641.118l1.073.292c.3.921-.7551.688-1.541.118l-2.8-2.034a11000-1.1750l-2.82.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a11000-.364-1.118L2.988.72c-.783-.57-.38-1.81.588-1.81h3.461a11000.951-.69l1.07-3.292z"></path>
 </svg>
 }
 </div>
 <span class="text-sm text-muted-foreground ml-2">(@product.ReviewCount)</span>
 </div>
 <div class="flex items-center justify-between">
 <div>
 <span class="text-lg font-bold">$@product.Price</span>
 @if (product.OriginalPrice.HasValue)
 {
 <span class="text-sm text-muted-foreground line-through ml-2">$@product.OriginalPrice</span>
 }
 </div>
 <button class="btn btn-primary btn-sm" onclick="event.stopPropagation(); addToCart('@product.Id')">
 Add to Cart
 </button>
 </div>
 </div>
 </div>
 }
 </div>
 }
 else
 {
 <div class="text-center py-12">
 <h3 class="text-lg font-medium mb-2">No products found</h3>
 <p class="text-muted-foreground">Try adjusting your filters or browse all products.</p>
 </div>
 }
 </div>
 </div>
</div>

<script>
 function addToCart(productId) {
 fetch('/Cart/AddToCart', {
 method: 'POST',
 headers: {
 'Content-Type': 'application/x-www-form-urlencoded',
 },
 body: `productId=${productId}&quantity=1`
 })
 .then(response => {
 if (response.ok) {
 alert('Product added to cart!');
 }
 })
 .catch(error => {
 console.error('Error:', error);
 });
 }
</script>
