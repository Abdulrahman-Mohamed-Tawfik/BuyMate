@using BuyMate.DTO.ViewModels.Product
@model ProductViewModel
@{
	ViewData["Title"] = Model.Name;

	string ResolveImage(string? img)
	{
		if (string.IsNullOrWhiteSpace(img))
		{
			return Url.Content("~/images/placeholder.png");
		}
		if (img.StartsWith("http", StringComparison.OrdinalIgnoreCase))
		{
			return img!;
		}
		if (img.StartsWith("~"))
		{
			return Url.Content(img);
		}
		// Default to images folder for relative names
		return Url.Content($"~/images/{img}");
	}
}

<main class="max-w-6xl mx-auto p-4">
	<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
		<!-- Left: Image gallery -->
		<section class="space-y-4" aria-labelledby="product-image-gallery">
			<div class="aspect-square bg-gray-100 rounded-lg overflow-hidden flex items-center justify-center">
				<img id="mainImage" src="@ResolveImage(Model.ImageUrl ?? Model.ImageUrls.FirstOrDefault())" alt="@Model.Name" class="w-full h-full object-cover" />
			</div>

			@if (Model.ImageUrls != null && Model.ImageUrls.Count > 0)
			{
				<div id="thumbnails" class="grid grid-cols-4 gap-2">
					@foreach (var image in Model.ImageUrls.Take(8))
					{
						var thumbSrc = ResolveImage(image);
						<button type="button" class="aspect-square bg-gray-100 rounded-lg overflow-hidden focus:outline-none focus:ring-2" onclick="setMainImage('@thumbSrc')" aria-label="View image">
							<img src="@thumbSrc" alt="@Model.Name thumbnail" class="w-full h-full object-cover" />
						</button>
					}
				</div>
			}
		</section>

		<!-- Right: Product details -->
		<section class="space-y-6" aria-labelledby="product-details">
			<div>
				<h1 id="product-details" class="text-3xl font-bold mb-2">@Model.Name</h1>
				@if (!string.IsNullOrWhiteSpace(Model.Brand))
				{
					<p class="text-muted-foreground mb-4">by @Model.Brand</p>
				}

				<div class="flex items-center mb-4">
					<div class="flex items-center" aria-hidden="true">
						@for (int i = 1; i <= 5; i++)
						{
							if (i <= Math.Round(Model.Rating))
							{
								<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .587l3.668 7.431 8.232 1.194-5.95 5.468 1.407 8.23L12 18.896l-7.357 3.866 1.407-8.23-5.95-5.468 8.232-1.194z" /></svg>
							}
							else
							{
								<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-300" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 17.27l4.188 2.182-1.064-6.158L18.672 9l-6.25-.907L12 2 10.577 8.09 4.32 9l4.548 4.364-1.064 6.158z" clip-rule="evenodd" /></svg>
							}
						}
					</div>
					<span class="text-sm text-muted-foreground ml-2">@Model.Rating.ToString("F1") (@Model.ReviewCount review@(Model.ReviewCount == 1 ? "" : "s"))</span>
				</div>

				<div class="flex items-center space-x-4 mb-6">
					<div class="flex items-baseline space-x-3">
						<span class="text-3xl font-bold">@Model.Price.ToString("C")</span>
						@if (Model.OriginalPrice.HasValue && Model.OriginalPrice.Value > Model.Price)
						{
							<span class="text-xl text-muted-foreground line-through">@Model.OriginalPrice.Value.ToString("C")</span>
						}
						@if (Model.Discount.HasValue && Model.Discount.Value > 0)
						{
							<span class="badge badge-destructive">Save @Model.Discount.Value% </span>
						}
					</div>

					<div class="flex gap-2 items-center">
						@if (Model.IsFlashDeal)
						{
							<span class="badge badge-accent">Flash Deal</span>
						}
						@if (Model.IsFeatured)
						{
							<span class="badge">Featured</span>
						}
						@if (Model.IsBestSeller)
						{
							<span class="badge">Best Seller</span>
						}
					</div>
				</div>

				<p class="text-gray-700 mb-6">@Model.Description</p>

				<div class="flex items-center space-x-4 mb-6">
					<div class="flex items-center space-x-2">
						<label for="quantity" class="text-sm font-medium">Quantity:</label>
						<select id="quantity" class="input w-20" aria-label="Quantity">
							@for (int i = 1; i <= Math.Min(10, Math.Max(0, Model.StockQuantity)); i++)
							{
								<option value="@i">@i</option>
							}
						</select>
					</div>
					<div class="text-sm text-muted-foreground">@((Model.StockQuantity > 0) ? $"{Model.StockQuantity} items in stock" : "Out of stock")</div>
				</div>

				<div class="flex flex-col sm:flex-row sm:items-center sm:space-x-4">
					<button id="addToCartBtn" class="btn btn-primary btn-lg flex-1" type="button" onclick="addToCart('@Model.Id', event)" @(Model.StockQuantity <=0 ? "disabled" : "")>
						@(Model.StockQuantity >0 ? "Add to Cart" : "Notify Me")
					</button>
				</div>
			</div>
		</section>
	</div>

	@if (Model.Specifications != null && Model.Specifications.Count > 0)
	{
		<section class="mt-12" aria-labelledby="specs-heading">
			<h2 id="specs-heading" class="text-2xl font-bold mb-6">Specifications</h2>
			<div class="card p-6">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
					@foreach (var spec in Model.Specifications)
					{
						<div class="flex justify-between py-2 border-b">
							<span class="font-medium">@spec.Key</span>
							<span class="text-muted-foreground">@spec.Value</span>
						</div>
					}
				</div>
			</div>
		</section>
	}

	<section class="mt-12" aria-labelledby="reviews-heading">
		<h2 id="reviews-heading" class="text-2xl font-bold mb-6">Customer Reviews</h2>
		<div class="card p-6">
			<div class="text-center py-8">
				<p class="text-muted-foreground">No reviews yet. Be the first to review this product!</p>
				<button class="btn btn-primary mt-4">Write a Review</button>
			</div>
		</div>
	</section>
</main>

@section Scripts {
	<script src="~/js/shop-product.js">
		
	</script>
	<script src="~/js/cart.js"></script>
}
