@using BuyMate.DTO.ViewModels.Product
@model ProductViewModel
@{
    ViewData["Title"] = Model.Name;

    string ResolveImage(string? img)
    {
        if (string.IsNullOrWhiteSpace(img))
        {
            return Url.Content("~/images/placeholder.png");
        }
        if (img.StartsWith("http", StringComparison.OrdinalIgnoreCase))
        {
            return img!;
        }
        if (img.StartsWith("~"))
        {
            return Url.Content(img);
        }
        return Url.Content($"~/images/{img}");
    }
}

<div class="container mb-5" style="max-width: 72rem;">
    <div class="row g-4">
        <section class="col-12 col-lg-6" aria-labelledby="product-image-gallery">
            <div class="bg-light rounded-3 d-flex align-items-center justify-content-center mb-3" style="aspect-ratio: 1 / 1; overflow:hidden;">
                <img id="mainImage" src="@ResolveImage(Model.ImageUrl ?? Model.ImageUrls.FirstOrDefault())" alt="@Model.Name" class="img-fluid" style="max-height:100%;object-fit:contain;" />
            </div>

            @if (Model.ImageUrls != null && Model.ImageUrls.Count > 0)
            {
                <div id="thumbnails" class="row g-2">
                    @foreach (var image in Model.ImageUrls.Take(8))
                    {
                        var thumbSrc = ResolveImage(image);
                        <div class="col-3">
                            <button type="button" class="btn p-0 w-100 bg-light rounded-3" style="aspect-ratio:1/1;overflow:hidden;" onclick="setMainImage('@thumbSrc')" aria-label="View image">
                                <img src="@thumbSrc" alt="@Model.Name thumbnail" class="img-fluid" style="height:100%;object-fit:contain;" />
                            </button>
                        </div>
                    }
                </div>
            }
        </section>

        <section class="col-12 col-lg-6" aria-labelledby="product-details">
            <div>
                <h1 id="product-details" class="h3 fw-bold mb-2">@Model.Name</h1>
                @if (!string.IsNullOrWhiteSpace(Model.Brand))
                {
                    <p class="text-muted mb-3">by @Model.Brand</p>
                }

                <div class="d-flex align-items-center mb-3">
                    <div class="me-2" aria-hidden="true">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Round(Model.Rating))
                            {
                                <i class="fas fa-star text-warning"></i>
                            }
                            else
                            {
                                <i class="far fa-star text-muted"></i>
                            }
                        }
                    </div>
                    <span class="small text-muted">@Model.Rating.ToString("F1") (@Model.ReviewCount review@(Model.ReviewCount == 1 ? "" : "s"))</span>
                </div>

                <div class="d-flex align-items-center flex-wrap gap-3 mb-3">
                    <div class="d-flex align-items-baseline gap-2">
                        <span class="h3 fw-bold mb-0">@Model.Price.ToString("C")</span>
                        @if (Model.OriginalPrice.HasValue && Model.OriginalPrice.Value > Model.Price)
                        {
                            <span class="h5 text-muted text-decoration-line-through mb-0">@Model.OriginalPrice.Value.ToString("C")</span>
                        }
                        @if (Model.Discount.HasValue && Model.Discount.Value > 0)
                        {
                            <span class="badge bg-danger">Save @Model.Discount.Value% </span>
                        }
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        @if (Model.IsFlashDeal)
                        {
                            <span class="badge bg-warning text-dark">Flash Deal</span>
                        }
                        @if (Model.IsFeatured)
                        {
                            <span class="badge bg-dark">Featured</span>
                        }
                        @if (Model.IsBestSeller)
                        {
                            <span class="badge bg-success">Best Seller</span>
                        }
                    </div>
                </div>

                <p class="mb-3">@Model.Description</p>

                <div class="d-flex align-items-center flex-wrap gap-3 mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <label for="quantity" class="small fw-medium">Quantity:</label>
                        <select id="quantity" class="form-select form-select-sm" style="width:auto;" aria-label="Quantity">
                            @for (int i = 1; i <= Math.Min(10, Math.Max(0, Model.StockQuantity)); i++)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>
                    </div>
                    <div class="small text-muted">
                        @((Model.StockQuantity > 0) ? $"{Model.StockQuantity} items in stock" : "Out of stock")
                    </div>
                </div>

                <button id="addToCartBtn" class="btn btn-dark w-100 w-sm-auto" type="button" onclick="addToCart('@Model.Id', event)" @(Model.StockQuantity <= 0 ? "disabled" : "")>
                    @(Model.StockQuantity > 0 ? "Add to Cart" : "Notify Me")
                </button>
            </div>
        </section>
    </div>

    @if (Model.Specifications != null && Model.Specifications.Count > 0)
    {
        <section class="mt-5" aria-labelledby="specs-heading">
            <h2 id="specs-heading" class="h5 fw-bold mb-3">Specifications</h2>
            <div class="card">
                <div class="card-body">
                    <div class="row g-2">
                        @foreach (var spec in Model.Specifications)
                        {
                            <div class="col-12 col-md-6 d-flex justify-content-between border-bottom py-2">
                                <span class="fw-medium">@spec.Key</span>
                                <span class="text-muted">@spec.Value</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </section>
    }

    <section class="mt-5" aria-labelledby="reviews-heading">
        <h2 id="reviews-heading" class="h5 fw-bold mb-3">Customer Reviews</h2>
        <div class="card">
            <div class="card-body text-center py-4">
                <p class="text-muted mb-3">No reviews yet. Be the first to review this product!</p>
                <button class="btn btn-dark">Write a Review</button>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="~/js/shop-product.js"></script>
    <script src="~/js/cart.js"></script>
}
