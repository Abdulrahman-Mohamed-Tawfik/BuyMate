@model BuyMate.DTO.ViewModels.SearchViewModel
@{
    ViewData["Title"] = "Search Results";
}

<div class="space-y-8">
    <!-- Search Header -->
    <div class="text-center">
        <h1 class="text-3xl font-bold mb-4">Search Results</h1>
        @if (!string.IsNullOrEmpty(Model.Query))
        {
            <p class="text-muted-foreground">Results for "@Model.Query"</p>
        }
    </div>

    @if (Model.Results.Any())
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            @foreach (var product in Model.Results)
            {
                <div class="card product-card" onclick="location.href='@Url.Action("Product", "Shop", new { id = product.Id })'">
                    <div class="relative">
                        <img src="@(product.ImageUrl ?? "/images/placeholder.png")" alt="@product.Name" class="w-full h-48 object-cover rounded-t-lg" />
                        @if (product.IsFlashDeal)
                        {
                            <span class="absolute top-2 left-2 badge badge-destructive">Flash Deal</span>
                        }
                        @if (product.Discount.HasValue)
                        {
                            <span class="absolute top-2 right-2 badge badge-secondary">-@product.Discount%</span>
                        }
                    </div>
                    <div class="card-content p-4">
                        <h3 class="font-medium mb-2 line-clamp-2">@product.Name</h3>
                        <p class="text-sm text-muted-foreground mb-2">@product.Brand</p>
                        <div class="flex items-center mb-2">
                            <div class="flex items-center">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <svg class="w-4 h-4 @(i <= product.Rating ? "text-yellow-400" : "text-gray-300")" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
                                    </svg>
                                }
                            </div>
                            <span class="text-sm text-muted-foreground ml-2">(@product.ReviewCount)</span>
                        </div>
                        <div class="flex items-center justify-between">
                            <div>
                                <span class="text-lg font-bold">$@product.Price</span>
                                @if (product.OriginalPrice.HasValue)
                                {
                                    <span class="text-sm text-muted-foreground line-through ml-2">$@product.OriginalPrice</span>
                                }
                            </div>
                            <button class="btn btn-primary btn-sm" onclick="event.stopPropagation(); addToCart('@product.Id')">
                                Add to Cart
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-12">
            <svg class="w-24 h-24 mx-auto text-muted-foreground mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <h3 class="text-lg font-medium mb-2">No products found</h3>
            <p class="text-muted-foreground mb-6">Try searching with different keywords or browse our categories.</p>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-primary">
                Browse All Products
            </a>
        </div>
    }
</div>

<script>
    function addToCart(productId) {
        fetch('/Cart/AddToCart', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `productId=${productId}&quantity=1`
        })
        .then(response => {
            if (response.ok) {
                alert('Product added to cart!');
            }
        })
        .catch(error => {
            console.error('Error:', error);
        });
    }
</script>
