@model BuyMate.DTO.ViewModels.ProfileViewModel
@{
 ViewData["Title"] = "Edit Profile";
}


<div class="max-w-2xl mx-auto">
 <h1 class="text-3xl font-bold mb-8">Edit Profile</h1>

 <form asp-action="EditProfile" method="post" enctype="multipart/form-data" class="space-y-6">
 <div class="card p-6">
 <h2 class="text-xl font-bold mb-4">Personal Information</h2>

 <div class="space-y-4">
 <div class="grid grid-cols-2 gap-4">
 <div>
 <label asp-for="FirstName" class="block text-sm font-medium mb-2">First Name</label>
 <input asp-for="FirstName" class="input w-full" />
 <span asp-validation-for="FirstName" class="text-sm text-destructive"></span>
 </div>
 <div>
 <label asp-for="LastName" class="block text-sm font-medium mb-2">Last Name</label>
 <input asp-for="LastName" class="input w-full" />
 <span asp-validation-for="LastName" class="text-sm text-destructive"></span>
 </div>
 </div>

 <div>
 <label asp-for="Email" class="block text-sm font-medium mb-2">Email Address</label>
 <input asp-for="Email" type="email" class="input w-full" />
 <span asp-validation-for="Email" class="text-sm text-destructive"></span>

 </div>

 <div class="grid grid-cols-2 gap-4">
 <div>
 <label asp-for="Phone" class="block text-sm font-medium mb-2">Phone Number</label>
 <input asp-for="Phone" type="tel" class="input w-full" />
 <span asp-validation-for="Phone" class="text-sm text-destructive"></span>
 </div>
 <div>
 <label asp-for="BirthDate" class="block text-sm font-medium mb-2">Birth Date</label>
 <input asp-for="BirthDate" type="date" class="input w-full" />
 </div>
 </div>

 <div>
 <label asp-for="Gender" class="block text-sm font-medium mb-2">Gender</label>
 <select asp-for="Gender" class="input w-48">
 <option value="0">Unspecified</option>
 <option value="1">Male</option>
 <option value="2">Female</option>
 </select>
 </div>

 <div>
 <label asp-for="Address" class="block text-sm font-medium mb-2">Address</label>
 <input asp-for="Address" class="input w-full" />
 </div>

 <div>
 <label class="block text-sm font-medium mb-2">Profile Picture</label>
 <div class="flex items-center space-x-4">
 @if (!string.IsNullOrEmpty(Model.Avatar))
 {
 <img src="/images/@Model.Avatar" alt="Profile" class="w-16 h-16 rounded-full object-cover" />
 }
 <input name="avatarFile" type="file" accept="image/*" class="input" />
 </div>
 </div>
 </div>
 </div>

 <div class="flex space-x-4">
 <button type="submit" class="btn btn-primary">Save Changes</button>
 <a asp-action="Profile" class="btn btn-secondary">Cancel</a>
 </div>
 </form>
</div>
