@using BuyMate.DTO.ViewModels.User
@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "_AuthLayout";

}


<div class="max-w-md mx-auto">
    <div class="card p-8">
        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold mb-2">Welcome Back</h1>
            <p class="text-muted-foreground">Sign in to your account to continue</p>
        </div>

        <form asp-action="Login" method="post" class="space-y-6">
            <div>
                <label asp-for="Email" class="block text-sm font-medium mb-2">Email Address</label>
                <input asp-for="Email" type="email" class="input w-full" placeholder="Enter your email" />
                <span asp-validation-for="Email" class="text-sm text-destructive"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-medium mb-2">Password</label>
                <input asp-for="Password" id="LoginPassword" type="password" class="input w-full" placeholder="Enter your password" />
                <span asp-validation-for="Password" class="text-sm text-destructive"></span>
            </div>

            <div class="flex items-center space-x-2">
                <input id="showPasswordLogin" type="checkbox" class="mr-2" />
                <label for="showPasswordLogin" class="text-sm">Show password</label>
            </div>

            <div class="flex items-center justify-between">
                <div class="flex items-center">
                    <input asp-for="RememberMe" type="checkbox" class="mr-2" />
                    <label asp-for="RememberMe" class="text-sm">Remember me</label>
                </div>
                <a href="#" class="text-sm text-primary hover:underline">Forgot password?</a>
            </div>

            <button type="submit" class="btn btn-primary w-full btn-lg">Sign In</button>
        </form>

        <div class="mt-6 text-center">
            <p class="text-sm text-muted-foreground">
                Don't have an account?
                <a asp-action="Register" class="text-primary hover:underline">Sign up</a>
            </p>
        </div>
    </div>
</div>

<script src="~/js/user-login.js">
   
</script>


