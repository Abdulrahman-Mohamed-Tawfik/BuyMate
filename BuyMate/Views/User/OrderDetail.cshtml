@using BuyMate.DTO.ViewModels.Order
@model OrderViewModel
@{
    ViewData["Title"] = "Order Details";
}

<div class="container mb-5" style="max-width: 48rem;">
    <div class="mb-3">
        <a asp-controller="Account" asp-action="Orders" class="btn btn-outline-secondary btn-sm mb-2">
            <i class="fas fa-arrow-left me-1"></i> Back to Orders
        </a>
        <h1 class="h4 fw-bold mb-1">Order #@Model.Id</h1>
        <p class="small text-muted mb-0">Placed on @Model.OrderDate.ToString("MMM dd, yyyy 'at' h:mm tt")</p>
    </div>

    <div class="row g-3 small">
        <div class="col-12 col-lg-8 d-flex flex-column gap-3">
            <div class="card p-3">
                <h2 class="h6 fw-bold mb-2">Order Items</h2>
                <div class="d-flex flex-column gap-2">
                    @foreach (var item in Model.Items)
                    {
                        <div class="d-flex align-items-center gap-3">
                            <img src="@(item.ImageUrl ?? "/images/placeholder.png")" alt="@item.ProductName" class="rounded" style="width:80px;height:80px;object-fit:contain;" />
                            <div class="flex-grow-1">
                                <h3 class="fw-semibold mb-0">@item.ProductName</h3>
                                <p class="text-muted mb-0">@item.Brand</p>
                                <p class="text-muted mb-0">Quantity: @item.Quantity</p>
                            </div>
                            <div class="text-end">
                                <p class="fw-semibold mb-0">$@item.UnitPrice</p>
                                <p class="text-muted mb-0">Total: $@item.TotalPrice</p>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="card p-3">
                <h2 class="h6 fw-bold mb-2">Shipping Address</h2>
                <p class="text-muted mb-0">@Model.Address.Street</p>
                <p class="text-muted mb-0">@Model.Address.City, @Model.Address.State @Model.Address.ZipCode</p>
            </div>
        </div>

        <div class="col-12 col-lg-4 d-flex flex-column gap-3">
            <div class="card p-3">
                <h2 class="h6 fw-bold mb-2">Order Summary</h2>
                <div class="d-flex flex-column gap-1">
                    <div class="d-flex justify-content-between"><span>Subtotal</span><span>$@Model.Items.Sum(item => item.TotalPrice)</span></div>
                    <div class="d-flex justify-content-between"><span>Shipping</span><span>Free</span></div>
                    <div class="d-flex justify-content-between"><span>Tax</span><span>$0.00</span></div>
                    <hr class="my-2" />
                    <div class="d-flex justify-content-between fw-bold"><span>Total</span><span>$@Model.Total</span></div>
                </div>
            </div>

            <div class="card p-3">
                <h2 class="h6 fw-bold mb-2">Order Status</h2>
                <div class="d-flex flex-column gap-2">
                    <div class="d-flex align-items-center">
                        <span class="rounded-circle bg-success me-2" style="width:0.75rem;height:0.75rem;"></span>
                        <span>Order Placed</span>
                        <span class="text-muted ms-auto">@Model.OrderDate.ToString("MMM dd")</span>
                    </div>

                    @if (Model.Status == OrderStatusViewModel.Confirmed || Model.Status == OrderStatusViewModel.Shipped || Model.Status == OrderStatusViewModel.Delivered)
                    {
                        <div class="d-flex align-items-center">
                            <span class="rounded-circle bg-success me-2" style="width:0.75rem;height:0.75rem;"></span>
                            <span>Order Confirmed</span>
                        </div>
                    }

                    @if (Model.Status == OrderStatusViewModel.Shipped || Model.Status == OrderStatusViewModel.Delivered)
                    {
                        <div class="d-flex align-items-center">
                            <span class="rounded-circle bg-success me-2" style="width:0.75rem;height:0.75rem;"></span>
                            <span>Shipped</span>
                            @if (!string.IsNullOrEmpty(Model.TrackingId))
                            {
                                <span class="text-muted ms-auto">@Model.TrackingId</span>
                            }
                        </div>
                    }

                    @if (Model.Status == OrderStatusViewModel.Delivered)
                    {
                        <div class="d-flex align-items-center">
                            <span class="rounded-circle bg-success me-2" style="width:0.75rem;height:0.75rem;"></span>
                            <span>Delivered</span>
                            @if (Model.ActualDelivery.HasValue)
                            {
                                <span class="text-muted ms-auto">@Model.ActualDelivery.Value.ToString("MMM dd")</span>
                            }
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.TrackingId))
                {
                    <div class="mt-2 pt-2 border-top">
                        <p class="text-muted mb-1">Tracking Number</p>
                        <p class="font-monospace mb-0">@Model.TrackingId</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
