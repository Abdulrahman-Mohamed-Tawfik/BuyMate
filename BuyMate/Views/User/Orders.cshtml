@using BuyMate.DTO.ViewModels.Order
@model List<OrderViewModel>
@{
    ViewData["Title"] = "My Orders";
}

<div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold mb-8">My Orders</h1>

    @if (Model.Any())
    {
        <div class="space-y-6">
            @foreach (var order in Model)
            {
                <div class="card p-6">
                    <div class="flex items-center justify-between mb-4">
                        <div>
                            <h3 class="font-semibold">Order #@order.Id</h3>
                            <p class="text-sm text-muted-foreground">Placed on @order.OrderDate.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div class="text-right">
                            <span class="badge @(order.Status == OrderStatusViewModel.Delivered ? "badge-secondary" : order.Status == OrderStatusViewModel.Shipped ? "badge-secondary" : "badge-destructive")">
                                @order.Status
                            </span>
                            <p class="text-sm font-medium mt-1">$@order.Total</p>
                        </div>
                    </div>

                    <div class="space-y-3">
                        @foreach (var item in order.Items)
                        {
                            <div class="flex items-center space-x-4">
                                <img src="@(item.ImageUrl ?? "/images/placeholder.png")" alt="@item.ProductName" class="w-16 h-16 object-cover rounded-lg" />
                                <div class="flex-1">
                                    <h4 class="font-medium">@item.ProductName</h4>
                                    <p class="text-sm text-muted-foreground">Qty: @item.Quantity</p>
                                </div>
                                <span class="font-medium">$@item.TotalPrice</span>
                            </div>
                        }
                    </div>

                    <div class="flex items-center justify-between mt-4 pt-4 border-t">
                        <div class="text-sm text-muted-foreground">
                            @if (!string.IsNullOrEmpty(order.TrackingId))
                            {
                                <p>Tracking: @order.TrackingId</p>
                            }
                            @if (order.EstimatedDelivery.HasValue)
                            {
                                <p>Estimated delivery: @order.EstimatedDelivery.Value.ToString("MMM dd, yyyy")</p>
                            }
                        </div>
                        <a asp-controller="Account" asp-action="OrderDetail" asp-route-id="@order.Id" class="btn btn-secondary btn-sm">
                            View Details
                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-12">
            <svg class="w-24 h-24 mx-auto text-muted-foreground mb-4" fill="none" stroke="currentColor" viewBox="002424">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M95H7a22000-22v10a2200022h8a220002-2V7a22000-2-2h-2M95a2200022h2a220002-2M95a220012-2h2a2200122"></path>
            </svg>
            <h2 class="text-2xl font-bold mb-2">No orders yet</h2>
            <p class="text-muted-foreground mb-6">When you place your first order, it will appear here.</p>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-primary btn-lg">
                Start Shopping
            </a>
        </div>
    }
</div>
