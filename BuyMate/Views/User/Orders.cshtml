@using BuyMate.DTO.ViewModels.Order
@model List<OrderViewModel>
@{
    ViewData["Title"] = "My Orders";
}

<div class="container mb-5" style="max-width: 48rem;">
    <h1 class="h4 fw-bold mb-3">My Orders</h1>

    @if (Model.Any())
    {
        <div class="d-flex flex-column gap-3 small">
            @foreach (var order in Model)
            {
                <div class="card p-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h3 class="fw-semibold mb-0">Order #@order.Id</h3>
                            <p class="text-muted mb-0">Placed on @order.OrderDate.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div class="text-end">
                            <span class="badge rounded-pill @(
                                order.Status == OrderStatusViewModel.Delivered ? "bg-success" :
                                order.Status == OrderStatusViewModel.Shipped ? "bg-primary" : "bg-danger")">
                                @order.Status
                            </span>
                            <p class="fw-semibold mt-1 mb-0">$@order.Total</p>
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-2">
                        @foreach (var item in order.Items)
                        {
                            <div class="d-flex align-items-center gap-3">
                                <img src="@(item.ImageUrl ?? "/images/placeholder.png")" alt="@item.ProductName" class="rounded" style="width:64px;height:64px;object-fit:contain;" />
                                <div class="flex-grow-1">
                                    <h4 class="fw-semibold mb-0">@item.ProductName</h4>
                                    <p class="text-muted mb-0">Qty: @item.Quantity</p>
                                </div>
                                <span class="fw-semibold">$@item.TotalPrice</span>
                            </div>
                        }
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
                        <div class="text-muted">
                            @if (!string.IsNullOrEmpty(order.TrackingId))
                            {
                                <p class="mb-0">Tracking: @order.TrackingId</p>
                            }
                            @if (order.EstimatedDelivery.HasValue)
                            {
                                <p class="mb-0">Estimated delivery: @order.EstimatedDelivery.Value.ToString("MMM dd, yyyy")</p>
                            }
                        </div>
                        <a asp-controller="Account" asp-action="OrderDetail" asp-route-id="@order.Id" class="btn btn-outline-secondary btn-sm">
                            View Details
                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="far fa-file-alt fa-3x text-muted mb-2"></i>
            <h2 class="h5 fw-bold mb-1">No orders yet</h2>
            <p class="text-muted mb-3">When you place your first order, it will appear here.</p>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-primary btn-sm">
                Start Shopping
            </a>
        </div>
    }
</div>
