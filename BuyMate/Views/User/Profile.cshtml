@using BuyMate.DTO.ViewModels.User
@model ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    string gender = "Unspecified";

    if (Model.Gender == 1)
    {
        gender = "Male";
    }
    else if (Model.Gender == 2)
    {
        gender = "Female";
    }
}

<div class="container mb-5" style="max-width: 64rem;">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <h1 class="h4 fw-bold mb-0">My Profile</h1>
        <a asp-controller="User" asp-action="EditProfile" class="btn btn-primary">Edit Profile</a>
    </div>

    <div class="d-flex flex-column gap-4">
        <div class="card p-4">
            <h2 class="h5 fw-bold mb-3">Personal Information</h2>
            <form>
                <div class="row g-3 mb-2">
                    <div class="col-12 col-md-6">
                        <label class="form-label small">First Name</label>
                        <input type="text" class="form-control" value="@Model.FirstName" readonly />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label small">Last Name</label>
                        <input type="text" class="form-control" value="@Model.LastName" readonly />
                    </div>
                </div>
                <div class="mb-2">
                    <label class="form-label small">Email Address</label>
                    <input type="email" class="form-control" value="@Model.Email" readonly />
                </div>
                <div class="mb-2">
                    <label class="form-label small">Phone Number</label>
                    <input type="tel" class="form-control" value="@Model.Phone" readonly />
                </div>
                <div class="mb-2">
                    <label class="form-label small">Address</label>
                    <input type="text" class="form-control" value="@(!string.IsNullOrEmpty(Model.Address) ? Model.Address : "No address added")" readonly />
                </div>
                <div class="mb-2">
                    <label class="form-label small">Gender</label>
                    <input type="text" class="form-control" value="@gender" readonly />
                </div>
                <div class="mb-2">
                    <label class="form-label small">Date of Birth</label>
                    <input type="date" class="form-control" value="@(Model.BirthDate.HasValue? Model.BirthDate.Value.ToString("yyyy-MM-dd") : string.Empty)" readonly />
                </div>
                <div class="mb-2">
                    <label class="form-label small">Profile Picture</label>
                    <div class="d-flex align-items-center gap-3 mt-1">
                        @if (!string.IsNullOrEmpty(Model.Avatar))
                        {
                            <img src="/images/@Model.Avatar" alt="Avatar" class="rounded-circle" style="width:80px;height:80px;object-fit:contain;" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width:80px;height:80px;">
                                <i class="fas fa-user text-muted fa-2x"></i>
                            </div>
                        }

                        <a asp-controller="User" asp-action="EditProfile" class="btn btn-outline-secondary">Change Photo / Edit</a>
                    </div>
                </div>
            </form>
        </div>

        <div class="card p-4">
            <h2 class="h5 fw-bold mb-3">Account Settings</h2>
            <div class="d-flex flex-column gap-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h3 class="small fw-bold mb-1">Email Notifications</h3>
                        <p class="small text-muted mb-0">Receive updates about your orders and promotions</p>
                    </div>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="emailNotif" checked>
                    </div>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h3 class="small fw-bold mb-1">SMS Notifications</h3>
                        <p class="small text-muted mb-0">Receive text messages about your orders</p>
                    </div>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="smsNotif">
                    </div>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h3 class="small fw-bold mb-1">Marketing Emails</h3>
                        <p class="small text-muted mb-0">Receive promotional offers and product updates</p>
                    </div>
                    <div class="form-check form-switch mb-0">
                        <input class="form-check-input" type="checkbox" id="marketingNotif" checked>
                    </div>
                </div>
            </div>
        </div>

        <div class="card p-4">
            <h2 class="h5 fw-bold mb-3">Security</h2>
            <div class="d-flex flex-column gap-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h3 class="small fw-bold mb-1">Change Password</h3>
                        <p class="small text-muted mb-0">Update your account password</p>
                    </div>
                    <a asp-controller="User" asp-action="EditProfile" class="btn btn-outline-secondary btn-sm">Change</a>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h3 class="small fw-bold mb-1">Two-Factor Authentication</h3>
                        <p class="small text-muted mb-0">Add an extra layer of security to your account</p>
                    </div>
                    <a asp-controller="User" asp-action="EditProfile" class="btn btn-outline-secondary btn-sm">Enable</a>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h3 class="small fw-bold mb-1">Login Activity</h3>
                        <p class="small text-muted mb-0">View recent login attempts and sessions</p>
                    </div>
                    <a asp-controller="User" asp-action="EditProfile" class="btn btn-outline-secondary btn-sm">View</a>
                </div>
            </div>
        </div>

        <div class="card p-4">
            <h2 class="h5 fw-bold mb-3">Account Actions</h2>
            <div class="d-flex flex-column gap-3">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h3 class="small fw-bold mb-1">Download Data</h3>
                        <p class="small text-muted mb-0">Download a copy of your personal data</p>
                    </div>
                    <a asp-controller="User" asp-action="EditProfile" class="btn btn-outline-secondary btn-sm">Download</a>
                </div>
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <h3 class="small fw-bold mb-1">Delete Account</h3>
                        <p class="small text-muted mb-0">Permanently delete your account and all data</p>
                    </div>
                    <form asp-controller="User" asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete your account?');">
                        <button type="button" class="btn btn-danger btn-sm" disabled>Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

