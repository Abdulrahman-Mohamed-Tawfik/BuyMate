@using BuyMate.DTO.ViewModels.User
@model ProfileViewModel
@{
	ViewData["Title"] = "My Profile";
	string gender = "Unspecified";
	
	if (Model.Gender == 1)
	{
		gender = "Male";
	}
	else if(Model.Gender == 2)
	{
		gender = "Female";
	}
}


<div class="max-w-4xl mx-auto">
	<div class="flex items-center justify-between mb-6">
		<h1 class="text-3xl font-bold">My Profile</h1>
		<a asp-controller="User" asp-action="EditProfile" class="btn btn-primary">Edit Profile</a>
	</div>

	<div class="space-y-8">
		<div class="card p-8">
			<h2 class="text-2xl font-bold mb-6">Personal Information</h2>
			<form class="space-y-6">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					<div>
						<label class="block text-sm font-medium mb-2">First Name</label>
						<input type="text" class="input w-full" value="@Model.FirstName" readonly />
					</div>
					<div>
						<label class="block text-sm font-medium mb-2">Last Name</label>
						<input type="text" class="input w-full" value="@Model.LastName" readonly />
					</div>
				</div>
				<div>
					<label class="block text-sm font-medium mb-2">Email Address</label>
					<input type="email" class="input w-full" value="@Model.Email" readonly />
				</div>
				<div>
					<label class="block text-sm font-medium mb-2">Phone Number</label>
					<input type="tel" class="input w-full" value="@Model.Phone" readonly />
				</div>

				<div>
					<label class="block text-sm font-medium mb-2">Address</label>
					<input type="email"
						   class="input w-full"
						   value="@(!string.IsNullOrEmpty(Model.Address) ? Model.Address : "No address added")"
						   readonly />
				</div>

				<div>
					<label class="block text-sm font-medium mb-2">Gender</label>
					<input type="email" class="input w-full" value="@gender" readonly />
				</div>

				<div>
					<label class="block text-sm font-medium mb-2">Date of Birth</label>
					<input type="date" class="input w-full" value="@(Model.BirthDate.HasValue? Model.BirthDate.Value.ToString("yyyy-MM-dd") : string.Empty)" readonly />
				</div>
				<div>
					<label class="block text-sm font-medium mb-2">Profile Picture</label>
					<div class="flex items-center space-x-4">
						@if (!string.IsNullOrEmpty(Model.Avatar))
						{
							<img src="/images/@Model.Avatar" alt="Avatar" class="w-20 h-20 rounded-full object-contain" />
						}
						else
						{
							<div class="w-20 h-20 rounded-full bg-muted flex items-center justify-center">
								<svg class="w-10 h-10 text-muted-foreground" fill="none" stroke="currentColor" viewBox="002424">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M167a44011-804400180zM1214a77000-77h14a77000-7-7z"></path>
								</svg>
							</div>
						}

						<a asp-controller="User" asp-action="EditProfile" class="btn btn-secondary">Change Photo / Edit</a>
					</div>
				</div>
			</form>
		</div>

		

		<div class="card p-8">
			<h2 class="text-2xl font-bold mb-6">Account Settings</h2>
			<div class="space-y-6">
				<div class="flex items-center justify-between">
					<div>
						<h3 class="font-bold">Email Notifications</h3>
						<p class="text-sm text-muted-foreground">Receive updates about your orders and promotions</p>
					</div>
					<label class="switch">
						<input type="checkbox" checked />
						<span class="slider"></span>
					</label>
				</div>
				<div class="flex items-center justify-between">
					<div>
						<h3 class="font-bold">SMS Notifications</h3>
						<p class="text-sm text-muted-foreground">Receive text messages about your orders</p>
					</div>
					<label class="switch">
						<input type="checkbox" />
						<span class="slider"></span>
					</label>
				</div>
				<div class="flex items-center justify-between">
					<div>
						<h3 class="font-bold">Marketing Emails</h3>
						<p class="text-sm text-muted-foreground">Receive promotional offers and product updates</p>
					</div>
					<label class="switch">
						<input type="checkbox" checked />
						<span class="slider"></span>
					</label>
				</div>
			</div>
		</div>

		<div class="card p-8">
			<h2 class="text-2xl font-bold mb-6">Security</h2>
			<div class="space-y-4">
				<div class="flex items-center justify-between">
					<div>
						<h3 class="font-bold">Change Password</h3>
						<p class="text-sm text-muted-foreground">Update your account password</p>
					</div>
					<a asp-controller="User" asp-action="EditProfile" class="btn btn-secondary">Change</a>
				</div>
				<div class="flex items-center justify-between">
					<div>
						<h3 class="font-bold">Two-Factor Authentication</h3>
						<p class="text-sm text-muted-foreground">Add an extra layer of security to your account</p>
					</div>
					<a asp-controller="User" asp-action="EditProfile" class="btn btn-secondary">Enable</a>
				</div>
				<div class="flex items-center justify-between">
					<div>
						<h3 class="font-bold">Login Activity</h3>
						<p class="text-sm text-muted-foreground">View recent login attempts and sessions</p>
					</div>
					<a asp-controller="User" asp-action="EditProfile" class="btn btn-secondary">View</a>
				</div>
			</div>
		</div>

		<div class="card p-8">
			<h2 class="text-2xl font-bold mb-6">Account Actions</h2>
			<div class="space-y-4">
				<div class="flex items-center justify-between">
					<div>
						<h3 class="font-bold">Download Data</h3>
						<p class="text-sm text-muted-foreground">Download a copy of your personal data</p>
					</div>
					<a asp-controller="User" asp-action="EditProfile" class="btn btn-secondary">Download</a>
				</div>
				<div class="flex items-center justify-between">
					<div>
						<h3 class="font-bold">Delete Account</h3>
						<p class="text-sm text-muted-foreground">Permanently delete your account and all data</p>
					</div>
					<form asp-controller="User" asp-action="Delete" method="post" onsubmit="return confirm('Are you sure you want to delete your account?');">
						<button type="button" class="btn btn-destructive" disabled>Delete</button>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>

