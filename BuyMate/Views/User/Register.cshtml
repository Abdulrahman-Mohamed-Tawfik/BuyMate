@using BuyMate.DTO.ViewModels
@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="max-w-md mx-auto">
    <div class="card p-8">
        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold mb-2">Create Account</h1>
            <p class="text-muted-foreground">Join BUYMATE and start shopping</p>
        </div>

        <form asp-action="Register" method="post" class="space-y-6" asp-antiforgery="true">
            <div asp-validation-summary="ModelOnly" class="text-sm text-destructive"></div>

            <div>
                <label asp-for="Name" class="block text-sm font-medium mb-2">Full Name</label>
                <input asp-for="Name" type="text" class="input w-full" placeholder="Enter your full name" />
                <span asp-validation-for="Name" class="text-sm text-destructive"></span>
            </div>

            <div>
                <label asp-for="Email" class="block text-sm font-medium mb-2">Email Address</label>
                <input asp-for="Email" type="email" class="input w-full" placeholder="Enter your email" />
                <span asp-validation-for="Email" class="text-sm text-destructive"></span>
            </div>

            <div>
                <label asp-for="Phone" class="block text-sm font-medium mb-2">Phone Number</label>
                <input asp-for="Phone" type="tel" class="input w-full" placeholder="Enter your phone number" />
                <span asp-validation-for="Phone" class="text-sm text-destructive"></span>
            </div>

            <div>
                <label asp-for="Password" class="block text-sm font-medium mb-2">Password</label>
                <input asp-for="Password" type="password" class="input w-full" placeholder="Create a password" />
                <span asp-validation-for="Password" class="text-sm text-destructive"></span>
            </div>

            <div>
                <label asp-for="ConfirmPassword" class="block text-sm font-medium mb-2">Confirm Password</label>
                <input asp-for="ConfirmPassword" type="password" class="input w-full" placeholder="Confirm your password" />
                <span asp-validation-for="ConfirmPassword" class="text-sm text-destructive"></span>
            </div>

            <button type="submit" class="btn btn-primary w-full btn-lg">Create Account</button>
        </form>

        <div class="mt-6 text-center">
            <p class="text-sm text-muted-foreground">
                Already have an account?
                <a asp-action="Login" class="text-primary hover:underline">Sign in</a>
            </p>
        </div>
    </div>
</div>