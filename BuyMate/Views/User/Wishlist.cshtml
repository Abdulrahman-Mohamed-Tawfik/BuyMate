@using BuyMate.DTO.ViewModels.Wishlist
@model WishlistViewModel
@{
    ViewData["Title"] = "Wishlist";
}

<div class="container mb-5" style="max-width: 72rem;">
    <h1 class="h4 fw-bold mb-3">My Wishlist</h1>

    @if (Model.Items.Any())
    {
        <div class="row g-3 small">
            @foreach (var item in Model.Items)
            {
                <div class="col-12 col-sm-6 col-lg-3">
                    <div class="card h-100" style="cursor:pointer;" onclick="location.href='@Url.Action("Product", "Shop", new { id = item.ProductId })'">
                        <div class="position-relative">
                            <img src="@(item.ImageUrl ?? "/images/placeholder.png")" alt="@item.ProductName" class="card-img-top p-2" style="height:12rem;object-fit:contain;" />
                            <button class="btn btn-outline-danger btn-sm position-absolute" style="top:0.4rem;right:0.4rem;" onclick="event.stopPropagation(); removeFromWishlist('@item.ProductId')">
                                <i class="fas fa-heart-broken"></i>
                            </button>
                        </div>
                        <div class="card-body p-2 d-flex flex-column">
                            <h3 class="fw-semibold mb-1" style="font-size:0.95rem;">@item.ProductName</h3>
                            <p class="text-muted mb-1">@item.Brand</p>
                            <div class="d-flex align-items-center mb-1">
                                <div class="text-warning me-1">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fas fa-star @(i <= item.Rating ? string.Empty : "text-secondary")" style="font-size:0.75rem;"></i>
                                    }
                                </div>
                                <span class="text-muted">(@item.ReviewCount)</span>
                            </div>
                            <div class="d-flex align-items-center justify-content-between mt-auto">
                                <div>
                                    <span class="fw-bold text-dark">$@item.Price</span>
                                    @if (item.OriginalPrice.HasValue)
                                    {
                                        <span class="text-muted text-decoration-line-through ms-1">$@item.OriginalPrice</span>
                                    }
                                </div>
                                <button class="btn btn-dark btn-sm" onclick="event.stopPropagation(); addToCart('@item.ProductId')">
                                    Add to Cart
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="far fa-heart fa-3x text-muted mb-2"></i>
            <h2 class="h5 fw-bold mb-1">Your wishlist is empty</h2>
            <p class="text-muted mb-3">Save items you love for later by adding them to your wishlist.</p>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-dark btn-sm">
                Start Shopping
            </a>
        </div>
    }
</div>

<script src="~/js/user-wishlist.js"></script>
